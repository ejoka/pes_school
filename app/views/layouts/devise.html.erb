<!DOCTYPE html>
<html>
  <head>
    <title>School Management System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <style>
      * {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
      }
      
      body {
        background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
        min-height: 100vh;
      }
      
      /* Split screen layout */
      .split-container {
        display: flex;
        min-height: 100vh;
      }
      
      /* Left side - Branding */
      .brand-side {
        flex: 1;
        background: linear-gradient(135deg, rgba(30, 58, 138, 0.95) 0%, rgba(30, 64, 175, 0.95) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
        overflow-y: auto;
      }
      
      .brand-content {
        max-width: 480px;
        color: white;
        text-align: center;
      }
      
      .brand-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
      }
      
      .brand-logo img {
        max-width: 180px;
        max-height: 80px;
        object-fit: contain;
      }
      
      /* Fallback logo if no image uploaded */
      .brand-logo-fallback {
        width: 80px;
        height: 80px;
        background: #eab308;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
      }
      
      .brand-logo-fallback svg {
        width: 40px;
        height: 40px;
      }
      
      .brand-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        line-height: 1.3;
        color: #eab308;
      }
      
      .brand-description {
        font-size: 1rem;
        line-height: 1.6;
        opacity: 0.9;
        margin-bottom: 1.5rem;
      }
      
      .feature-list {
        list-style: none;
        margin-top: 1.5rem;
        text-align: left;
      }
      
      .feature-list li {
        display: flex;
        align-items: center;
        margin-bottom: 0.75rem;
        font-size: 0.875rem;
      }
      
      .feature-list li svg {
        width: 18px;
        height: 18px;
        margin-right: 0.75rem;
        flex-shrink: 0;
      }
      
      /* Right side - Form */
      .form-side {
        flex: 1;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        overflow-y: auto;
      }
      
      .form-container {
        max-width: 420px;
        width: 100%;
      }
      
      .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        transition: all 0.2s;
      }
      
      .form-input:focus {
        outline: none;
        border-color: #1e3a8a;
        box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
      }
      
      .form-button {
        width: 100%;
        padding: 0.75rem 1rem;
        background: #1e3a8a;
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
      }
      
      .form-button:hover {
        background: #1e40af;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(30, 58, 138, 0.4);
      }
      
      .form-link {
        color: #1e3a8a;
        text-decoration: none;
        font-weight: 500;
      }
      
      .form-link:hover {
        color: #1e40af;
        text-decoration: underline;
      }
      
      @media (max-width: 768px) {
        .split-container {
          flex-direction: column;
        }
        
        .brand-side {
          padding: 2rem;
        }
        
        .brand-title {
          font-size: 1.5rem;
        }
        
        .brand-logo img {
          max-width: 140px;
        }
      }
    </style>
  </head>
  
  <body>
    <div class="split-container">
      <!-- Left Side - Branding with School Logo -->
      <div class="brand-side">
        <div class="brand-content">
          <!-- School Logo -->
          <div class="brand-logo">
            <% logo_setting = Setting.find_by(key: 'logo') %>
            <% if logo_setting&.logo&.attached? %>
              <%= image_tag url_for(logo_setting.logo), alt: "School Logo", class: "max-w-[180px] max-h-[80px] object-contain" %>
            <% else %>
              <div class="brand-logo-fallback">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke="#1e3a8a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            <% end %>
          </div>
          
          <!-- School Name from Settings -->
          <h1 class="brand-title">
            <%= Setting.get('school_name', 'School Management System') %>
          </h1>
          
          <p class="brand-description">
            Streamline school operations with this comprehensive management solution.
          </p>
          
          <ul class="feature-list">
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2">
                <path d="M16.6667 5L7.5 14.1667L3.33333 10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Student Management
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2">
                <path d="M16.6667 5L7.5 14.1667L3.33333 10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Fee Tracking & Invoices
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2">
                <path d="M16.6667 5L7.5 14.1667L3.33333 10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Academic Management
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="white" stroke-width="2">
                <path d="M16.6667 5L7.5 14.1667L3.33333 10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Transport & Inventory
            </li>
          </ul>
        </div>
      </div>
      
      <!-- Right Side - Form -->
      <div class="form-side">
        <div class="form-container">
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>