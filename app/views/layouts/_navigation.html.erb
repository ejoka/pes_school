<body class="bg-gray-100 font-sans antialiased">
    <% if user_signed_in? %>
      <!-- Mobile Sidebar Overlay -->
      <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
      
      <div class="flex min-h-screen">
       <!-- Sidebar -->
        <aside id="sidebar" class="sidebar flex flex-col overflow-y-auto">
          <!-- Logo Area -->
          <div class="flex items-center justify-between h-16 px-4 bg-blue-900 border-b border-blue-800">
            <div class="flex items-center space-x-2">
              <%= school_logo %>
              <span class="text-yellow-500 font-bold text-lg">School Mgmt</span>
            </div>
            <button id="closeSidebarBtn" class="mobile-menu-btn text-yellow-500 hover:text-yellow-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <!-- User Info -->
          <div class="px-4 py-3 bg-blue-800 bg-opacity-30 border-b border-blue-800">
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 bg-yellow-500 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-blue-900 font-bold text-sm"><%= current_user.first_name[0].upcase %></span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate"><%= current_user.full_name %></p>
                <p class="text-xs text-yellow-500 truncate"><%= current_user.role.capitalize %></p>
              </div>
            </div>
          </div>

        <!-- Navigation Menu -->
        <nav class="flex-1 overflow-y-auto py-4">
          <div class="px-3 space-y-1">
            
            <!-- Dashboard Link -->
            <% if current_user.admin? %>
              <%= link_to admin_dashboard_path, class: "menu-item flex items-center px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out #{current_page?(admin_dashboard_path) ? 'bg-yellow-500 text-blue-900 shadow-md' : 'text-white hover:bg-blue-800'}" do %>
                <svg class="w-5 h-5 mr-3 <%= current_page?(admin_dashboard_path) ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                <span>Dashboard</span>
              <% end %>
            <% else %>
              <%= link_to dashboard_path, class: "menu-item flex items-center px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out #{current_page?(dashboard_path) ? 'bg-yellow-500 text-blue-900 shadow-md' : 'text-white hover:bg-blue-800'}" do %>
                <svg class="w-5 h-5 mr-3 <%= current_page?(dashboard_path) ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                <span>Dashboard</span>
              <% end %>
            <% end %>

            <!-- ==================== FOR NON-ADMIN USERS ==================== -->
            <% if !current_user.admin? %>
              <!-- My Categories -->
              <% if current_user.assigned_categories.any? %>
                <div x-data="{ open: false }">
                  <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                    <div class="flex items-center">
                      <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                      </svg>
                      <span>My Categories</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                    <% current_user.assigned_categories.each do |category| %>
                      <% is_active = current_page?(admin_category_path(category)) %>
                      <%= link_to admin_category_path(category), class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                        <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l5 5a2 2 0 01.586 1.414V19a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"></path>
                        </svg>
                        <span><%= category.name %></span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Classes -->
              <% if current_user.assigned_classes.any? %>
                <div x-data="{ open: false }">
                  <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                    <div class="flex items-center">
                      <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                      </svg>
                      <span>My Classes</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                    <% current_user.assigned_classes.each do |school_class| %>
                      <% is_active = current_page?(admin_school_class_path(school_class)) %>
                      <%= link_to admin_school_class_path(school_class), class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                        <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
                        </svg>
                        <span><%= school_class.name %></span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Subjects -->
              <% if current_user.assigned_subjects.any? %>
                <div x-data="{ open: false }">
                  <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                    <div class="flex items-center">
                      <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                      </svg>
                      <span>My Subjects</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                    <% current_user.assigned_subjects.each do |subject| %>
                      <% is_active = current_page?(admin_subject_path(subject)) %>
                      <%= link_to admin_subject_path(subject), class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                        <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                        <span><%= subject.name %></span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Tasks -->
              <% if current_user.my_tasks.any? %>
                <div x-data="{ open: false }">
                  <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                    <div class="flex items-center">
                      <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                      </svg>
                      <span>My Tasks</span>
                      <% if current_user.pending_tasks.count > 0 %>
                        <span class="ml-2 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5"><%= current_user.pending_tasks.count %></span>
                      <% end %>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                    <% is_active = current_page?(my_tasks_path) %>
                    <%= link_to my_tasks_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                      <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                      </svg>
                      <span>View All Tasks</span>
                      <% if current_user.pending_tasks.count > 0 %>
                        <span class="ml-2 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5"><%= current_user.pending_tasks.count %></span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>

            <!-- ==================== FOR ADMIN USERS ==================== -->
            <% if current_user.admin? %>
              
              <!-- 1. ACADEMICS -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/categories admin/school_classes admin/subjects]) %> }">
                <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                    <span>Academics</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                  <% is_active = current_page?(admin_categories_path) %>
                  <%= link_to admin_categories_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l5 5a2 2 0 01.586 1.414V19a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"></path>
                    </svg>
                    <span>Categories</span>
                  <% end %>
                  <% is_active = current_page?(admin_school_classes_path) %>
                  <%= link_to admin_school_classes_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    <span>Classes</span>
                  <% end %>
                  <% is_active = current_page?(admin_subjects_path) %>
                  <%= link_to admin_subjects_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                    <span>Subjects</span>
                  <% end %>
                </div>
              </div>

              <!-- 2. STUDENT DATA -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/students admin/attendances]) %> }">
                <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                    <span>Student Data</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                  <% is_active = current_page?(admin_students_path) %>
                  <%= link_to admin_students_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                    </svg>
                    <span>Manage Students</span>
                  <% end %>
                  <% is_active = current_page?(admin_attendances_path(class_id: SchoolClass.first&.id)) %>
                  <%= link_to admin_attendances_path(class_id: SchoolClass.first&.id), class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>Class Attendance</span>
                  <% end %>
                </div>
              </div>

              <!-- 3. FEE MANAGEMENT -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/student_fees admin/invoices admin/all_payments]) %> }">
                <button @click="open = !open" class="menu-item w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-xl transition-all duration-200 ease-in-out text-white hover:bg-blue-800">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>Fee Management</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 text-white transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-8 mt-1 space-y-1">
                  <% is_active = current_page?(admin_all_students_fees_path) %>
                  <%= link_to admin_all_students_fees_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                    <span>Student Fees</span>
                  <% end %>
                  <% is_active = current_page?(admin_all_invoices_path) %>
                  <%= link_to admin_all_invoices_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-in-out #{is_active ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                    <svg class="w-4 h-4 mr-3 <%= is_active ? 'text-blue-900' : 'text-white' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <span>All Invoices</span>
