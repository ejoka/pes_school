<body class="bg-gray-50 font-sans antialiased">
  <% if user_signed_in? %>
    <!-- Mobile Sidebar Overlay -->
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeSidebar()"></div>
    
    <div class="flex min-h-screen">
      <!-- ======================================== -->
      <!-- MODERN SIDEBAR -->
      <!-- ======================================== -->
      <aside id="sidebar" class="fixed md:relative z-50 h-full w-72 bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900 shadow-2xl transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out flex flex-col">
        
        <!-- Brand / Logo Section -->
        <div class="relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-yellow-500/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-24 h-24 bg-yellow-500/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
          
          <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
            <div class="flex items-center space-x-3">
              <div class="relative">
                <div class="w-10 h-10 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-xl flex items-center justify-center shadow-lg shadow-yellow-500/20 transform rotate-3">
                  <svg class="w-6 h-6 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                  </svg>
                </div>
                <div class="absolute -bottom-1 -right-1 w-3 h-3 bg-green-400 rounded-full border-2 border-slate-900"></div>
              </div>
              <div>
                <h1 class="text-lg font-bold text-white tracking-tight">
                  School<span class="text-yellow-400">MS</span>
                </h1>
                <p class="text-[10px] text-slate-400 uppercase tracking-wider">Management System</p>
              </div>
            </div>
            
            <button id="closeSidebarBtn" class="md:hidden text-slate-400 hover:text-white p-1 rounded-lg hover:bg-white/5 transition-all duration-200">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- User Profile -->
        <div class="px-4 py-3 mx-3 mt-2 bg-white/5 rounded-xl border border-white/5">
          <div class="flex items-center space-x-3">
            <div class="relative flex-shrink-0">
              <div class="w-10 h-10 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-full flex items-center justify-center shadow-lg">
                <span class="text-slate-900 font-bold text-sm"><%= current_user.first_name[0].upcase %></span>
              </div>
              <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 rounded-full border-2 border-slate-800 pulse-dot"></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-white truncate"><%= current_user.full_name %></p>
              <div class="flex items-center space-x-2">
                <span class="w-1.5 h-1.5 bg-yellow-400 rounded-full"></span>
                <p class="text-xs text-yellow-400 truncate"><%= current_user.role.capitalize %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Search Bar -->
        <div class="px-4 py-3">
          <div class="relative">
            <input type="text" 
                   placeholder="Search menu..." 
                   class="w-full pl-9 pr-3 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-slate-400 focus:outline-none focus:border-yellow-400/50 focus:ring-2 focus:ring-yellow-400/20 transition-all duration-200">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <kbd class="absolute right-3 top-1/2 -translate-y-1/2 px-1.5 py-0.5 bg-white/5 border border-white/10 rounded text-[10px] text-slate-400 font-mono">⌘K</kbd>
          </div>
        </div>

        <!-- Navigation Menu -->
        <nav class="flex-1 overflow-y-auto px-3 py-2 custom-scrollbar" x-data="{ 
          openSections: {} 
        }">
          
          <div class="space-y-1">
            
            <!-- Dashboard -->
            <a href="<%= current_user.admin? ? admin_dashboard_path : dashboard_path %>" 
               class="menu-item flex items-center px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group
                      <%= current_page?(current_user.admin? ? admin_dashboard_path : dashboard_path) ? 'bg-yellow-500 text-slate-900 shadow-lg shadow-yellow-500/20' : 'text-slate-300 hover:text-white hover:bg-white/5' %>">
              <span class="nav-icon-wrapper flex items-center justify-center w-8 h-8 rounded-lg <%= current_page?(current_user.admin? ? admin_dashboard_path : dashboard_path) ? 'bg-slate-900/20' : 'bg-white/5 group-hover:bg-white/10' %> transition-all duration-200 mr-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
              </span>
              <span>Dashboard</span>
              <span class="ml-auto flex items-center space-x-1">
                <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
                <span class="text-[10px] text-slate-400">Live</span>
              </span>
            </a>

            <!-- ==================== NON-ADMIN SECTIONS ==================== -->
            <% if !current_user.admin? %>
              <!-- My Categories -->
              <% if current_user.assigned_categories.any? %>
                <div x-data="{ open: <%= current_page?(admin_category_path(current_user.assigned_categories.first)) %> }" class="menu-item">
                  <button @click="open = !open" 
                          class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                    <div class="flex items-center">
                      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                      </span>
                      <span>My Categories</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                    <% current_user.assigned_categories.each do |category| %>
                      <% is_active = current_page?(admin_category_path(category)) %>
                      <a href="<%= admin_category_path(category) %>" 
                         class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= is_active ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                        <span class="w-2 h-2 rounded-full <%= is_active ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                        <span><%= category.name %></span>
                        <span class="ml-auto text-xs text-slate-500"><%= category.items.count %></span>
                      </a>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Classes -->
              <% if current_user.assigned_classes.any? %>
                <div x-data="{ open: false }" class="menu-item">
                  <button @click="open = !open" 
                          class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                    <div class="flex items-center">
                      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                        </svg>
                      </span>
                      <span>My Classes</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                    <% current_user.assigned_classes.each do |school_class| %>
                      <% is_active = current_page?(admin_school_class_path(school_class)) %>
                      <a href="<%= admin_school_class_path(school_class) %>" 
                         class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= is_active ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                        <span class="w-2 h-2 rounded-full <%= is_active ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                        <span><%= school_class.name %></span>
                        <span class="ml-auto text-xs text-slate-500"><%= school_class.students.count %></span>
                      </a>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Subjects -->
              <% if current_user.assigned_subjects.any? %>
                <div x-data="{ open: false }" class="menu-item">
                  <button @click="open = !open" 
                          class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                    <div class="flex items-center">
                      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                      </span>
                      <span>My Subjects</span>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                    <% current_user.assigned_subjects.each do |subject| %>
                      <% is_active = current_page?(admin_subject_path(subject)) %>
                      <a href="<%= admin_subject_path(subject) %>" 
                         class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= is_active ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                        <span class="w-2 h-2 rounded-full <%= is_active ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                        <span><%= subject.name %></span>
                        <span class="ml-auto text-xs text-slate-500"><%= subject.code %></span>
                      </a>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- My Tasks -->
              <% if current_user.my_tasks.any? %>
                <div x-data="{ open: false }" class="menu-item">
                  <button @click="open = !open" 
                          class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                    <div class="flex items-center">
                      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                      </span>
                      <span>My Tasks</span>
                      <% if current_user.pending_tasks.count > 0 %>
                        <span class="ml-2 px-2 py-0.5 bg-red-500/20 text-red-400 text-xs font-medium rounded-full"><%= current_user.pending_tasks.count %></span>
                      <% end %>
                    </div>
                    <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                    <a href="<%= my_tasks_path %>" 
                       class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(my_tasks_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                      <span class="w-2 h-2 rounded-full <%= current_page?(my_tasks_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                      <span>View All Tasks</span>
                      <% if current_user.pending_tasks.count > 0 %>
                        <span class="ml-auto px-2 py-0.5 bg-red-500/20 text-red-400 text-xs font-medium rounded-full"><%= current_user.pending_tasks.count %></span>
                      <% end %>
                    </a>
                  </div>
                </div>
              <% end %>
            <% end %>

            <!-- ==================== ADMIN SECTIONS ==================== -->
            <% if current_user.admin? %>
              
              <!-- 1. ACADEMICS -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/categories admin/school_classes admin/subjects]) %> }" class="menu-item">
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                  <div class="flex items-center">
                    <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                      </svg>
                    </span>
                    <span>Academics</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                  <!-- Categories -->
                  <a href="<%= admin_categories_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_categories_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_categories_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Categories</span>
                    <span class="ml-auto text-xs text-slate-500"><%= Category.count %></span>
                  </a>
                  <!-- Classes -->
                  <a href="<%= admin_school_classes_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_school_classes_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_school_classes_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Classes</span>
                    <span class="ml-auto text-xs text-slate-500"><%= SchoolClass.count %></span>
                  </a>
                  <!-- Subjects -->
                  <a href="<%= admin_subjects_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_subjects_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_subjects_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Subjects</span>
                    <span class="ml-auto text-xs text-slate-500"><%= Subject.count %></span>
                  </a>
                </div>
              </div>

              <!-- 2. STUDENT DATA -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/students admin/attendances]) %> }" class="menu-item">
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                  <div class="flex items-center">
                    <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                      </svg>
                    </span>
                    <span>Student Data</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                  <a href="<%= admin_students_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_students_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_students_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Manage Students</span>
                    <span class="ml-auto text-xs text-slate-500"><%= Student.count %></span>
                  </a>
                  <a href="<%= admin_attendances_path(class_id: SchoolClass.first&.id) %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_attendances_path(class_id: SchoolClass.first&.id)) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_attendances_path(class_id: SchoolClass.first&.id)) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Attendance</span>
                    <span class="ml-auto text-xs text-green-400">Today</span>
                  </a>
                </div>
              </div>

              <!-- 3. FEE MANAGEMENT -->
              <div x-data="{ open: <%= params[:controller].in?(%w[admin/student_fees admin/invoices admin/all_payments]) %> }" class="menu-item">
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 group text-slate-300 hover:text-white hover:bg-white/5">
                  <div class="flex items-center">
                    <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 transition-all duration-200 mr-3">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </span>
                    <span>Fee Management</span>
                    <span class="ml-auto px-2 py-0.5 bg-yellow-500/20 text-yellow-400 text-xs font-medium rounded-full">New</span>
                  </div>
                  <svg :class="{'rotate-180': open}" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open" x-collapse class="ml-11 mt-1 space-y-1">
                  <a href="<%= admin_all_students_fees_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_all_students_fees_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
                    <span class="w-2 h-2 rounded-full <%= current_page?(admin_all_students_fees_path) ? 'bg-yellow-400' : 'bg-slate-600' %> mr-3"></span>
                    <span>Student Fees</span>
                  </a>
                  <a href="<%= admin_all_invoices_path %>" 
                     class="flex items-center px-3 py-2 rounded-lg text-sm transition-all duration-200 <%= current_page?(admin_all_invoices_path) ? 'bg-yellow-500/10 text-yellow-400' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
