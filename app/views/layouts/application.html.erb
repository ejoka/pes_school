<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pes School" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

    <body class="bg-gray-100">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden">
        <!-- Vertical Sidebar Menu -->
        <div class="w-64 bg-blue-900 shadow-xl flex flex-col">
          <!-- Logo Area -->
          <div class="flex items-center justify-center h-20 bg-blue-900 border-b border-blue-800">
            <div class="flex items-center space-x-2">
              <div class="bg-yellow-500 text-blue-900 font-bold text-2xl px-3 py-1 rounded">
                SMS
              </div>
              <span class="text-yellow-500 font-bold hidden lg:inline">School Mgmt</span>
            </div>
          </div>

          <!-- User Info -->
          <div class="px-4 py-4 bg-blue-800 bg-opacity-30 border-b border-blue-800">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-yellow-500 rounded-full flex items-center justify-center">
                <span class="text-blue-900 font-bold text-lg"><%= current_user.first_name[0].upcase %></span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate"><%= current_user.full_name %></p>
                <p class="text-xs text-yellow-500 truncate"><%= current_user.role.capitalize %></p>
              </div>
            </div>
          </div>

          <!-- Navigation Menu -->
          <nav class="flex-1 overflow-y-auto py-4">
            <div class="px-3 space-y-1">
              <!-- Dashboard Link -->
              <% if current_user.admin? %>
                <%= link_to admin_dashboard_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(admin_dashboard_path) ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                  <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                  </svg>
                  Dashboard
                <% end %>
              <% else %>
                <%= link_to dashboard_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(dashboard_path) ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                  <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                  </svg>
                  Dashboard
                <% end %>
              <% end %>

              <!-- Academics Dropdown Group (for admin only) -->
              <% if current_user.admin? %>
                <div x-data="{ open: <%= params[:controller].in?(%w[admin/categories admin/school_classes admin/subjects]) %> }">
                  <button @click="open = !open" class="w-full flex items-center justify-between px-3 py-2 text-sm font-medium text-white rounded-md hover:bg-blue-800 transition duration-150 ease-in-out">
                    <div class="flex items-center">
                      <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                      </svg>
                      Academics Info
                    </div>
                    <svg :class="{'rotate-180': open}" class="h-4 w-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div x-show="open" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 transform -translate-y-2" x-transition:enter-end="opacity-100 transform translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 transform translate-y-0" x-transition:leave-end="opacity-0 transform -translate-y-2" class="ml-8 mt-1 space-y-1">
                    <%= link_to admin_categories_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(admin_categories_path) ? 'bg-yellow-500 text-blue-900' : 'text-blue-200 hover:text-white hover:bg-blue-800'}" do %>
                      <svg class="mr-3 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l5 5a2 2 0 01.586 1.414V19a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"></path>
                      </svg>
                      Categories
                    <% end %>
                    <%= link_to admin_school_classes_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(admin_school_classes_path) ? 'bg-yellow-500 text-blue-900' : 'text-blue-200 hover:text-white hover:bg-blue-800'}" do %>
                      <svg class="mr-3 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                      </svg>
                      Classes
                    <% end %>
                    <%= link_to admin_subjects_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(admin_subjects_path) ? 'bg-yellow-500 text-blue-900' : 'text-blue-200 hover:text-white hover:bg-blue-800'}" do %>
                      <svg class="mr-3 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                      </svg>
                      Subjects
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- Users Link (for admin only) -->
              <% if current_user.admin? %>
                <%= link_to admin_users_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(admin_users_path) ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                  <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                  </svg>
                  Users
                <% end %>
              <% end %>

              <!-- Profile Link -->
              <%= link_to profile_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-md transition duration-150 ease-in-out #{current_page?(profile_path) ? 'bg-yellow-500 text-blue-900' : 'text-white hover:bg-blue-800'}" do %>
                <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Profile
              <% end %>
            </div>
          </nav>

          <!-- Sign Out Button -->
          <div class="p-4 border-t border-blue-800">
            <%= button_to destroy_user_session_path, method: :delete, 
                class: "w-full flex items-center justify-center px-4 py-2 text-sm font-medium text-blue-900 bg-yellow-500 rounded-md hover:bg-yellow-600 transition duration-150 ease-in-out",
                form: { data: { turbo: false } } do %>
              <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
              </svg>
              Sign Out
            <% end %>
          </div>
        </div>

        <!-- Main Content Area -->
        <div class="flex-1 overflow-y-auto bg-gray-100">
          <!-- Top Bar -->
          <div class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
            <div class="px-6 py-3">
              <div class="flex justify-between items-center">
                <h1 class="text-xl font-semibold text-gray-800">
                  <%= yield :page_title %>
                </h1>
                <div class="flex items-center space-x-4">
                  <span class="text-sm text-gray-600 hidden md:inline">
                    <%= Time.current.strftime("%A, %B %d, %Y") %>
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Flash Messages -->
          <div class="px-6 py-4">
            <% if notice %>
              <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded mb-4" role="alert">
                <p><%= notice %></p>
              </div>
            <% end %>

            <% if alert %>
              <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded mb-4" role="alert">
                <p><%= alert %></p>
              </div>
            <% end %>
          </div>

          <!-- Page Content -->
          <div class="px-6 pb-6">
            <%= yield %>
          </div>
        </div>
      </div>
    <% else %>
      <!-- Non-logged in layout -->
      <div class="min-h-screen bg-blue-900">
        <main class="container mx-auto px-4 py-8">
          <% if notice %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
              <span class="block sm:inline"><%= notice %></span>
            </div>
          <% end %>

          <% if alert %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
              <span class="block sm:inline"><%= alert %></span>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/alpinejs@2.8.2/dist/alpine.min.js" defer></script>
  </body>
</html>
