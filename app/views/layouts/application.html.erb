<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pes School" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-blue-900">
    <main class="container mx-auto px-4">
      <% if user_signed_in? %>
        <nav class="bg-yellow-500 shadow-lg mb-8 rounded-b-lg">
          <div class="max-w-7xl mx-auto px-4">
            <div class="flex justify-between h-16">
              <div class="flex items-center">
                <div class="flex-shrink-0 flex items-center">
                  <div class="bg-blue-900 text-yellow-500 font-bold text-xl px-3 py-1 rounded">
                    SMS
                  </div>
                  <span class="ml-2 text-blue-900 font-bold">School Management</span>
                </div>
                <div class="hidden md:ml-6 md:flex md:space-x-8">
                  <% if current_user.admin? %>
                    <%= link_to "Dashboard", admin_dashboard_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                    <%= link_to "Users", admin_users_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                    <%= link_to "Categories", categories_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                    <%= link_to "Classes", school_classes_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                    <%= link_to "Subjects", subjects_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                  <% else %>
                    <%= link_to "Dashboard", dashboard_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                  <% end %>
                  <%= link_to "Profile", profile_path, class: "text-blue-900 hover:bg-blue-900 hover:text-yellow-500 px-3 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
                </div>
              </div>
              <div class="flex items-center">
                <span class="text-blue-900 mr-4"><%= current_user.full_name %></span>
                <%= link_to "Logout", destroy_user_session_path, method: :delete, class: "bg-blue-900 text-yellow-500 hover:bg-blue-800 px-4 py-2 rounded-md text-sm font-medium transition duration-150 ease-in-out" %>
              </div>
            </div>
          </div>
        </nav>
      <% end %>

      <% if notice %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
          <span class="block sm:inline"><%= notice %></span>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
          <span class="block sm:inline"><%= alert %></span>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
