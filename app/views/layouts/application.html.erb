<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pes School" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Favicon -->
    <% favicon_setting = Setting.find_by(key: 'favicon') %>
    <% if favicon_setting&.favicon&.attached? %>
      <%= favicon_link_tag url_for(favicon_setting.favicon), type: 'image/png' %>
      <%= favicon_link_tag url_for(favicon_setting.favicon), rel: 'icon', type: 'image/x-icon' %>
    <% else %>
      <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%231e3a8a'/%3E%3Ctext x='50' y='67' font-size='50' text-anchor='middle' fill='%23eab308' font-family='Arial, sans-serif' font-weight='bold'%3ESMS%3C/text%3E%3C/svg%3E">
    <% end %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.5/dist/cdn.min.js"></script>
    
    <style>
      :root {
        --primary-color: <%= Setting.get('primary_color', '#1e3a8a') %>;
        --secondary-color: <%= Setting.get('secondary_color', '#eab308') %>;
        --accent-color: <%= Setting.get('accent_color', '#ffffff') %>;
        --sidebar-bg: <%= Setting.get('sidebar_bg', '#1e3a8a') %>;
        --header-bg: <%= Setting.get('header_bg', '#ffffff') %>;
        --button-bg: <%= Setting.get('button_bg', '#eab308') %>;
        --button-text: <%= Setting.get('button_text', '#1e3a8a') %>;
      }
      
      /* Base sidebar styles */
      .sidebar {
        background-color: #1e3a8a;
        transition: transform 0.3s ease-in-out;
      }
      
      .menu-item {
        transition: all 0.2s ease;
      }
      
      .menu-item:hover {
        background-color: rgba(255, 255, 255, 0.1);
      }
      
      /* Desktop styles */
      @media (min-width: 769px) {
        .sidebar {
          position: relative !important;
          width: 260px !important;
          transform: translateX(0) !important;
        }
        .mobile-menu-btn {
          display: none !important;
        }
        .sidebar-overlay {
          display: none !important;
        }
      }
      
      /* Mobile styles */
      @media (max-width: 768px) {
        .sidebar {
          position: fixed !important;
          top: 0 !important;
          left: 0 !important;
          bottom: 0 !important;
          width: 280px !important;
          z-index: 1000 !important;
          transform: translateX(-100%);
        }
        .sidebar.mobile-open {
          transform: translateX(0) !important;
        }
        .sidebar-overlay {
          position: fixed !important;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          background: rgba(0, 0, 0, 0.5);
          z-index: 999;
          display: none;
        }
        .sidebar-overlay.active {
          display: block !important;
        }
        .mobile-menu-btn {
          display: flex !important;
        }
      }
    </style>
    
    <%= javascript_importmap_tags %>
  </head>

  <%= render 'layouts/navigation' %>
</html>
