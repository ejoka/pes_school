<% content_for :page_title, "Weekly Attendance Report" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Weekly Attendance Report</h1>
    <div class="flex space-x-3">
      <%= link_to "Previous Week", admin_attendance_weekly_report_path(class_id: @school_class&.id, date: @week_start - 7.days), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
      <%= link_to "This Week", admin_attendance_weekly_report_path(class_id: @school_class&.id, date: Date.today), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      <%= link_to "Next Week", admin_attendance_weekly_report_path(class_id: @school_class&.id, date: @week_start + 7.days), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
      <%= link_to "Back to Marking", admin_attendances_path(class_id: @school_class&.id), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" %>
    </div>
  </div>

  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <p class="text-center font-semibold">Week of <%= @week_start.strftime("%B %d, %Y") %> - <%= @week_end.strftime("%B %d, %Y") %></p>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Student Name</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Mon</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Tue</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Wed</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Thu</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Fri</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Present</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Absent</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">%</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @students.each do |student| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= student.full_name %></td>
            <% (@week_start..@week_end).each do |day| %>
              <% attendance = @attendance_records.find { |a| a.student_id == student.id && a.date == day } %>
              <td class="px-4 py-2 text-center">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= attendance&.status_color || 'bg-gray-100' %> text-sm font-semibold">
                  <%= attendance&.status_code || '—' %>
                </span>
              </td>
            <% end %>
            <% 
              student_attendances = @attendance_records.select { |a| a.student_id == student.id }
              present_count = student_attendances.select { |a| a.attendance_status&.code == 'P' }.count
              absent_count = student_attendances.select { |a| a.attendance_status&.code == 'A' }.count
              total = student_attendances.count
              percentage = total > 0 ? (present_count.to_f / total * 100).round(1) : 0
            %>
            <td class="px-4 py-2 text-center font-semibold text-green-600"><%= present_count %></td>
            <td class="px-4 py-2 text-center font-semibold text-red-600"><%= absent_count %></td>
            <td class="px-4 py-2 text-center font-semibold text-blue-600"><%= percentage %>%</td>
          <tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>