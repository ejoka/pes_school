<% content_for :page_title, "Select Class for Attendance" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">Select Class</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @school_classes.each do |school_class| %>
      <%= link_to admin_attendances_path(class_id: school_class.id), 
          class: "bg-gray-50 hover:bg-blue-50 border border-gray-200 rounded-lg p-4 transition" do %>
        <div class="font-semibold text-gray-900"><%= school_class.name %></div>
        <div class="text-sm text-gray-500"><%= school_class.students.count %> students</div>
      <% end %>
    <% end %>
  </div>
</div>