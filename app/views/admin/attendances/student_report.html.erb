<% content_for :page_title, "Attendance Report - #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Attendance Report</h1>
      <p class="text-gray-600 mt-1">Student: <%= @student.full_name %> | Class: <%= @student.school_class&.name %></p>
    </div>
    <div class="flex space-x-3">
      <%= link_to "Previous Month", admin_attendance_student_report_path(student_id: @student.id, month: @month - 1.month), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
      <%= link_to "This Month", admin_attendance_student_report_path(student_id: @student.id), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
      <%= link_to "Next Month", admin_attendance_student_report_path(student_id: @student.id, month: @month + 1.month), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
      <%= link_to "Back to Class", admin_attendances_path(class_id: @student.school_class_id), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Days</h3>
      <p class="text-2xl font-bold"><%= @summary[:total_days] %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Present</h3>
      <p class="text-2xl font-bold"><%= @summary[:present] %></p>
    </div>
    <div class="bg-red-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Absent</h3>
      <p class="text-2xl font-bold"><%= @summary[:absent] %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Attendance Rate</h3>
      <p class="text-2xl font-bold"><%= @summary[:percentage] %>%</p>
    </div>
  </div>

  <!-- Attendance Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Day</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Remarks</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recorded By</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @attendances.each do |attendance| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= attendance.date.strftime("%B %d, %Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= attendance.date.strftime("%A") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= attendance.status_color %>">
                <%= attendance.status_name %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= attendance.remarks.presence || '—' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= attendance.recorded_by_name %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-6 flex justify-end">
    <%= link_to "Back to Class", admin_attendances_path(class_id: @student.school_class_id), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
  </div>
</div>