<% content_for :page_title, "Manage Students" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Manage Students</h1>
    <%= link_to "Add New Student", new_admin_student_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Class</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Admission Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Age</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gender</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @students.each do |student| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= student.full_name %></div>
              <div class="text-xs text-gray-500">ID: <%= student.id %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= student.school_class&.name || 'Not assigned' %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= student.admission_date.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= student.age %> years</td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= student.gender == 'Male' ? 'bg-blue-100 text-blue-800' : student.gender == 'Female' ? 'bg-pink-100 text-pink-800' : 'bg-gray-100 text-gray-800' %>">
                <%= student.gender %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm font-medium space-x-3">
              <%= link_to "View", admin_student_path(student), class: "text-green-600 hover:text-green-900" %>
              <%= link_to "Edit", edit_admin_student_path(student), class: "text-blue-600 hover:text-blue-900" %>
              <%= link_to "Delete", admin_student_path(student), method: :delete, data: { confirm: "Are you sure you want to delete #{student.full_name}?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @students.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No students found. Click "Add New Student" to get started.</p>
    </div>
  <% end %>
</div>