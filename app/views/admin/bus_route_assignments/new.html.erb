<% content_for :page_title, "Assign Bus to Route" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Assign Bus to Route</h1>
    <%= link_to admin_bus_route_assignments_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Assignments
    <% end %>
  </div>

  <%= form_with(model: [:admin, @bus_route_assignment], local: true, class: "space-y-6") do |f| %>
    <% if @bus_route_assignment.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@bus_route_assignment.errors.count, "error") %> prohibited this assignment from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @bus_route_assignment.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :school_bus_id, "School Bus", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :school_bus_id, @school_buses, :id, :bus_number, { include_blank: 'Select Bus' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <p class="mt-1 text-xs text-gray-500">Only active buses are shown</p>
      </div>

      <div>
        <%= f.label :route_id, "Transport Route", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :route_id, @routes, :id, :name, { include_blank: 'Select Route' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :assigned_date, "Assignment Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :assigned_date, required: true, value: Date.today, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :status, options_for_select(BusRouteAssignment::STATUSES.map { |k, v| [v, k] }, 'active'), {}, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :description, "Description / Notes (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Additional notes about this bus route assignment..." %>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="text-sm text-blue-800">
          <p class="font-semibold mb-1">Note:</p>
          <p>A bus can only be assigned to one route at a time. Active assignments are used for daily transport operations.</p>
        </div>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_bus_route_assignments_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Assign Bus", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>