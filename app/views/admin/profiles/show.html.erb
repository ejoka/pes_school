<% content_for :page_title, "Admin Profile" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Admin Profile</h1>
    <%= link_to "Edit Profile", edit_admin_admin_profile_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold" %>
  </div>

  <!-- Profile Information -->
  <div class="border border-gray-200 rounded-lg p-6 mb-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Personal Information</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <p class="text-sm text-gray-600 mb-1">Title</p>
        <p class="font-medium text-gray-900"><%= @user.title || 'Not specified' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Full Name</p>
        <p class="font-medium text-gray-900"><%= @user.full_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">First Name</p>
        <p class="font-medium text-gray-900"><%= @user.first_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Middle Name</p>
        <p class="font-medium text-gray-900"><%= @user.middle_name || '—' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Last Name</p>
        <p class="font-medium text-gray-900"><%= @user.last_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Phone Number</p>
        <p class="font-medium text-gray-900"><%= @user.phone_number || '—' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Email Address</p>
        <p class="font-medium text-gray-900"><%= @user.email %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Role</p>
        <p class="font-medium text-blue-900 bg-blue-100 inline-block px-2 py-1 rounded"><%= @user.role.capitalize %></p>
      </div>
    </div>
  </div>

  <!-- Account Information -->
  <div class="border border-gray-200 rounded-lg p-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Account Information</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Member Since</p>
        <p class="font-semibold text-blue-900"><%= @user.created_at.strftime("%B %d, %Y") %></p>
      </div>
      
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Last Sign In</p>
        <p class="font-semibold text-blue-900">
          <% if @user.last_sign_in_at %>
            <%= @user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") %>
          <% else %>
            <span class="text-gray-500">First sign in</span>
          <% end %>
        </p>
      </div>
      
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Sign In Count</p>
        <p class="font-semibold text-blue-900"><%= @user.sign_in_count || 0 %></p>
      </div>
      
      <% if @user.last_sign_in_ip %>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-600">Last IP Address</p>
          <p class="font-semibold text-blue-900 font-mono"><%= @user.last_sign_in_ip %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Admin Stats -->
  <div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
    <h3 class="font-semibold text-yellow-800 mb-2">Admin Statistics</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <p class="text-sm text-yellow-700">Total Users Managed</p>
        <p class="text-2xl font-bold text-yellow-900"><%= User.count %></p>
      </div>
      <div>
        <p class="text-sm text-yellow-700">Categories Managed</p>
        <p class="text-2xl font-bold text-yellow-900"><%= Category.count %></p>
      </div>
      <div>
        <p class="text-sm text-yellow-700">Classes Managed</p>
        <p class="text-2xl font-bold text-yellow-900"><%= SchoolClass.count %></p>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-end">
    <%= link_to "Change Password", edit_user_registration_path, class: "text-yellow-600 hover:text-yellow-700 font-semibold" %>
  </div>
</div>