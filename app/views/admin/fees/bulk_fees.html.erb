<% content_for :page_title, "Bulk Create Fees" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Bulk Create Fees</h1>
    <%= link_to "Back to Fees", admin_fees_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_tag bulk_fees_admin_fees_path, method: :post, class: "space-y-6" do %>
    <div class="grid grid-cols-1 gap-6">
      <div>
        <%= label_tag :class_id, "Select Class", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= select_tag :class_id, options_from_collection_for_select(@classes, :id, :name), include_blank: 'Select Class', required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <p class="mt-1 text-xs text-gray-500">All students in this class will receive this fee</p>
      </div>

      <div>
        <%= label_tag :fee_type_id, "Fee Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= select_tag :fee_type_id, options_from_collection_for_select(@fee_types, :id, :name), include_blank: 'Select Fee Type', required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= label_tag :amount, "Amount to Pay ($)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= number_field_tag :amount, nil, required: true, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= label_tag :due_date, "Due Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= date_field_tag :due_date, Date.today + 30.days, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <p class="text-sm text-yellow-800">
        <strong>Note:</strong> This will create fee records for ALL students in the selected class. 
        You can later edit individual fees if needed.
      </p>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_fees_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Create Bulk Fees", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>