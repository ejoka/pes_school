<% content_for :page_title, "Record Payment" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Record Payment</h1>
    <%= link_to "Back to Fee", admin_fee_path(@fee), class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-sm text-gray-600">Student</p>
        <p class="font-semibold"><%= @fee.student.full_name %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Fee Type</p>
        <p class="font-semibold"><%= @fee.fee_type.name %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Total Amount</p>
        <p class="font-semibold">$<%= number_with_delimiter(@fee.amount_to_pay.to_i) %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Remaining Balance</p>
        <p class="font-semibold text-red-600">$<%= number_with_delimiter(@fee.remaining_balance.to_i) %></p>
      </div>
    </div>
  </div>

  <%= form_with(url: save_payment_admin_fees_path, local: true, class: "space-y-6") do |f| %>
    <%= hidden_field_tag :fee_id, @fee.id %>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= label_tag :amount, "Amount Paid ($)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= number_field_tag :amount, nil, required: true, step: 0.01, min: 0.01, max: @fee.remaining_balance, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <p class="mt-1 text-xs text-gray-500">Maximum: $<%= number_with_delimiter(@fee.remaining_balance.to_i) %></p>
      </div>

      <div>
        <%= label_tag :payment_date, "Payment Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= date_field_tag :payment_date, Date.today, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= label_tag :payment_method, "Payment Method", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= select_tag :payment_method, options_for_select(Payment::PAYMENT_METHODS), include_blank: 'Select Payment Method', required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= label_tag :reference_number, "Reference Number (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= text_field_tag :reference_number, nil, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Check #, Transaction ID, etc." %>
      </div>

      <div class="md:col-span-2">
        <%= label_tag :notes, "Notes (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= text_area_tag :notes, nil, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Additional notes about this payment..." %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_fee_path(@fee), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Record Payment", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>