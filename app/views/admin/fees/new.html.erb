<% content_for :page_title, "Add New Fee" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Add New Fee</h1>
    <%= link_to "Back to Fees", admin_fees_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_with(model: [:admin, @fee], local: true, class: "space-y-6") do |f| %>
    <% if @fee.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        <h3 class="font-bold"><%= pluralize(@fee.errors.count, "error") %> prohibited this fee from being saved:</h3>
        <ul class="list-disc list-inside mt-2">
          <% @fee.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :student_id, "Student", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :student_id, Student.all.order(:first_name), :id, :full_name, { include_blank: 'Select Student' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :fee_type_id, "Fee Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="flex space-x-2">
          <div class="flex-1">
            <%= f.collection_select :fee_type_id, @fee_types, :id, :name, { include_blank: 'Select Fee Type' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", id: "fee_type_select" %>
          </div>
          <button type="button" onclick="showNewFeeTypeModal()" class="bg-green-500 text-white px-3 py-2 rounded hover:bg-green-600 transition duration-150">
            + New
          </button>
        </div>
      </div>

      <div>
        <%= f.label :amount_to_pay, "Amount to Pay ($)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :amount_to_pay, required: true, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :amount_paid, "Amount Paid ($)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :amount_paid, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <p class="mt-1 text-xs text-gray-500">Leave 0 if no payment yet</p>
      </div>

      <div>
        <%= f.label :due_date, "Due Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :due_date, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :notes, "Notes (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :notes, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Additional notes about this fee..." %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_fees_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Create Fee", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>

<!-- Modal for adding new fee type -->
<div id="newFeeTypeModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold text-blue-900">Add New Fee Type</h3>
      <button onclick="closeNewFeeTypeModal()" class="text-gray-400 hover:text-gray-600">&times;</button>
    </div>
    <div class="space-y-4">
      <div>
        <label for="new_fee_type_name" class="block text-sm font-medium text-gray-700 mb-2">Fee Type Name</label>
        <input type="text" id="new_fee_type_name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" placeholder="e.g., Sports Fee">
      </div>
      <div>
        <label for="new_fee_type_description" class="block text-sm font-medium text-gray-700 mb-2">Description (Optional)</label>
        <textarea id="new_fee_type_description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" placeholder="Description of this fee type"></textarea>
      </div>
      <div class="flex justify-end space-x-3 pt-4">
        <button onclick="closeNewFeeTypeModal()" class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150">Cancel</button>
        <button onclick="saveNewFeeType()" class="bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150">Save Fee Type</button>
      </div>
    </div>
  </div>
</div>

<script>
  function showNewFeeTypeModal() {
    document.getElementById('newFeeTypeModal').classList.remove('hidden');
  }
  
  function closeNewFeeTypeModal() {
    document.getElementById('newFeeTypeModal').classList.add('hidden');
    document.getElementById('new_fee_type_name').value = '';
    document.getElementById('new_fee_type_description').value = '';
  }
  
  function saveNewFeeType() {
    const name = document.getElementById('new_fee_type_name').value.trim();
    const description = document.getElementById('new_fee_type_description').value.trim();
    
    if (!name) {
      alert('Please enter a fee type name');
      return;
    }
    
    fetch('/admin/fees/create_fee_type', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      },
      body: JSON.stringify({ name: name, description: description })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        const select = document.getElementById('fee_type_select');
        const option = document.createElement('option');
        option.value = data.id;
        option.text = data.name;
        select.add(option);
        select.value = data.id;
        closeNewFeeTypeModal();
      } else {
        alert(data.errors.join(', '));
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error creating fee type');
    });
  }
</script>