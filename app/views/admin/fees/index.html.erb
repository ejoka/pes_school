<% content_for :page_title, "Fee Management" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Fee Management</h1>
    <div class="space-x-3">
      <%= link_to "Add New Fee", new_admin_fee_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold" %>
      <%= link_to "Bulk Create Fees", bulk_fees_admin_fees_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition duration-150" %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Expected</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_expected.to_i) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Collected</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_collected.to_i) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Outstanding Balance</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@outstanding_balance.to_i) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Collection Rate</h3>
      <p class="text-2xl font-bold">
        <%= @total_expected > 0 ? ((@total_collected / @total_expected) * 100).round(1) : 0 %>%
      </p>
    </div>
  </div>

  <!-- Fees Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fee Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @fees.each do |fee| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to admin_student_path(fee.student), class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
                <%= fee.student.full_name %>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= fee.fee_type.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">$<%= number_with_delimiter(fee.amount_to_pay.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">$<%= number_with_delimiter(fee.amount_paid.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold">$<%= number_with_delimiter(fee.remaining_balance.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= fee.status_color %>">
                <%= fee.status.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= fee.due_date.strftime("%b %d, %Y") if fee.due_date %>
              <% if fee.due_date && fee.due_date < Date.today && fee.status != 'fully_paid' %>
                <span class="text-red-600 ml-1">(Overdue)</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-3">
              <%= link_to "View", admin_fee_path(fee), class: "text-green-600 hover:text-green-900" %>
              <%= link_to "Record Payment", record_payment_admin_fee_path(fee), class: "text-blue-600 hover:text-blue-900" %>
              <%= link_to "Edit", edit_admin_fee_path(fee), class: "text-yellow-600 hover:text-yellow-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @fees.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No fee records found. Click "Add New Fee" to get started.</p>
    </div>
  <% end %>
</div>