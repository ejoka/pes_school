<% content_for :page_title, "All Invoices" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">All Invoices</h1>
    <div class="space-x-3">
      <%= link_to "All Payments", admin_all_payments_path, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition duration-150" %>
      <%= link_to "All Students Fees", admin_all_students_fees_path, class: "bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition duration-150" %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Invoices</h3>
      <p class="text-2xl font-bold"><%= @invoices.count %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Invoiced</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_invoiced.to_i) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Collected</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_revenue.to_i) %></p>
    </div>
    <div class="bg-red-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Outstanding</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@outstanding_invoices.to_i) %></p>
    </div>
  </div>

  <!-- Invoices Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Invoice #</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Class</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if @invoices.any? %>
          <% @invoices.each do |invoice| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-mono font-medium text-blue-600">
                <%= link_to invoice.invoice_number, admin_student_invoice_path(invoice.student, invoice) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= link_to invoice.student.full_name, admin_student_path(invoice.student), class: "text-gray-900 hover:text-blue-600" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= invoice.student.school_class&.name || 'N/A' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                $<%= number_with_delimiter(invoice.total_amount.to_i) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 text-right">
                $<%= number_with_delimiter(invoice.paid_amount.to_i) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold text-right">
                $<%= number_with_delimiter(invoice.remaining_balance.to_i) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= invoice.due_date.strftime("%b %d, %Y") %>
                <% if invoice.due_date < Date.today && invoice.status != 'paid' %>
                  <span class="text-red-600 ml-1">(Overdue)</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= invoice.status_color %>">
                  <%= invoice.status.humanize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= invoice.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
                <%= link_to "View", admin_student_invoice_path(invoice.student, invoice), class: "text-blue-600 hover:text-blue-900" %>
                <%= link_to "PDF", download_pdf_admin_student_invoice_path(invoice.student, invoice), class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="10" class="px-6 py-12 text-center text-gray-500">
              <div class="text-6xl mb-4">📄</div>
              <p>No invoices generated yet.</p>
              <p class="text-sm mt-2">Generate invoices from student fee management pages.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>