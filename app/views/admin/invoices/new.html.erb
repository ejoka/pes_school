<% content_for :page_title, "Generate Invoice for #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Generate Invoice</h1>
    <%= link_to "Cancel", admin_student_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
  </div>

  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-sm text-gray-600">Student</p>
        <p class="font-semibold"><%= @student.full_name %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Class</p>
        <p class="font-semibold"><%= @student.school_class&.name || 'Not assigned' %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Total Outstanding</p>
        <p class="font-semibold text-red-600">$<%= number_with_delimiter(@student.current_balance.to_i) %></p>
      </div>
    </div>
  </div>

  <%= form_tag admin_student_invoices_path(@student), method: :post, class: "space-y-6" do %>
    <div class="border border-gray-200 rounded-lg p-4">
      <h2 class="text-lg font-semibold text-blue-900 mb-4">Select Fees to Invoice</h2>
      
      <% if @unpaid_fees.any? %>
        <div class="space-y-3 max-h-96 overflow-y-auto">
          <label class="flex items-center p-2 bg-gray-50 rounded">
            <input type="checkbox" id="select_all" class="form-checkbox h-4 w-4 text-yellow-500 rounded">
            <span class="ml-2 font-semibold">Select All Fees</span>
          </label>
          
          <% @unpaid_fees.each do |fee| %>
            <label class="flex items-center justify-between p-3 hover:bg-gray-50 rounded border">
              <div class="flex items-center">
                <input type="checkbox" name="fee_ids[]" value="<%= fee.id %>" class="fee-checkbox form-checkbox h-4 w-4 text-yellow-500 rounded">
                <div class="ml-3">
                  <p class="font-medium text-gray-900"><%= fee.fee_category.name %></p>
                  <p class="text-xs text-gray-500">Due: <%= fee.due_date.strftime("%b %d, %Y") %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="font-semibold text-gray-900">$<%= number_with_delimiter(fee.remaining_balance.to_i) %></p>
                <p class="text-xs text-gray-500">Paid: $<%= number_with_delimiter(fee.amount_paid.to_i) %></p>
              </div>
            </label>
          <% end %>
        </div>
        
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Due Date</label>
          <input type="date" name="invoice[due_date]" value="<%= Date.today + 30.days %>" required class="w-full md:w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Notes (Optional)</label>
          <textarea name="invoice[notes]" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" placeholder="Additional notes for this invoice..."></textarea>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-gray-500">No unpaid fees available for this student.</p>
          <%= link_to "Add Fees First", new_admin_student_student_fee_path(@student), class: "mt-2 inline-block text-blue-600 hover:text-blue-800" %>
        </div>
      <% end %>
    </div>

    <% if @unpaid_fees.any? %>
      <div class="flex justify-end space-x-3">
        <%= link_to "Cancel", admin_student_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
        <%= submit_tag "Generate Invoice", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
      </div>
    <% end %>
  <% end %>
</div>

<script>
  // Select all functionality
  const selectAllCheckbox = document.getElementById('select_all');
  if (selectAllCheckbox) {
    selectAllCheckbox.addEventListener('change', function() {
      const checkboxes = document.querySelectorAll('.fee-checkbox');
      checkboxes.forEach(checkbox => {
        checkbox.checked = selectAllCheckbox.checked;
      });
    });
  }
</script>