<% content_for :page_title, "Assign Staff" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">Assign Staff to Department</h1>

  <%= form_with(model: [:admin, @assignment], local: true, class: "space-y-4") do |f| %>
    <% if @assignment.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <% @assignment.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :user_id, "Staff Member", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.collection_select :user_id, @users, :id, :full_name, { include_blank: 'Select Staff' }, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div>
      <%= f.label :department_id, "Department", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: 'Select Department' }, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div>
      <%= f.label :position, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :position, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div>
      <%= f.label :joined_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.date_field :joined_date, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :status, options_for_select(StaffAssignment::STATUSES.map { |k,v| [v,k] }, 'active'), {}, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_staff_assignments_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
      <%= f.submit "Assign Staff", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded font-semibold" %>
    </div>
  <% end %>
</div>