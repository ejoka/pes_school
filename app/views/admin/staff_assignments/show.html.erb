<% content_for :page_title, "Staff Assignment Details" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Staff Assignment Details</h1>
    <div class="space-x-2">
      <%= link_to "Edit", edit_admin_staff_assignment_path(@assignment), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded" %>
      <%= link_to "Back", admin_staff_assignments_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Staff Information</h2>
      <p><strong>Name:</strong> <%= @assignment.user.full_name %></p>
      <p><strong>Email:</strong> <%= @assignment.user.email %></p>
      <p><strong>Professional Type:</strong> <%= @assignment.user.professional_type %></p>
      <p><strong>Phone:</strong> <%= @assignment.user.phone_number %></p>
    </div>

    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Assignment Details</h2>
      <p><strong>Department:</strong> <%= @assignment.department.name %></p>
      <p><strong>Position:</strong> <%= @assignment.position %></p>
      <p><strong>Joined Date:</strong> <%= @assignment.joined_date.strftime("%B %d, %Y") %></p>
      <p><strong>Status:</strong> <span class="px-2 py-1 rounded-full text-xs <%= @assignment.status_color %>"><%= @assignment.status.humanize %></span></p>
    </div>
  </div>

  <div class="mt-6 border-t pt-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-blue-900">Payroll History</h2>
      <%= link_to "Add Payroll", new_admin_payroll_path(staff_assignment_id: @assignment.id), class: "bg-green-600 text-white px-3 py-1 rounded text-sm" %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50"><tr><th class="px-4 py-2">Month</th><th class="px-4 py-2">Basic</th><th class="px-4 py-2">Allowances</th><th class="px-4 py-2">Deductions</th><th class="px-4 py-2">Net Pay</th><th class="px-4 py-2">Status</th><th class="px-4 py-2">Actions</th></tr></thead>
        <tbody>
          <% @payrolls.each do |payroll| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2"><%= payroll.month_name %> <%= payroll.year %></td>
              <td class="px-4 py-2"><%= number_to_currency(payroll.basic_salary) %></td>
              <td class="px-4 py-2"><%= number_to_currency(payroll.allowances) %></td>
              <td class="px-4 py-2"><%= number_to_currency(payroll.deductions) %></td>
              <td class="px-4 py-2 font-semibold"><%= number_to_currency(payroll.net_salary) %></td>
              <td class="px-4 py-2"><span class="px-2 py-1 rounded-full text-xs <%= payroll.status_color %>"><%= payroll.status.humanize %></span></td>
              <td class="px-4 py-2"><%= link_to "View", admin_payroll_path(payroll), class: "text-blue-600" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>