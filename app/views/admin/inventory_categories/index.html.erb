<% content_for :page_title, "Inventory Categories" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Inventory Categories</h1>
    <%= link_to "Add New Category", new_admin_inventory_category_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items Count</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @inventory_categories.each do |category| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= category.name %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= category.description %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= category.inventory_items.count %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <%= link_to "Edit", edit_admin_inventory_category_path(category), class: "text-blue-600 hover:text-blue-900" %>
              <%= link_to "Delete", admin_inventory_category_path(category), method: :delete, data: { confirm: "Are you sure you want to delete '#{category.name}'?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
