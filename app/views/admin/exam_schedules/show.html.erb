<% content_for :page_title, "Exam Schedule Details" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Schedule Details</h1>
    <div class="flex space-x-3">
      <%= link_to edit_admin_exam_schedule_path(@exam_schedule), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit Schedule
      <% end %>
      <%= link_to admin_exam_schedules_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Schedules
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Main Information -->
    <div class="bg-gradient-to-r from-blue-50 to-white rounded-lg p-6">
      <div class="space-y-4">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Status</p>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @exam_schedule.status_color %>">
            <%= @exam_schedule.status.upcase %>
          </span>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Subject</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.subject&.name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Type</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.exam_type&.name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Class</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.school_class&.name %></p>
        </div>
      </div>
    </div>

    <!-- Schedule Information -->
    <div class="bg-gradient-to-r from-green-50 to-white rounded-lg p-6">
      <div class="space-y-4">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Date & Time</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.formatted_datetime %></p>
          <p class="text-sm text-gray-500 mt-1">Duration: <%= @exam_schedule.duration_hours %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Venue</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.venue %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Supervising Teacher</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_schedule.teacher_name %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Description -->
  <% if @exam_schedule.description.present? %>
    <div class="mt-6 bg-gray-50 rounded-lg p-6">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Description</p>
      <p class="text-gray-700"><%= @exam_schedule.description %></p>
    </div>
  <% end %>

  <!-- Additional Info -->
  <div class="mt-6 bg-blue-50 rounded-lg p-6">
    <h3 class="text-sm font-semibold text-blue-900 mb-3">Schedule Information</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-gray-500">Created At</p>
        <p class="text-sm text-gray-700"><%= @exam_schedule.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500">Last Updated</p>
        <p class="text-sm text-gray-700"><%= @exam_schedule.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
    </div>
  </div>
</div>