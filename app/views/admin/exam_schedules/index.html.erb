<% content_for :page_title, "Exam Schedules" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Schedules</h1>
      <p class="text-sm text-gray-500 mt-1">Manage examination timetables and schedules</p>
    </div>
    <%= link_to new_admin_exam_schedule_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add New Schedule
    <% end %>
  </div>

  <!-- Tabs for different schedule categories -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex space-x-8" aria-label="Tabs">
      <button onclick="showScheduleTab('ongoing')" id="tab-ongoing" class="tab-button py-2 px-1 border-b-2 font-medium text-sm border-yellow-500 text-yellow-600">
        Ongoing (<%= @ongoing_schedules.count %>)
      </button>
      <button onclick="showScheduleTab('upcoming')" id="tab-upcoming" class="tab-button py-2 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        Upcoming (<%= @upcoming_schedules.count %>)
      </button>
      <button onclick="showScheduleTab('past')" id="tab-past" class="tab-button py-2 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        Past (<%= @past_schedules.count %>)
      </button>
    </nav>
  </div>

  <!-- Ongoing Schedules -->
  <div id="ongoing-schedules" class="schedule-tab">
    <% if @ongoing_schedules.any? %>
      <div class="grid grid-cols-1 gap-4">
        <% @ongoing_schedules.each do |schedule| %>
          <%= render 'schedule_card', schedule: schedule %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <p class="text-gray-500">No ongoing exams at the moment.</p>
      </div>
    <% end %>
  </div>

  <!-- Upcoming Schedules -->
  <div id="upcoming-schedules" class="schedule-tab" style="display: none;">
    <% if @upcoming_schedules.any? %>
      <div class="grid grid-cols-1 gap-4">
        <% @upcoming_schedules.each do |schedule| %>
          <%= render 'schedule_card', schedule: schedule %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <p class="text-gray-500">No upcoming exams scheduled.</p>
      </div>
    <% end %>
  </div>

  <!-- Past Schedules -->
  <div id="past-schedules" class="schedule-tab" style="display: none;">
    <% if @past_schedules.any? %>
      <div class="grid grid-cols-1 gap-4">
        <% @past_schedules.each do |schedule| %>
          <%= render 'schedule_card', schedule: schedule %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <p class="text-gray-500">No past exams found.</p>
      </div>
    <% end %>
  </div>
</div>

<script>
  function showScheduleTab(tabName) {
    // Hide all tabs
    document.querySelectorAll('.schedule-tab').forEach(tab => {
      tab.style.display = 'none';
    });
    
    // Show selected tab
    document.getElementById(`${tabName}-schedules`).style.display = 'block';
    
    // Update tab styles
    document.querySelectorAll('.tab-button').forEach(button => {
      button.classList.remove('border-yellow-500', 'text-yellow-600');
      button.classList.add('border-transparent', 'text-gray-500');
    });
    
    const activeButton = document.getElementById(`tab-${tabName}`);
    activeButton.classList.remove('border-transparent', 'text-gray-500');
    activeButton.classList.add('border-yellow-500', 'text-yellow-600');
  }
</script>