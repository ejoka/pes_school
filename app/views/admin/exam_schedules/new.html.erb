<% content_for :page_title, @exam_schedule.new_record? ? "Add New Exam Schedule" : "Edit Exam Schedule" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-3xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900"><%= @exam_schedule.new_record? ? "Add New Exam Schedule" : "Edit Exam Schedule" %></h1>
    <%= link_to admin_exam_schedules_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Schedules
    <% end %>
  </div>

  <%= form_with(model: [:admin, @exam_schedule], local: true, class: "space-y-6") do |f| %>
    <% if @exam_schedule.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@exam_schedule.errors.count, "error") %> prohibited this schedule from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @exam_schedule.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :subject_id, "Subject", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :subject_id, @subjects, :id, :name, { include_blank: 'Select Subject' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :school_class_id, "Class", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :school_class_id, @school_classes, :id, :name, { include_blank: 'Select Class' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :exam_type_id, "Exam Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :exam_type_id, @exam_types, :id, :name, { include_blank: 'Select Exam Type' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :user_id, "Supervising Teacher", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :user_id, @teachers, :id, :full_name, { include_blank: 'Select Teacher' }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <p class="mt-1 text-xs text-gray-500">Only users with Teacher professional type are shown</p>
      </div>

      <div>
        <%= f.label :start_time, "Start Time", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.datetime_local_field :start_time, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :end_time, "End Time", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.datetime_local_field :end_time, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :venue, "Venue", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :venue, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "e.g., Hall A, Room 101, Online" %>
      </div>
    </div>

    <div>
      <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Additional notes or instructions..." %>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="text-sm text-blue-800">
          <p class="font-semibold mb-1">Note:</p>
          <p>Ensure the end time is after the start time. Teachers must have the "Teacher" professional type to be assignable.</p>
        </div>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_exam_schedules_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit @exam_schedule.new_record? ? "Create Schedule" : "Update Schedule", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>