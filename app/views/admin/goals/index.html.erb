<% content_for :page_title, "Goals & Tasks" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Goals & Objectives</h1>
    <%= link_to "Create New Goal", new_admin_goal_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600" %>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Goals</h3>
      <p class="text-2xl font-bold"><%= @total_goals %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Completed</h3>
      <p class="text-2xl font-bold"><%= @completed_goals %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">In Progress</h3>
      <p class="text-2xl font-bold"><%= @in_progress_goals %></p>
    </div>
    <div class="bg-red-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Overdue</h3>
      <p class="text-2xl font-bold"><%= @overdue_goals %></p>
    </div>
  </div>

  <!-- Goals List -->
  <div class="space-y-4">
    <% @goals.each do |goal| %>
      <div class="border rounded-lg p-4 hover:shadow-lg transition">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <div class="flex items-center space-x-3 mb-2">
              <h2 class="text-xl font-semibold text-gray-900"><%= link_to goal.title, admin_goal_path(goal), class: "hover:text-blue-600" %></h2>
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= goal.priority_color %>">
                <%= goal.priority.humanize %>
              </span>
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= goal.status_color %>">
                <%= goal.status.humanize %>
              </span>
              <% if goal.is_overdue? %>
                <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                  Overdue
                </span>
              <% end %>
            </div>
            <p class="text-gray-600 text-sm mb-2"><%= goal.description %></p>
            <div class="flex flex-wrap gap-4 text-sm text-gray-500">
              <span>👥 For: <%= goal.professional_type.humanize %></span>
              <span>📅 <%= goal.start_date.strftime("%b %d") %> - <%= goal.end_date.strftime("%b %d, %Y") %></span>
              <span>⏰ <%= goal.days_remaining %> days remaining</span>
              <span>✅ Tasks: <%= goal.tasks.count %></span>
            </div>
          </div>
          <div class="text-right min-w-[150px]">
            <div class="text-sm text-gray-600 mb-1">Progress</div>
            <div class="text-2xl font-bold text-blue-600"><%= goal.progress %>%</div>
            <div class="w-full bg-gray-200 rounded-full h-2 mt-1">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= goal.progress %>%"></div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @goals.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No goals created yet.</p>
      <%= link_to "Create Your First Goal", new_admin_goal_path, class: "mt-2 inline-block text-blue-600" %>
    </div>
  <% end %>
</div>