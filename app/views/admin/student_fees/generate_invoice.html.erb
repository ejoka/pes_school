<% content_for :page_title, "Invoice - #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-8" id="invoice">
  <!-- Invoice Header -->
  <div class="flex justify-between mb-8 pb-8 border-b">
    <div>
      <% if Setting.find_by(key: 'logo')&.logo&.attached? %>
        <%= image_tag Setting.find_by(key: 'logo').logo, class: "h-16 mb-4", alt: "School Logo" %>
      <% else %>
        <div class="bg-primary text-secondary text-3xl font-bold px-4 py-2 rounded inline-block">
          SMS
        </div>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-800 mt-4"><%= school_name %></h1>
      <p class="text-gray-600"><%= school_address %></p>
      <p class="text-gray-600">Tel: <%= school_phone %> | Email: <%= school_email %></p>
    </div>
    <div class="text-right">
      <h2 class="text-3xl font-bold text-primary">INVOICE</h2>
      <p class="text-gray-600 mt-2">Date: <%= Date.today.strftime("%B %d, %Y") %></p>
    </div>
  </div>

  <!-- Student Information -->
  <div class="mb-8 p-4 bg-gray-50 rounded-lg">
    <h3 class="text-lg font-semibold text-primary mb-2">Student Information</h3>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p><strong>Name:</strong> <%= @student.full_name %></p>
        <p><strong>Class:</strong> <%= @student.school_class&.name %></p>
      </div>
      <div>
        <p><strong>Admission No:</strong> <%= @student.id %></p>
        <p><strong>Academic Year:</strong> <%= @student.academic_year %></p>
      </div>
    </div>
  </div>

  <!-- Fee Items -->
  <div class="mb-8">
    <h3 class="text-lg font-semibold text-primary mb-4">Fee Details</h3>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Paid</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Balance</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @invoice_data[:fees].each do |fee| %>
          <tr>
            <td class="px-4 py-2 text-sm text-gray-900"><%= fee.fee_category.name %></td>
            <td class="px-4 py-2 text-sm text-gray-900 text-right"><%= format_currency(fee.amount) %></td>
            <td class="px-4 py-2 text-sm text-green-600 text-right"><%= format_currency(fee.amount_paid) %></td>
            <td class="px-4 py-2 text-sm text-red-600 text-right"><%= format_currency(fee.remaining_balance) %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-50">
        <tr>
          <td class="px-4 py-2 font-bold text-right" colspan="3">Total Due:</td>
          <td class="px-4 py-2 font-bold text-right"><%= format_currency(@invoice_data[:total_due]) %></td>
        </tr>
        <tr class="border-t">
          <td class="px-4 py-2 font-bold text-right" colspan="3">Total Paid:</td>
          <td class="px-4 py-2 font-bold text-green-600 text-right"><%= format_currency(@invoice_data[:total_paid]) %></td>
        </tr>
        <tr class="border-t-2 border-gray-400">
          <td class="px-4 py-2 text-lg font-bold text-right" colspan="3">Balance Due:</td>
          <td class="px-4 py-2 text-lg font-bold text-red-600 text-right"><%= format_currency(@invoice_data[:balance]) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- Payment History -->
  <% if @invoice_data[:payments].any? %>
    <div class="mb-8">
      <h3 class="text-lg font-semibold text-primary mb-4">Payment History</h3>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Method</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Reference</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @invoice_data[:payments].each do |payment| %>
            <tr>
              <td class="px-4 py-2 text-sm text-gray-900"><%= payment.payment_date.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-2 text-sm text-gray-900"><%= payment.payment_method %></td>
              <td class="px-4 py-2 text-sm text-green-600 text-right"><%= format_currency(payment.amount) %></td>
              <td class="px-4 py-2 text-sm text-gray-500"><%= payment.reference || '—' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Invoice Footer -->
  <div class="mt-8 pt-8 border-t text-center">
    <p class="text-sm text-gray-500"><%= invoice_footer_text %></p>
    <p class="text-sm text-gray-500 mt-2">This is a computer-generated invoice and does not require a signature.</p>
  </div>
</div>

<div class="mt-6 flex justify-center space-x-4">
  <button onclick="window.print()" class="bg-primary text-secondary px-6 py-2 rounded hover:opacity-90 transition duration-150">
    Print Invoice
  </button>
  <%= link_to "Back to Student", admin_student_path(@student), class: "bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600 transition duration-150" %>
</div>

<style media="print">
  .bg-white { background: white !important; }
  .no-print, button, .bg-gray-500, .bg-primary { display: none !important; }
  #invoice { margin: 0; padding: 0; }
</style>