<% content_for :page_title, "Edit Fees for #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Edit Fees</h1>
    <div class="space-x-3">
      <%= link_to admin_student_student_fee_path(@student, @student_fee), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Cancel
      <% end %>
    </div>
  </div>

  <p class="text-gray-600 mb-6">Student: <span class="font-semibold"><%= @student.full_name %></span> | Class: <span class="font-semibold"><%= @student.school_class&.name %></span></p>

  <%= form_with(url: admin_student_student_fee_path(@student, @student_fee), method: :patch, local: true, class: "space-y-6") do |f| %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fee Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount ($)</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount Paid ($)</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remaining</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @student_fee_items.each do |fee_item| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= fee_item.fee_type.name %></div>
                <div class="text-xs text-gray-500"><%= fee_item.fee_type.description %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <input type="number" 
                       name="fee_items[<%= fee_item.fee_type.id %>][amount]" 
                       value="<%= fee_item.amount.to_i %>" 
                       step="0.01" 
                       min="0" 
                       class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <input type="number" 
                       name="fee_items[<%= fee_item.fee_type.id %>][paid]" 
                       value="<%= fee_item.paid.to_i %>" 
                       step="0.01" 
                       min="0" 
                       class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
                <p class="text-xs text-gray-500 mt-1">Paid: $<%= fee_item.paid.to_i %></p>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-sm text-red-600 font-semibold">
                  $<%= fee_item.remaining_balance.to_i %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <input type="date" 
                       name="fee_items[<%= fee_item.fee_type.id %>][due_date]" 
                       value="<%= fee_item.due_date %>" 
                       class="w-40 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_student_student_fee_path(@student, @student_fee), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Fees", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>