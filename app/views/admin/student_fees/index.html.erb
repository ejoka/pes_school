<% content_for :page_title, "Fees Management - #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Fees Management</h1>
      <p class="text-gray-600 mt-1">Student: <%= link_to @student.full_name, admin_student_path(@student), class: "text-blue-600 hover:text-blue-800" %></p>
    </div>
    <div class="space-x-3">
      <%= link_to new_admin_student_student_fee_path(@student), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" do %>
        Add Single Fee
      <% end %>
      <%= link_to bulk_add_admin_student_student_fees_path(@student), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition duration-150" do %>
        Bulk Add Fees
      <% end %>
      <%= link_to generate_invoice_admin_student_student_fees_path(@student), class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition duration-150" do %>
        Generate Invoice
      <% end %>
      <%= link_to admin_student_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Student
      <% end %>
    </div>
  </div>

  <!-- Financial Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Fees Due</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_due.to_i) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Paid</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_paid.to_i) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Current Balance</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@balance.to_i) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Payment Progress</h3>
      <p class="text-2xl font-bold"><%= @total_due > 0 ? ((@total_paid / @total_due) * 100).round(1) : 0 %>%</p>
    </div>
  </div>

  <!-- Overall Progress Bar -->
  <div class="mb-8">
    <div class="flex justify-between mb-2">
      <span class="text-sm text-gray-600">Overall Payment Progress</span>
      <span class="text-sm font-semibold text-blue-900"><%= @total_due > 0 ? ((@total_paid / @total_due) * 100).round(1) : 0 %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-4">
      <div class="bg-green-600 h-4 rounded-full transition-all duration-500" style="width: <%= @total_due > 0 ? (@total_paid / @total_due) * 100 : 0 %>%"></div>
    </div>
  </div>

  <!-- Fees Table -->
  <div class="overflow-x-auto mb-8">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Fee Items</h2>
      <% if @student.invoices.any? %>
        <%= link_to "Sync All Invoices", sync_invoices_admin_student_student_fees_path(@student), method: :post, class: "bg-purple-600 text-white px-3 py-1 rounded hover:bg-purple-700 text-sm" %>
      <% end %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fee Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @student_fees.each do |fee| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= fee.fee_category.name %></div>
              <div class="text-xs text-gray-500"><%= fee.fee_category.is_recurring ? 'Recurring' : 'One-time' %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">$<%= number_with_delimiter(fee.amount.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">$<%= number_with_delimiter(fee.amount_paid.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold">$<%= number_with_delimiter(fee.remaining_balance.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= fee.due_date.strftime("%b %d, %Y") %>
              <% if fee.due_date < Date.today && !fee.is_paid %>
                <span class="text-red-600 ml-1">(Overdue)</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex flex-col space-y-2">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= fee.status_color %>">
                  <%= fee.status.humanize %>
                </span>
                <div class="w-32 bg-gray-200 rounded-full h-1.5">
                  <div class="<%= fee.percentage_paid == 100 ? 'bg-green-600' : 'bg-yellow-600' %> h-1.5 rounded-full" style="width: <%= fee.percentage_paid %>%"></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <%= link_to "Edit", edit_admin_student_student_fee_path(@student, fee), class: "text-blue-600 hover:text-blue-900" %>
              <%= link_to "Remove", admin_student_student_fee_path(@student, fee), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Payments Table -->
  <div>
    <h2 class="text-xl font-bold text-blue-900 mb-4">Payment History</h2>
    <%= link_to "Record New Payment", new_admin_student_payment_path(@student), class: "bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 transition duration-150 mb-4 inline-block" %>
    
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Method</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reference</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notes</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @student.payments.order(payment_date: :desc).each do |payment| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= payment.payment_date.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">$<%= number_with_delimiter(payment.amount.to_i) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= payment.payment_method %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= payment.reference || '—' %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= payment.notes || '—' %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= link_to "Delete", admin_student_payment_path(@student, payment), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>