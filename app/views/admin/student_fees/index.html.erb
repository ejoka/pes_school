<% content_for :page_title, "Fees Management - #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Fees Management</h1>
      <p class="text-gray-600 mt-1">Student: <%= link_to @student.full_name, admin_student_path(@student), class: "text-blue-600 hover:text-blue-800" %></p>
    </div>
    <div class="space-x-3">
      <%= link_to new_admin_student_student_fee_path(@student), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" do %>
        Add Single Fee
      <% end %>
      <%= link_to bulk_add_admin_student_student_fees_path(@student), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition duration-150" do %>
        Bulk Add Fees
      <% end %>
      <%= link_to admin_student_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Student
      <% end %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Fees Due</h3>
      <p class="text-2xl font-bold"><%= format_currency(@total_due) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Paid</h3>
      <p class="text-2xl font-bold"><%= format_currency(@total_paid) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Current Balance</h3>
      <p class="text-2xl font-bold"><%= format_currency(@balance) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Payment Progress</h3>
      <p class="text-2xl font-bold"><%= @total_due > 0 ? ((@total_paid / @total_due) * 100).round(1) : 0 %>%</p>
    </div>
  </div>

  <!-- Overall Progress Bar -->
  <div class="mb-8">
    <div class="flex justify-between mb-2">
      <span class="text-sm text-gray-600">Overall Payment Progress</span>
      <span class="text-sm font-semibold text-blue-900"><%= @total_due > 0 ? ((@total_paid / @total_due) * 100).round(1) : 0 %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-4">
      <div class="bg-green-600 h-4 rounded-full transition-all duration-500" style="width: <%= @total_due > 0 ? (@total_paid / @total_due) * 100 : 0 %>%"></div>
    </div>
  </div>

  <!-- Fees Table -->
  <div class="overflow-x-auto">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Fee Items</h2>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fee Category</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @student_fees.each do |student_fee| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= student_fee.fee_category.name %></div>
              <div class="text-xs text-gray-500"><%= student_fee.fee_category.is_recurring ? 'Recurring' : 'One-time' %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
              <%= format_currency(student_fee.amount) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold text-right">
              <%= format_currency(student_fee.amount_paid) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold text-right">
              <%= format_currency(student_fee.remaining_balance) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= student_fee.due_date.strftime("%b %d, %Y") if student_fee.due_date %>
              <% if student_fee.due_date && student_fee.due_date < Date.today && !student_fee.is_paid %>
                <span class="text-red-600 ml-1">(Overdue)</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex flex-col space-y-2">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= student_fee.status_color %>">
                  <%= student_fee.status.humanize %>
                </span>
                <div class="w-32 bg-gray-200 rounded-full h-1.5">
                  <div class="<%= student_fee.percentage_paid == 100 ? 'bg-green-600' : 'bg-yellow-600' %> h-1.5 rounded-full" style="width: <%= student_fee.percentage_paid %>%"></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <% if @can_edit %>
                <%= link_to "Edit", edit_admin_student_student_fee_path(@student, student_fee), class: "text-blue-600 hover:text-blue-900" %>
              <% end %>
              <% if @can_delete %>
                <%= link_to "Delete", admin_student_student_fee_path(@student, student_fee), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
              <% end %>
              <% if student_fee.remaining_balance > 0 && @can_edit %>
                <%= link_to "Record Payment", new_admin_student_payment_path(@student, fee_id: student_fee.id), class: "text-green-600 hover:text-green-900" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-100">
        <tr>
          <td colspan="3" class="px-6 py-4 text-right font-bold">Total Balance:</td>
          <td class="px-6 py-4 text-right font-bold text-red-600"><%= format_currency(@balance) %></td>
          <td colspan="3"></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <% if @student_fees.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No fees recorded for this student.</p>
      <%= link_to "Add First Fee", new_admin_student_student_fee_path(@student), class: "mt-2 inline-block text-blue-600 hover:text-blue-800" %>
    </div>
  <% end %>
</div>