<% content_for :page_title, "Fees for #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Fee Management</h1>
      <p class="text-gray-600 mt-1">Student: <%= link_to @student.full_name, admin_student_path(@student), class: "text-blue-600 hover:text-blue-800" %></p>
    </div>
    <div class="space-x-3">
      <%= link_to edit_admin_student_student_fee_path(@student, @student_fee), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" do %>
        Edit Fees
      <% end %>
      <%= link_to admin_student_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Student
      <% end %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Amount</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_amount.to_i) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Paid</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_paid.to_i) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Remaining Balance</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@balance.to_i) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Payment Progress</h3>
      <p class="text-2xl font-bold"><%= @total_amount > 0 ? ((@total_paid / @total_amount) * 100).round(1) : 0 %>%</p>
    </div>
  </div>

  <!-- Overall Progress Bar -->
  <div class="mb-8">
    <div class="flex justify-between mb-2">
      <span class="text-sm text-gray-600">Overall Payment Progress</span>
      <span class="text-sm font-semibold text-blue-900"><%= @total_amount > 0 ? ((@total_paid / @total_amount) * 100).round(1) : 0 %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-4">
      <div class="bg-green-600 h-4 rounded-full transition-all duration-500" style="width: <%= @total_amount > 0 ? (@total_paid / @total_amount) * 100 : 0 %>%"></div>
    </div>
  </div>

  <!-- Fee Items Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <table>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fee Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @student_fee_items.each do |fee_item| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= fee_item.fee_type.name %></div>
             </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              $<%= number_with_delimiter(fee_item.amount.to_i) %>
             </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">
              $<%= number_with_delimiter(fee_item.paid.to_i) %>
             </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold">
              $<%= number_with_delimiter(fee_item.remaining_balance.to_i) %>
             </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= fee_item.due_date&.strftime("%b %d, %Y") || 'Not set' %>
             </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex flex-col space-y-2">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= fee_item.status_color %>">
                  <%= fee_item.status&.humanize || 'Unpaid' %>
                </span>
                <div class="w-32 bg-gray-200 rounded-full h-1.5">
                  <div class="<%= fee_item.percentage_paid == 100 ? 'bg-green-600' : 'bg-yellow-600' %> h-1.5 rounded-full" style="width: <%= fee_item.percentage_paid %>%"></div>
                </div>
              </div>
             </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <% if fee_item.remaining_balance.to_f > 0 %>
                <button onclick="showPaymentModal(<%= fee_item.id %>, '<%= fee_item.fee_type.name %>', <%= fee_item.remaining_balance.to_i %>)" class="text-blue-600 hover:text-blue-900">
                  Record Payment
                </button>
              <% else %>
                <span class="text-gray-400">Fully Paid</span>
              <% end %>
             </td>
           </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Payment Modal -->
<div id="paymentModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold text-blue-900">Record Payment</h3>
      <button onclick="closePaymentModal()" class="text-gray-400 hover:text-gray-600">&times;</button>
    </div>
    <form id="paymentForm" method="post">
      <div class="space-y-4">
        <div>
          <p class="text-sm text-gray-600">Fee Type: <span id="feeTypeName" class="font-semibold"></span></p>
          <p class="text-sm text-gray-600 mt-1">Remaining Balance: $<span id="remainingBalance"></span></p>
        </div>
        <div>
          <label for="payment_amount" class="block text-sm font-medium text-gray-700 mb-2">Payment Amount ($)</label>
          <input type="number" id="payment_amount" name="additional_payment" step="0.01" min="0.01" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <div class="flex justify-end space-x-3 pt-4">
          <button type="button" onclick="closePaymentModal()" class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600">Cancel</button>
          <button type="submit" class="bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800">Record Payment</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  function showPaymentModal(feeItemId, feeTypeName, remainingBalance) {
    const modal = document.getElementById('paymentModal');
    const form = document.getElementById('paymentForm');
    form.action = `/admin/students/${<%= @student.id %>}/student_fees/${<%= @student_fee.id %>}/record_payment?fee_item_id=${feeItemId}`;
    document.getElementById('feeTypeName').textContent = feeTypeName;
    document.getElementById('remainingBalance').textContent = remainingBalance;
    modal.classList.remove('hidden');
  }
  
  function closePaymentModal() {
    document.getElementById('paymentModal').classList.add('hidden');
    document.getElementById('payment_amount').value = '';
  }
</script>