<% content_for :page_title, "All Student Fees Overview" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Student Fees Overview</h1>
    <div class="space-x-3">
      <% if current_user.admin? %>
        <%= link_to "Permission Settings", admin_users_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      <% end %>
      <%= link_to dashboard_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Dashboard
      <% end %>
    </div>
  </div>

  <!-- Global Statistics -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Fees Due</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_fees.to_i) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Payments Received</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@total_paid.to_i) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Outstanding Balance</h3>
      <p class="text-2xl font-bold">$<%= number_with_delimiter(@outstanding.to_i) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Collection Rate</h3>
      <p class="text-2xl font-bold"><%= @total_fees > 0 ? ((@total_paid / @total_fees) * 100).round(1) : 0 %>%</p>
    </div>
  </div>

  <!-- Students List -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Class</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total Due</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total Paid</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @students.each do |student| %>
          <% total_due = student.total_fees_due %>
          <% total_paid = student.total_paid %>
          <% balance = total_due - total_paid %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= student.full_name %></div>
              <div class="text-xs text-gray-500">ID: <%= student.id %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= student.school_class&.name || 'Not assigned' %></td>
            <td class="px-6 py-4 text-sm text-gray-900 text-right">$<%= number_with_delimiter(total_due.to_i) %></td>
            <td class="px-6 py-4 text-sm text-green-600 text-right">$<%= number_with_delimiter(total_paid.to_i) %></td>
            <td class="px-6 py-4 text-sm text-red-600 font-semibold text-right">$<%= number_with_delimiter(balance.to_i) %></td>
            <td class="px-6 py-4 text-center">
              <% if balance <= 0 %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  Fully Paid
                </span>
              <% elsif total_paid > 0 %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                  Partially Paid
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                  Unpaid
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-center space-x-2">
              <%= link_to "View Fees", admin_student_student_fees_path(student), class: "text-blue-600 hover:text-blue-900 text-sm" %>
              <% if current_user.can_generate_invoice? %>
                <%= link_to "Invoice", generate_invoice_admin_student_student_fees_path(student), class: "text-green-600 hover:text-green-900 text-sm" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Fee Category Breakdown -->
  <div class="mt-8">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Fees by Category</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @category_stats.each do |category_name, total| %>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-600"><%= category_name %></p>
          <p class="text-xl font-bold text-blue-900">$<%= number_with_delimiter(total.to_i) %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>