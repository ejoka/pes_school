<% content_for :page_title, "Payment History for #{@student.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Payment History</h1>
      <p class="text-gray-600 mt-1">Student: <%= link_to @student.full_name, admin_student_path(@student), class: "text-blue-600 hover:text-blue-800" %></p>
    </div>
    <div class="space-x-3">
      <%= link_to "Record New Payment", new_admin_student_payment_path(@student), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      <%= link_to "Back to Fees", admin_student_student_fees_path(@student), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Fees Due</h3>
      <p class="text-2xl font-bold"><%= format_currency(@student.total_fees_due) %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Paid</h3>
      <p class="text-2xl font-bold"><%= format_currency(@total_paid) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Remaining Balance</h3>
      <p class="text-2xl font-bold"><%= format_currency(@student.current_balance) %></p>
    </div>
  </div>

  <!-- Payments Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Method</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reference</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Applied To</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notes</th>
          <% if @can_delete %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          <% end %>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @payments.each do |payment_record| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= payment_record.payment_date.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">
              <%= format_currency(payment_record.amount) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= payment_record.payment_method %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= payment_record.reference.presence || '—' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if payment_record.payable_type == 'StudentFee' && payment_record.payable_id %>
                <% fee = StudentFee.find_by(id: payment_record.payable_id) %>
                <%= fee&.fee_category&.name || 'N/A' %>
              <% else %>
                General Payment
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= payment_record.notes.presence || '—' %>
            </td>
            <% if @can_delete %>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "Delete", admin_student_payment_path(@student, payment_record), method: :delete, data: { confirm: "Are you sure you want to delete this payment?" }, class: "text-red-600 hover:text-red-900" %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    <table>
  </div>

  <% if @payments.empty? %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">💰</div>
      <p class="text-gray-500">No payments recorded yet.</p>
      <%= link_to "Record First Payment", new_admin_student_payment_path(@student), class: "mt-2 inline-block text-blue-600 hover:text-blue-800" %>
    </div>
  <% end %>
</div>