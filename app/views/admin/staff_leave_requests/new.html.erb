<% content_for :page_title, "New Leave Request" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">New Leave Request</h1>

  <%= form_with(model: [:admin, @leave_request], local: true, class: "space-y-4") do |f| %>
    <% if @leave_request.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <% @leave_request.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :staff_assignment_id, "Staff Member", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.collection_select :staff_assignment_id, @staff_members, :id, ->(sa) { "#{sa.user.full_name} - #{sa.department.name}" }, { include_blank: 'Select Staff' }, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div>
      <%= f.label :leave_type, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :leave_type, options_for_select(StaffLeaveRequest::LEAVE_TYPES.map { |k,v| [v,k] }), { include_blank: 'Select Leave Type' }, required: true, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :start_date, required: true, class: "w-full px-3 py-2 border rounded-md" %>
      </div>
      <div>
        <%= f.label :end_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :end_date, required: true, class: "w-full px-3 py-2 border rounded-md" %>
      </div>
    </div>

    <div>
      <%= f.label :reason, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :reason, rows: 4, class: "w-full px-3 py-2 border rounded-md", placeholder: "Please provide reason for leave..." %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :status, options_for_select(StaffLeaveRequest::STATUSES.map { |k,v| [v,k] }, 'pending'), {}, class: "w-full px-3 py-2 border rounded-md" %>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_staff_leave_requests_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
      <%= f.submit "Submit Request", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded font-semibold" %>
    </div>
  <% end %>
</div>