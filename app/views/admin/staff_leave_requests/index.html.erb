<% content_for :page_title, "Staff Leave Requests" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-3xl font-bold text-blue-900">Staff Leave Requests</h1>
    <%= link_to new_admin_staff_leave_request_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      New Leave Request
    <% end %>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6">
    <div class="bg-yellow-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Pending</p>
      <p class="text-2xl font-bold text-yellow-600"><%= @leave_requests.select { |l| l.status == 'pending' }.count %></p>
    </div>
    <div class="bg-green-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Approved</p>
      <p class="text-2xl font-bold text-green-600"><%= @leave_requests.select { |l| l.status == 'approved' }.count %></p>
    </div>
    <div class="bg-red-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Rejected</p>
      <p class="text-2xl font-bold text-red-600"><%= @leave_requests.select { |l| l.status == 'rejected' }.count %></p>
    </div>
    <div class="bg-blue-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Total Leave Days</p>
      <p class="text-2xl font-bold text-blue-600"><%= @leave_requests.sum(&:leave_days) %></p>
    </div>
  </div>

  <!-- Scrollable table container -->
  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Staff</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Department</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Leave Type</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Period</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Days</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Reason</th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% if @leave_requests.any? %>
              <% @leave_requests.each do |leave| %>
                <tr class="hover:bg-gray-50 transition duration-150">
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                    <div class="flex items-center">
                      <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-2">
                        <span class="text-blue-600 font-semibold text-sm"><%= leave.staff_assignment.user.first_name[0].upcase %></span>
                      </div>
                      <%= leave.staff_assignment.user.full_name %>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= leave.staff_assignment.department.name %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      <%= leave.leave_type_humanized %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= leave.start_date.strftime("%b %d") %> - <%= leave.end_date.strftime("%b %d, %Y") %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-center font-semibold">
                    <%= leave.leave_days %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= leave.status_color %>">
                      <%= leave.status.humanize %>
                    </span>
                  </td>
                  <td class="px-3 py-4 text-sm text-gray-500 max-w-xs truncate">
                    <%= leave.reason.truncate(50) if leave.reason %>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <div class="flex items-center justify-end space-x-2">
                      <%= link_to admin_staff_leave_request_path(leave), class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-green-100 text-green-700 hover:bg-green-200 transition", title: "View" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                        View
                      <% end %>
                      
                      <%= link_to edit_admin_staff_leave_request_path(leave), class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-blue-100 text-blue-700 hover:bg-blue-200 transition", title: "Edit" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Edit
                      <% end %>
                      
                      <% if leave.status == 'pending' %>
                        <%= button_to approve_admin_staff_leave_request_path(leave), method: :patch, class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-green-100 text-green-700 hover:bg-green-200 transition", title: "Approve" do %>
                          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                          Approve
                        <% end %>
                        
                        <%= button_to reject_admin_staff_leave_request_path(leave), method: :patch, class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-red-100 text-red-700 hover:bg-red-200 transition", title: "Reject" do %>
                          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                          </svg>
                          Reject
                        <% end %>
                      <% end %>
                      
                      <%= link_to admin_staff_leave_request_path(leave), method: :delete, data: { confirm: "Are you sure you want to delete this leave request for #{leave.staff_assignment.user.full_name}?" }, class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-red-100 text-red-700 hover:bg-red-200 transition", title: "Delete" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8" class="text-center py-12">
                  <div class="flex flex-col items-center justify-center">
                    <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <p class="text-gray-500 text-lg">No leave requests found.</p>
                    <p class="text-gray-400 text-sm mt-1">Create a new leave request.</p>
                    <%= link_to new_admin_staff_leave_request_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition" do %>
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                      </svg>
                      Create First Leave Request
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
