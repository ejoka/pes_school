<% content_for :page_title, @department.name %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900"><%= @department.name %></h1>
    <div class="space-x-2">
      <%= link_to "Edit", edit_admin_department_path(@department), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" %>
      <%= link_to "Back", admin_departments_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Department Info</h2>
      <p><strong>Name:</strong> <%= @department.name %></p>
      <p><strong>Code:</strong> <%= @department.code %></p>
      <p><strong>Head of Department:</strong> <%= @department.hod_name %></p>
      <p><strong>Description:</strong> <%= @department.description %></p>
    </div>

    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Statistics</h2>
      <p><strong>Total Staff:</strong> <%= @department.staff_count %></p>
      <p><strong>Active Staff:</strong> <%= @department.staff_assignments.active.count %></p>
    </div>
  </div>

  <div class="mt-6 border-t pt-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-blue-900">Staff Members</h2>
      <%= link_to "Assign Staff", new_admin_staff_assignment_path(department_id: @department.id), class: "bg-green-600 text-white px-3 py-1 rounded text-sm" %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr><th class="px-4 py-2 text-left">Name</th><th class="px-4 py-2 text-left">Position</th><th class="px-4 py-2 text-left">Status</th><th class="px-4 py-2 text-left">Joined</th><th class="px-4 py-2">Actions</th></tr>
        </thead>
        <tbody>
          <% @staff_assignments.each do |sa| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2"><%= sa.user.full_name %></td>
              <td class="px-4 py-2"><%= sa.position %></td>
              <td class="px-4 py-2"><span class="px-2 py-1 rounded-full text-xs <%= sa.status_color %>"><%= sa.status.humanize %></span></td>
              <td class="px-4 py-2"><%= sa.joined_date.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-2"><%= link_to "View", admin_staff_assignment_path(sa), class: "inline-flex items-center px-2 py-1 bg-green-600 text-white font-medium text-xs rounded-md shadow-sm hover:bg-green-700 hover:shadow-md active:shadow-sm transition-all duration-200 ease-in-out" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>