<% content_for :page_title, "Admin Dashboard" %>

<div class="space-y-6">
  <!-- Welcome Section -->
  <div class="rounded-lg shadow-lg p-6 text-white mb-6" style="background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);">
    <h1 class="text-3xl font-bold">Welcome back, <%= current_user.first_name %>!</h1>
    <p class="text-blue-200 mt-2">Here's what's happening with your school today.</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-500 text-sm">Total Students</p>
          <p class="text-3xl font-bold text-blue-900"><%= number_with_delimiter(@total_students) %></p>
        </div>
        <div class="bg-blue-100 rounded-full p-3">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <span class="text-green-600 text-sm">+<%= Student.where('created_at > ?', 30.days.ago).count %> this month</span>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-500 text-sm">Total Teachers</p>
          <p class="text-3xl font-bold text-blue-900"><%= number_with_delimiter(@total_teachers) %></p>
        </div>
        <div class="bg-green-100 rounded-full p-3">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <span class="text-green-600 text-sm"><%= @total_staff %> total staff members</span>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-500 text-sm">Fee Collection</p>
          <p class="text-3xl font-bold text-blue-900"><%= @collection_rate %>%</p>
        </div>
        <div class="bg-yellow-100 rounded-full p-3">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <span class="text-blue-600 text-sm"><%= format_currency(@total_fees_collected) %> collected</span>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-500 text-sm">Attendance Rate</p>
          <p class="text-3xl font-bold text-blue-900"><%= @attendance_rate %>%</p>
        </div>
        <div class="bg-purple-100 rounded-full p-3">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <span class="text-green-600 text-sm">This month</span>
      </div>
    </div>
  </div>

  <!-- Charts - 2 per row using CSS Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Monthly Fee Collection Chart -->
    <div class="bg-white rounded-lg shadow-lg p-4">
      <h2 class="text-lg font-bold text-blue-900 mb-3">Monthly Fee Collection</h2>
      <canvas id="feeCollectionChart" style="width:100%; height:300px;"></canvas>
    </div>

    <!-- Student Enrollment by Class Chart -->
    <div class="bg-white rounded-lg shadow-lg p-4">
      <h2 class="text-lg font-bold text-blue-900 mb-3">Student Enrollment by Class</h2>
      <canvas id="enrollmentChart" style="width:100%; height:300px;"></canvas>
    </div>

    <!-- Fee Collection by Category Chart -->
    <div class="bg-white rounded-lg shadow-lg p-4">
      <h2 class="text-lg font-bold text-blue-900 mb-3">Fee Collection by Category</h2>
      <canvas id="feeCategoryChart" style="width:100%; height:300px;"></canvas>
    </div>

    <!-- Gender Distribution Chart -->
    <div class="bg-white rounded-lg shadow-lg p-4">
      <h2 class="text-lg font-bold text-blue-900 mb-3">Gender Distribution</h2>
      <canvas id="genderChart" style="width:100%; height:300px;"></canvas>
    </div>
  </div>

  <!-- Recent Activities in 2 Columns -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-white rounded-lg shadow-lg p-6">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Recent Payments</h2>
      <div class="space-y-3">
        <% if @recent_payments.any? %>
          <% @recent_payments.each do |payment| %>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
              <div>
                <p class="font-medium text-gray-900"><%= payment.student&.full_name %></p>
                <p class="text-xs text-gray-500"><%= payment.payment_date.strftime("%b %d, %Y") %></p>
              </div>
              <div class="text-right">
                <p class="font-semibold text-green-600"><%= format_currency(payment.amount) %></p>
                <p class="text-xs text-gray-500"><%= payment.payment_method %></p>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 text-center py-4">No recent payments</p>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Recent Attendance</h2>
      <div class="space-y-3">
        <% if @recent_attendance.any? %>
          <% @recent_attendance.each do |attendance| %>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
              <div>
                <p class="font-medium text-gray-900"><%= attendance.student&.full_name %></p>
                <p class="text-xs text-gray-500"><%= attendance.date.strftime("%b %d, %Y") %></p>
              </div>
              <div>
                <span class="px-2 py-1 rounded-full text-xs font-semibold <%= attendance.status_color %>">
                  <%= attendance.status_name %>
                </span>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 text-center py-4">No recent attendance records</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Top Performing Classes -->
  <div class="bg-white rounded-lg shadow-lg p-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Top Performing Classes</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Class Name</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Student Count</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Pass Mark</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @top_classes.each do |class_obj| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= class_obj.name %></td>
              <td class="px-6 py-4 text-sm text-center text-gray-500"><%= class_obj.student_count %></td>
              <td class="px-6 py-4 text-sm text-center"><span class="px-2 py-1 bg-green-100 text-green-800 rounded-full text-xs"><%= class_obj.pass_mark %>%</span></td>
            </td>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  // Wait for the page to fully load
  document.addEventListener('DOMContentLoaded', function() {
    // Ensure Chart.js is loaded
    if (typeof Chart === 'undefined') {
      // If Chart.js isn't loaded yet, wait for it
      var checkChart = setInterval(function() {
        if (typeof Chart !== 'undefined') {
          clearInterval(checkChart);
          initializeCharts();
        }
      }, 100);
    } else {
      initializeCharts();
    }
    
    function initializeCharts() {
      // Monthly Fee Collection Chart
      const feeCtx = document.getElementById('feeCollectionChart');
      if (feeCtx) {
        new Chart(feeCtx, {
          type: 'line',
          data: {
            labels: <%= @monthly_fee_labels.to_json.html_safe %>,
            datasets: [{
              label: 'Fee Collection',
              data: <%= @monthly_fee_data.to_json.html_safe %>,
              borderColor: '#1e3a8a',
              backgroundColor: 'rgba(30, 58, 138, 0.1)',
              tension: 0.4,
              fill: true
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
              legend: { position: 'top' },
              tooltip: { callbacks: { label: function(context) { return formatCurrency(context.raw); } } }
            }
          }
        });
      }

      // Enrollment by Class Chart
      const enrollCtx = document.getElementById('enrollmentChart');
      if (enrollCtx) {
        new Chart(enrollCtx, {
          type: 'bar',
          data: {
            labels: <%= @class_enrollment_labels.to_json.html_safe %>,
            datasets: [{
              label: 'Number of Students',
              data: <%= @class_enrollment_data.to_json.html_safe %>,
              backgroundColor: '#eab308',
              borderRadius: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { position: 'top' } }
          }
        });
      }

      // Fee Collection by Category Chart
      const feeCatCtx = document.getElementById('feeCategoryChart');
      if (feeCatCtx) {
        new Chart(feeCatCtx, {
          type: 'doughnut',
          data: {
            labels: <%= @fee_category_labels.to_json.html_safe %>,
            datasets: [{
              data: <%= @fee_category_values.to_json.html_safe %>,
              backgroundColor: ['#1e3a8a', '#eab308', '#10b981', '#ef4444', '#8b5cf6', '#f59e0b', '#06b6d4', '#ec4899']
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { position: 'bottom' } }
          }
        });
      }

      // Gender Distribution Chart
      const genderCtx = document.getElementById('genderChart');
      if (genderCtx) {
        new Chart(genderCtx, {
          type: 'pie',
          data: {
            labels: ['Male', 'Female', 'Other'],
            datasets: [{
              data: [<%= @male_students %>, <%= @female_students %>, <%= @other_students %>],
              backgroundColor: ['#3b82f6', '#ec4899', '#9ca3af']
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { position: 'bottom' } }
          }
        });
      }
    }
  });

  function formatCurrency(amount) {
    return '<%= Setting.get("currency_symbol", "$") %>' + amount.toLocaleString();
  }
</script>