<% content_for :page_title, "Item: #{@inventory_item.name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900"><%= @inventory_item.name %></h1>
    <div class="space-x-3">
      <%= link_to edit_admin_inventory_item_path(@inventory_item), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" do %>
        Edit Item
      <% end %>
      <%= link_to new_admin_stock_movement_path(item_id: @inventory_item.id), class: "inline-flex items-center px-4 py-2 bg-amber-600 text-white font-medium rounded-lg shadow-md hover:bg-amber-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" do %>
        Record Movement
      <% end %>
      <%= link_to admin_inventory_items_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" do %>
        Back to Items
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="border border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Item Details</h2>
      <div class="space-y-3">
        <div><span class="font-medium">Category:</span> <%= @inventory_item.inventory_category&.name %></div>
        <div><span class="font-medium">Supplier:</span> <%= @inventory_item.supplier&.name || 'N/A' %></div>
        <div><span class="font-medium">Unit:</span> <%= @inventory_item.unit %></div>
        <div><span class="font-medium">Location:</span> <%= @inventory_item.location || 'Not specified' %></div>
        <div><span class="font-medium">Description:</span> <%= @inventory_item.description || 'No description' %></div>
      </div>
    </div>

    <div class="border border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Stock Information</h2>
      <div class="space-y-3">
        <div><span class="font-medium">Current Quantity:</span> <span class="text-xl font-bold"><%= @inventory_item.quantity %> <%= @inventory_item.unit %></span></div>
        <div><span class="font-medium">Minimum Stock Level:</span> <%= @inventory_item.minimum_stock %> <%= @inventory_item.unit %></div>
        <div><span class="font-medium">Unit Price:</span> <%= format_currency(@inventory_item.unit_price) %></div>
        <div><span class="font-medium">Total Value:</span> <%= format_currency(@inventory_item.total_value) %></div>
        <div>
          <span class="font-medium">Status:</span>
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= @inventory_item.stock_status[:color] %>">
            <%= @inventory_item.stock_status[:text] %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 border border-gray-200 rounded-lg p-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Recent Stock Movements</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Quantity</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Reference</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Notes</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @stock_movements.each do |movement| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= movement.date.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="px-2 py-1 rounded-full text-xs <%= movement.movement_type == 'receive' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= movement.movement_type.upcase %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center"><%= movement.quantity %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= movement.reference_number || '—' %></td>
              <td class="px-6 py-4 text-sm"><%= movement.notes || '—' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>