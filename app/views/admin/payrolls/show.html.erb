<% content_for :page_title, "Payroll Details" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Payroll Details</h1>
    <div class="space-x-2">
      <%= link_to "Edit", edit_admin_payroll_path(@payroll), class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" %>
      <%= link_to "Back", admin_payrolls_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Staff Information</h2>
      <p><strong>Name:</strong> <%= @payroll.staff_assignment.user.full_name %></p>
      <p><strong>Department:</strong> <%= @payroll.staff_assignment.department.name %></p>
      <p><strong>Position:</strong> <%= @payroll.staff_assignment.position %></p>
    </div>

    <div class="border p-4 rounded-lg">
      <h2 class="font-bold text-lg mb-3">Payroll Period</h2>
      <p><strong>Month:</strong> <%= @payroll.month_name %></p>
      <p><strong>Year:</strong> <%= @payroll.year %></p>
      <p><strong>Payment Date:</strong> <%= @payroll.payment_date&.strftime("%B %d, %Y") || 'Not paid yet' %></p>
      <p><strong>Status:</strong> <span class="px-2 py-1 rounded-full text-xs <%= @payroll.status_color %>"><%= @payroll.status.humanize %></span></p>
    </div>
  </div>

  <div class="mt-6 border p-4 rounded-lg bg-gray-50">
    <h2 class="font-bold text-lg mb-3">Salary Breakdown</h2>
    <div class="grid grid-cols-2 gap-4">
      <div><strong>Basic Salary:</strong></div><div class="text-right"><%= number_to_currency(@payroll.basic_salary) %></div>
      <div><strong>Allowances:</strong></div><div class="text-right"><%= number_to_currency(@payroll.allowances) %></div>
      <div><strong>Deductions:</strong></div><div class="text-right"><%= number_to_currency(@payroll.deductions) %></div>
      <div class="border-t pt-2"><strong>Net Pay:</strong></div><div class="border-t pt-2 text-right font-bold"><%= number_to_currency(@payroll.net_salary) %></div>
    </div>
  </div>

  <% if @payroll.notes.present? %>
    <div class="mt-4 border p-4 rounded-lg">
      <p><strong>Notes:</strong> <%= @payroll.notes %></p>
    </div>
  <% end %>
</div>