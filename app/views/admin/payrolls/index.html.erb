<% content_for :page_title, "Payroll" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-3xl font-bold text-blue-900">Payroll Management</h1>
    <%= link_to new_admin_payroll_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Create Payroll
    <% end %>
  </div>

  <% if @payrolls.nil? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <p>Debug: @payrolls is nil. Please check the logs.</p>
    </div>
  <% elsif @payrolls.empty? %>
    <div class="text-center py-12">
      <div class="flex flex-col items-center justify-center">
        <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-gray-500 text-lg">No payroll records found.</p>
        <p class="text-gray-400 text-sm mt-1">Create your first payroll record.</p>
        <%= link_to new_admin_payroll_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Create First Payroll
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Scrollable table container -->
    <div class="overflow-x-auto -mx-4 sm:mx-0">
      <div class="inline-block min-w-full align-middle">
        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
          <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Staff</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Department</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Month/Year</th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Basic</th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Allowances</th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Deductions</th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Net Pay</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                  <span class="sr-only">Actions</span>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% @payrolls.each do |payroll| %>
                <tr class="hover:bg-gray-50 transition duration-150">
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                    <%= payroll.staff_assignment.user.full_name %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= payroll.staff_assignment.department.name %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <span class="font-medium"><%= payroll.month_name %></span> <%= payroll.year %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-900 text-right">
                    <%= number_to_currency(payroll.basic_salary) %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-900 text-right">
                    <%= number_to_currency(payroll.allowances) %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-red-600 text-right">
                    <%= number_to_currency(payroll.deductions) %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm font-bold text-green-600 text-right">
                    <%= number_to_currency(payroll.net_salary) %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= payroll.status_color %>">
                      <%= payroll.status.humanize %>
                    </span>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <div class="flex items-center justify-end space-x-2">
                      <%= link_to admin_payroll_path(payroll), class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-green-100 text-green-700 hover:bg-green-200 transition", title: "View" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                        View
                      <% end %>
                      
                      <%= link_to edit_admin_payroll_path(payroll), class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-blue-100 text-blue-700 hover:bg-blue-200 transition", title: "Edit" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Edit
                      <% end %>
                      
                      <% if payroll.status == 'draft' %>
                        <%= button_to mark_paid_admin_payroll_path(payroll), method: :patch, class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-green-100 text-green-700 hover:bg-green-200 transition", title: "Mark as Paid", form: { data: { turbo: false } } do %>
                          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          Mark Paid
                        <% end %>
                      <% end %>
                      
                      <%= link_to admin_payroll_path(payroll), method: :delete, data: { confirm: "Are you sure you want to delete this payroll record?" }, class: "inline-flex items-center px-2.5 py-1.5 text-xs font-medium rounded bg-red-100 text-red-700 hover:bg-red-200 transition", title: "Delete" do %>
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </td>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6 pt-4 border-t">
      <div class="bg-blue-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Total Payroll Amount</p>
        <p class="text-2xl font-bold text-blue-900"><%= number_to_currency(@payrolls.sum(&:net_salary)) %></p>
      </div>
      <div class="bg-green-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Paid Payroll</p>
        <p class="text-2xl font-bold text-green-600"><%= number_to_currency(@payrolls.select { |p| p.status == 'paid' }.sum(&:net_salary)) %></p>
      </div>
      <div class="bg-yellow-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Pending Payroll</p>
        <p class="text-2xl font-bold text-yellow-600"><%= number_to_currency(@payrolls.select { |p| p.status == 'draft' }.sum(&:net_salary)) %></p>
      </div>
      <div class="bg-purple-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">Total Staff on Payroll</p>
        <p class="text-2xl font-bold text-purple-600"><%= @payrolls.map(&:staff_assignment_id).uniq.count %></p>
      </div>
    </div>
  <% end %>
</div>