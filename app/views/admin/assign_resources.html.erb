<div class="bg-white rounded-lg shadow-lg p-6">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">Assign Resources to <%= @user.full_name %></h1>
  
  <%= form_tag save_resource_assignment_admin_user_path(@user), method: :post do %>
    <div class="space-y-6">
      <div>
        <h2 class="text-xl font-semibold text-blue-900 mb-4">Categories</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @categories.each do |category| %>
            <label class="flex items-center space-x-3">
              <%= check_box_tag "resources[Category][]", category.id, @user.assigned_categories.include?(category), class: "form-checkbox h-5 w-5 text-yellow-500" %>
              <span class="text-gray-700"><%= category.name %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-blue-900 mb-4">Classes</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @classes.each do |school_class| %>
            <label class="flex items-center space-x-3">
              <%= check_box_tag "resources[SchoolClass][]", school_class.id, @user.assigned_classes.include?(school_class), class: "form-checkbox h-5 w-5 text-yellow-500" %>
              <span class="text-gray-700"><%= school_class.name %> (Pass Mark: <%= school_class.pass_mark %>)</span>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-blue-900 mb-4">Subjects</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @subjects.each do |subject| %>
            <label class="flex items-center space-x-3">
              <%= check_box_tag "resources[Subject][]", subject.id, @user.assigned_subjects.include?(subject), class: "form-checkbox h-5 w-5 text-yellow-500" %>
              <span class="text-gray-700"><%= subject.name %> (<%= subject.subject_code %>) - Pass Mark: <%= subject.pass_mark %></span>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end space-x-3">
      <%= link_to "Cancel", admin_users_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save Assignments", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150" %>
    </div>
  <% end %>
</div>