<% content_for :page_title, "Assign Resources to #{@user.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Assign Resources & Permissions</h1>
      <p class="text-gray-600 mt-1">User: <span class="font-semibold text-blue-900"><%= @user.full_name %></span> (<%= @user.email %>)</p>
    </div>
    <%= link_to "Back to Users", admin_users_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_tag save_resource_assignment_admin_user_path(@user), method: :post, class: "space-y-8" do %>
    
    <!-- Categories Section -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3">
        <h2 class="text-xl font-bold">Categories</h2>
      </div>
      
      <% if @categories.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">View</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Create</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Edit</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Delete</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @categories.each do |category| %>
                <% key = "Category_#{category.id}" %>
                <% existing_perms = @resource_permissions[key] || { 'can_view' => false, 'can_create' => false, 'can_edit' => false, 'can_delete' => false } %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= category.name %></div>
                    <div class="text-xs text-gray-500"><%= category.school_classes.count %> classes</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Category][<%= category.id %>][can_view]" value="0">
                    <%= check_box_tag "resources[Category][#{category.id}][can_view]", "1", existing_perms['can_view'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Category][<%= category.id %>][can_create]" value="0">
                    <%= check_box_tag "resources[Category][#{category.id}][can_create]", "1", existing_perms['can_create'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Category][<%= category.id %>][can_edit]" value="0">
                    <%= check_box_tag "resources[Category][#{category.id}][can_edit]", "1", existing_perms['can_edit'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Category][<%= category.id %>][can_delete]" value="0">
                    <%= check_box_tag "resources[Category][#{category.id}][can_delete]", "1", existing_perms['can_delete'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          No categories available. <%= link_to "Create a category", new_admin_category_path, class: "text-blue-600 hover:text-blue-800" %> first.
        </div>
      <% end %>
    </div>

    <!-- Classes Section -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3">
        <h2 class="text-xl font-bold">Classes</h2>
      </div>
      
      <% if @classes.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Class</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">View</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Create</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Edit</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Delete</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @classes.each do |school_class| %>
                <% key = "SchoolClass_#{school_class.id}" %>
                <% existing_perms = @resource_permissions[key] || { 'can_view' => false, 'can_create' => false, 'can_edit' => false, 'can_delete' => false } %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= school_class.name %></div>
                    <div class="text-xs text-gray-500">Pass Mark: <%= school_class.pass_mark %>%</div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= school_class.category.name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[SchoolClass][<%= school_class.id %>][can_view]" value="0">
                    <%= check_box_tag "resources[SchoolClass][#{school_class.id}][can_view]", "1", existing_perms['can_view'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[SchoolClass][<%= school_class.id %>][can_create]" value="0">
                    <%= check_box_tag "resources[SchoolClass][#{school_class.id}][can_create]", "1", existing_perms['can_create'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[SchoolClass][<%= school_class.id %>][can_edit]" value="0">
                    <%= check_box_tag "resources[SchoolClass][#{school_class.id}][can_edit]", "1", existing_perms['can_edit'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[SchoolClass][<%= school_class.id %>][can_delete]" value="0">
                    <%= check_box_tag "resources[SchoolClass][#{school_class.id}][can_delete]", "1", existing_perms['can_delete'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          No classes available. <%= link_to "Create a class", new_admin_school_class_path, class: "text-blue-600 hover:text-blue-800" %> first.
        </div>
      <% end %>
    </div>

    <!-- Subjects Section -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3">
        <h2 class="text-xl font-bold">Subjects</h2>
      </div>
      
      <% if @subjects.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subject</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Class</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">View</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Create</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Edit</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Delete</th>
               </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @subjects.each do |subject| %>
                <% key = "Subject_#{subject.id}" %>
                <% existing_perms = @resource_permissions[key] || { 'can_view' => false, 'can_create' => false, 'can_edit' => false, 'can_delete' => false } %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= subject.name %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 text-xs font-mono font-semibold bg-gray-100 text-gray-800 rounded"><%= subject.subject_code %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= subject.school_class.name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Subject][<%= subject.id %>][can_view]" value="0">
                    <%= check_box_tag "resources[Subject][#{subject.id}][can_view]", "1", existing_perms['can_view'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Subject][<%= subject.id %>][can_create]" value="0">
                    <%= check_box_tag "resources[Subject][#{subject.id}][can_create]", "1", existing_perms['can_create'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Subject][<%= subject.id %>][can_edit]" value="0">
                    <%= check_box_tag "resources[Subject][#{subject.id}][can_edit]", "1", existing_perms['can_edit'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <input type="hidden" name="resources[Subject][<%= subject.id %>][can_delete]" value="0">
                    <%= check_box_tag "resources[Subject][#{subject.id}][can_delete]", "1", existing_perms['can_delete'], class: "form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-6 text-center text-gray-500">
          No subjects available. <%= link_to "Create a subject", new_admin_subject_path, class: "text-blue-600 hover:text-blue-800" %> first.
        </div>
      <% end %>
    </div>

    <!-- Permission Summary -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h3 class="font-semibold text-blue-900 mb-2">Permission Guidelines</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-sm">
        <div>
          <span class="font-medium text-green-700">View:</span>
          <span class="text-gray-600">Can see the resource</span>
        </div>
        <div>
          <span class="font-medium text-blue-700">Create:</span>
          <span class="text-gray-600">Can add new items</span>
        </div>
        <div>
          <span class="font-medium text-yellow-700">Edit:</span>
          <span class="text-gray-600">Can modify existing items</span>
        </div>
        <div>
          <span class="font-medium text-red-700">Delete:</span>
          <span class="text-gray-600">Can remove items</span>
        </div>
      </div>
      <div class="mt-3 text-xs text-gray-500">
        Note: Admin users have full access regardless of these settings.
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_users_path, class: "bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save Assignments & Permissions", class: "bg-blue-900 text-yellow-500 px-6 py-2 rounded-lg hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>