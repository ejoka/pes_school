<% content_for :page_title, "Assign Resources to #{@user.full_name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Assign Resources & Permissions</h1>
      <p class="text-gray-600 mt-1">User: <span class="font-semibold text-blue-900"><%= @user.full_name %></span> (<%= @user.email %>)</p>
    </div>
    <%= link_to "Back to Users", admin_users_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_tag save_resource_assignment_admin_user_path(@user), method: :post, class: "space-y-4", id: "permissions-form" do %>
    
    <!-- ==================== ACADEMICS SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('academics')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
          <h2 class="text-xl font-bold">Academics</h2>
        </div>
        <svg id="academics-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
      
      <div id="academics-content" class="hidden">
        <!-- Categories -->
        <div class="border-t border-gray-200">
          <div class="bg-gray-50 px-6 py-2 flex justify-between items-center">
            <h3 class="font-semibold text-gray-700">Categories</h3>
            <button type="button" onclick="toggleAllInSection('category', true)" class="text-xs bg-green-500 text-white px-2 py-1 rounded">Select All</button>
          </div>
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr>
            </thead>
            <tbody>
              <% @categories.each do |category| %>
                <% key = "Category_#{category.id}" %>
                <% perms = @resource_permissions[key] || {} %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-3 text-sm"><%= category.name %></td>
                  <td class="text-center"><input type="hidden" name="resources[Category][<%= category.id %>][can_view]" value="0"><input type="checkbox" name="resources[Category][<%= category.id %>][can_view]" value="1" <%= 'checked' if perms['can_view'] %> class="category-checkbox"></td>
                  <td class="text-center"><input type="hidden" name="resources[Category][<%= category.id %>][can_create]" value="0"><input type="checkbox" name="resources[Category][<%= category.id %>][can_create]" value="1" <%= 'checked' if perms['can_create'] %> class="category-checkbox"></td>
                  <td class="text-center"><input type="hidden" name="resources[Category][<%= category.id %>][can_edit]" value="0"><input type="checkbox" name="resources[Category][<%= category.id %>][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %> class="category-checkbox"></td>
                  <td class="text-center"><input type="hidden" name="resources[Category][<%= category.id %>][can_delete]" value="0"><input type="checkbox" name="resources[Category][<%= category.id %>][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %> class="category-checkbox"></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <!-- Classes & Subjects sections similar... -->
      </div>
    </div>

    <!-- ==================== STUDENT MANAGEMENT SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('student_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          <h2 class="text-xl font-bold">Student Management</h2>
        </div>
        <svg id="student_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="student_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% sm = StudentManagement.default %>
            <% perms = @resource_permissions["StudentManagement_#{sm.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Student Records</td>
              <td class="text-center"><input type="hidden" name="resources[StudentManagement][can_view]" value="0"><input type="checkbox" name="resources[StudentManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[StudentManagement][can_create]" value="0"><input type="checkbox" name="resources[StudentManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[StudentManagement][can_edit]" value="0"><input type="checkbox" name="resources[StudentManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[StudentManagement][can_delete]" value="0"><input type="checkbox" name="resources[StudentManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ==================== FEE MANAGEMENT SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('fee_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h2 class="text-xl font-bold">Fee Management</h2>
        </div>
        <svg id="fee_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="fee_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% fm = FeeManagement.default %>
            <% perms = @resource_permissions["FeeManagement_#{fm.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Fee Records</td>
              <td class="text-center"><input type="hidden" name="resources[FeeManagement][can_view]" value="0"><input type="checkbox" name="resources[FeeManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[FeeManagement][can_create]" value="0"><input type="checkbox" name="resources[FeeManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[FeeManagement][can_edit]" value="0"><input type="checkbox" name="resources[FeeManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[FeeManagement][can_delete]" value="0"><input type="checkbox" name="resources[FeeManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ==================== EXAMINATION SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('exam_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
          <h2 class="text-xl font-bold">Examination</h2>
        </div>
        <svg id="exam_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="exam_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% em = ExamManagement.default %>
            <% perms = @resource_permissions["ExamManagement_#{em.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Exam Management</td>
              <td class="text-center"><input type="hidden" name="resources[ExamManagement][can_view]" value="0"><input type="checkbox" name="resources[ExamManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[ExamManagement][can_create]" value="0"><input type="checkbox" name="resources[ExamManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[ExamManagement][can_edit]" value="0"><input type="checkbox" name="resources[ExamManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[ExamManagement][can_delete]" value="0"><input type="checkbox" name="resources[ExamManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ==================== TRANSPORT SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('transport_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
          <h2 class="text-xl font-bold">Transport</h2>
        </div>
        <svg id="transport_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="transport_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% tm = TransportManagement.default %>
            <% perms = @resource_permissions["TransportManagement_#{tm.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Transport Management</td>
              <td class="text-center"><input type="hidden" name="resources[TransportManagement][can_view]" value="0"><input type="checkbox" name="resources[TransportManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[TransportManagement][can_create]" value="0"><input type="checkbox" name="resources[TransportManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[TransportManagement][can_edit]" value="0"><input type="checkbox" name="resources[TransportManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[TransportManagement][can_delete]" value="0"><input type="checkbox" name="resources[TransportManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ==================== INVENTORY SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('inventory_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
          <h2 class="text-xl font-bold">Inventory</h2>
        </div>
        <svg id="inventory_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="inventory_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% im = InventoryManagement.default %>
            <% perms = @resource_permissions["InventoryManagement_#{im.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Inventory Management</td>
              <td class="text-center"><input type="hidden" name="resources[InventoryManagement][can_view]" value="0"><input type="checkbox" name="resources[InventoryManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[InventoryManagement][can_create]" value="0"><input type="checkbox" name="resources[InventoryManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[InventoryManagement][can_edit]" value="0"><input type="checkbox" name="resources[InventoryManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[InventoryManagement][can_delete]" value="0"><input type="checkbox" name="resources[InventoryManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ==================== ATTENDANCE SECTION ==================== -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-blue-900 text-white px-6 py-3 flex justify-between items-center cursor-pointer" onclick="toggleSection('attendance_mgmt')">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h2 class="text-xl font-bold">Attendance</h2>
        </div>
        <svg id="attendance_mgmt-icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
      <div id="attendance_mgmt-content" class="hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th><th class="px-6 py-3 text-center">View</th><th class="px-6 py-3 text-center">Create</th><th class="px-6 py-3 text-center">Edit</th><th class="px-6 py-3 text-center">Delete</th></tr></thead>
          <tbody>
            <% am = AttendanceManagement.default %>
            <% perms = @resource_permissions["AttendanceManagement_#{am.id}"] || {} %>
            <tr><td class="px-6 py-3 text-sm">Attendance Management</td>
              <td class="text-center"><input type="hidden" name="resources[AttendanceManagement][can_view]" value="0"><input type="checkbox" name="resources[AttendanceManagement][can_view]" value="1" <%= 'checked' if perms['can_view'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[AttendanceManagement][can_create]" value="0"><input type="checkbox" name="resources[AttendanceManagement][can_create]" value="1" <%= 'checked' if perms['can_create'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[AttendanceManagement][can_edit]" value="0"><input type="checkbox" name="resources[AttendanceManagement][can_edit]" value="1" <%= 'checked' if perms['can_edit'] %>></td>
              <td class="text-center"><input type="hidden" name="resources[AttendanceManagement][can_delete]" value="0"><input type="checkbox" name="resources[AttendanceManagement][can_delete]" value="1" <%= 'checked' if perms['can_delete'] %>></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Permission Guidelines -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h3 class="font-semibold text-blue-900 mb-2">Permission Guidelines</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-sm">
        <div><span class="font-medium text-green-700">View:</span> <span class="text-gray-600">Can see the resource</span></div>
        <div><span class="font-medium text-blue-700">Create:</span> <span class="text-gray-600">Can add new items</span></div>
        <div><span class="font-medium text-yellow-700">Edit:</span> <span class="text-gray-600">Can modify existing items</span></div>
        <div><span class="font-medium text-red-700">Delete:</span> <span class="text-gray-600">Can remove items</span></div>
      </div>
      <div class="mt-3 text-xs text-gray-500">Note: Admin users have full access regardless of these settings.</div>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_users_path, class: "bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600" %>
      <%= submit_tag "Save Assignments & Permissions", class: "bg-blue-900 text-yellow-500 px-6 py-2 rounded-lg hover:bg-blue-800 font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  function toggleSection(sectionId) {
    const content = document.getElementById(`${sectionId}-content`);
    const icon = document.getElementById(`${sectionId}-icon`);
    if (content) {
      content.classList.toggle('hidden');
      if (icon) icon.classList.toggle('rotate-180');
    }
  }
  
  function toggleAllInSection(section, checked) {
    document.querySelectorAll(`.${section}-checkbox`).forEach(cb => cb.checked = checked);
  }
</script>

<style>
  .rotate-180 { transform: rotate(180deg); }
  .form-checkbox { width: 1.25rem; height: 1.25rem; border-radius: 0.25rem; border-color: #d1d5db; }
  .form-checkbox:checked { background-color: #eab308; border-color: #eab308; }
  table input[type="checkbox"] { width: 1.25rem; height: 1.25rem; cursor: pointer; }
  .hover\:bg-gray-50:hover { background-color: #f9fafb; }
  .cursor-pointer { cursor: pointer; }
  .transition-transform { transition: transform 0.2s ease; }
</style>