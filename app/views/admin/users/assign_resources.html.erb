<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Assign Resources</h1>
      <p class="text-gray-600 mt-1">User: <span class="font-semibold text-blue-900"><%= @user.full_name %></span> (<%= @user.email %>)</p>
    </div>
    <%= link_to "Back to Users", admin_users_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_tag save_resource_assignment_admin_user_path(@user), method: :post, class: "space-y-8" do %>
    
    <!-- Categories Section -->
    <div class="border border-gray-200 rounded-lg p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-blue-900">Categories</h2>
        <button type="button" onclick="toggleAll('categories')" class="text-sm text-yellow-600 hover:text-yellow-700">
          Select All
        </button>
      </div>
      
      <% if @categories.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @categories.each do |category| %>
            <label class="flex items-center space-x-3 p-3 hover:bg-gray-50 rounded-lg transition duration-150">
              <%= check_box_tag "resources[Category][]", category.id, @user.assigned_categories.include?(category), 
                  class: "category-checkbox form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500",
                  data: { category_id: category.id } %>
              <div class="flex-1">
                <span class="text-gray-700 font-medium"><%= category.name %></span>
                <span class="text-xs text-gray-500 ml-2">
                  (<%= category.school_classes.count %> classes)
                </span>
              </div>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No categories available. <%= link_to "Create a category", new_admin_category_path, class: "text-blue-600 hover:text-blue-800" %> first.</p>
      <% end %>
    </div>

    <!-- Classes Section -->
    <div class="border border-gray-200 rounded-lg p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-blue-900">Classes</h2>
        <button type="button" onclick="toggleAll('classes')" class="text-sm text-yellow-600 hover:text-yellow-700">
          Select All
        </button>
      </div>
      
      <% if @classes.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @classes.each do |school_class| %>
            <label class="flex items-center space-x-3 p-3 hover:bg-gray-50 rounded-lg transition duration-150">
              <%= check_box_tag "resources[SchoolClass][]", school_class.id, @user.assigned_classes.include?(school_class), 
                  class: "class-checkbox form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500",
                  data: { class_id: school_class.id } %>
              <div class="flex-1">
                <div class="font-medium text-gray-700"><%= school_class.name %></div>
                <div class="text-xs text-gray-500">
                  Category: <%= school_class.category.name %> | Pass Mark: <%= school_class.pass_mark %>%
                </div>
                <div class="text-xs text-gray-400">
                  <%= school_class.subjects.count %> subjects
                </div>
              </div>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No classes available. <%= link_to "Create a class", new_admin_school_class_path, class: "text-blue-600 hover:text-blue-800" %> first.</p>
      <% end %>
    </div>

    <!-- Subjects Section -->
    <div class="border border-gray-200 rounded-lg p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-blue-900">Subjects</h2>
        <button type="button" onclick="toggleAll('subjects')" class="text-sm text-yellow-600 hover:text-yellow-700">
          Select All
        </button>
      </div>
      
      <% if @subjects.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @subjects.each do |subject| %>
            <label class="flex items-center space-x-3 p-3 hover:bg-gray-50 rounded-lg transition duration-150">
              <%= check_box_tag "resources[Subject][]", subject.id, @user.assigned_subjects.include?(subject), 
                  class: "subject-checkbox form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500",
                  data: { subject_id: subject.id } %>
              <div class="flex-1">
                <div class="font-medium text-gray-700"><%= subject.name %></div>
                <div class="text-xs text-gray-500">
                  Code: <%= subject.subject_code %> | Class: <%= subject.school_class.name %>
                </div>
                <div class="text-xs text-gray-400">
                  Pass Mark: <%= subject.pass_mark %>%
                </div>
              </div>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No subjects available. <%= link_to "Create a subject", new_admin_subject_path, class: "text-blue-600 hover:text-blue-800" %> first.</p>
      <% end %>
    </div>

    <!-- Current Assigned Resources Summary -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <h3 class="font-semibold text-blue-900 mb-2">Current Assignments Summary</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
        <div>
          <span class="text-gray-600">Categories:</span>
          <span class="font-semibold text-blue-900 ml-2" id="categories-count"><%= @user.assigned_categories.count %></span>
        </div>
        <div>
          <span class="text-gray-600">Classes:</span>
          <span class="font-semibold text-blue-900 ml-2" id="classes-count"><%= @user.assigned_classes.count %></span>
        </div>
        <div>
          <span class="text-gray-600">Subjects:</span>
          <span class="font-semibold text-blue-900 ml-2" id="subjects-count"><%= @user.assigned_subjects.count %></span>
        </div>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_users_path, class: "bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save Assignments", class: "bg-blue-900 text-yellow-500 px-6 py-2 rounded-lg hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  function toggleAll(section) {
    const checkboxes = document.querySelectorAll(`.${section === 'categories' ? 'category-checkbox' : section === 'classes' ? 'class-checkbox' : 'subject-checkbox'}`);
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(checkbox => {
      checkbox.checked = !allChecked;
    });
    updateCounts();
  }

  function updateCounts() {
    const categoriesCount = document.querySelectorAll('.category-checkbox:checked').length;
    const classesCount = document.querySelectorAll('.class-checkbox:checked').length;
    const subjectsCount = document.querySelectorAll('.subject-checkbox:checked').length;
    
    document.getElementById('categories-count').textContent = categoriesCount;
    document.getElementById('classes-count').textContent = classesCount;
    document.getElementById('subjects-count').textContent = subjectsCount;
  }

  // Add event listeners to update counts when checkboxes are clicked
  document.querySelectorAll('.category-checkbox, .class-checkbox, .subject-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', updateCounts);
  });
</script>