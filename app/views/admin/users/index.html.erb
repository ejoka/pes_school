<% content_for :page_title, "Manage Users" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Manage Users</h1>
    <%= link_to "Add New User", new_admin_user_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Professional Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned Resources</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <%= link_to admin_user_path(user), class: "text-sm font-medium text-blue-600 hover:text-blue-900" do %>
                <%= user.full_name %>
              <% end %>
              <div class="text-xs text-gray-500"><%= user.title %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= user.email %></td>
            <td class="px-6 py-4">
              <% if user.admin? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">
                  Administrator
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                  <%= user.professional_type_humanized %>
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= user.admin? ? 'bg-blue-900 text-yellow-500' : 'bg-gray-100 text-gray-800' %>">
                <%= user.admin? ? 'Admin' : 'User' %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm">
              <div class="space-y-1">
                <div class="text-xs">
                  <span class="font-medium">Categories:</span> 
                  <%= user.assigned_categories.count %>
                  <% 
                    categories_with_edit = 0
                    user.assigned_categories.each do |cat|
                      categories_with_edit += 1 if user.permissions_for(cat)['can_edit'] == true
                    end
                  %>
                  <% if categories_with_edit > 0 %>
                    (<%= categories_with_edit %> with edit)
                  <% end %>
                </div>
                <div class="text-xs">
                  <span class="font-medium">Classes:</span> 
                  <%= user.assigned_classes.count %>
                  <% 
                    classes_with_edit = 0
                    user.assigned_classes.each do |cls|
                      classes_with_edit += 1 if user.permissions_for(cls)['can_edit'] == true
                    end
                  %>
                  <% if classes_with_edit > 0 %>
                    (<%= classes_with_edit %> with edit)
                  <% end %>
                </div>
                <div class="text-xs">
                  <span class="font-medium">Subjects:</span> 
                  <%= user.assigned_subjects.count %>
                  <% 
                    subjects_with_edit = 0
                    user.assigned_subjects.each do |subj|
                      subjects_with_edit += 1 if user.permissions_for(subj)['can_edit'] == true
                    end
                  %>
                  <% if subjects_with_edit > 0 %>
                    (<%= subjects_with_edit %> with edit)
                  <% end %>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 text-sm font-medium space-x-3">
              <%= link_to "View", admin_user_path(user), class: "text-green-600 hover:text-green-900" %>
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-blue-600 hover:text-blue-900" %>
              <%= link_to "Permissions", assign_resources_admin_user_path(user), class: "text-yellow-600 hover:text-yellow-900" %>
              <%= link_to "Delete", admin_user_path(user), method: :delete, data: { confirm: "Are you sure you want to delete #{user.full_name}?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>