<% content_for :page_title, "Batch Attendance - #{@exam_schedule.subject&.name} (#{@exam_schedule.exam_type&.name})" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Batch Attendance</h1>
      <p class="text-gray-600 mt-1">
        <%= @exam_schedule.subject&.name %> - <%= @exam_schedule.exam_type&.name %>
        <br>Date: <%= @exam_schedule.start_time.strftime("%B %d, %Y at %I:%M %p") if @exam_schedule.start_time %>
        <br>Class: <%= @exam_schedule.school_class&.name %>
      </p>
    </div>
    <div class="space-x-3">
      <%= link_to admin_exam_attendances_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Attendance
      <% end %>
    </div>
  </div>

  <% if @students.any? %>
    <%= form_tag batch_attendance_admin_exam_attendances_path, method: :post, class: "space-y-6" do %>
      <%= hidden_field_tag :exam_schedule_id, @exam_schedule.id %>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Admission No</th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Attendance Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remarks</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @students.each do |student| %>
              <% existing = @existing_attendances[student.id] %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= student.full_name %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= student.id %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <div class="flex items-center justify-center space-x-4">
                    <label class="inline-flex items-center">
                      <input type="radio" name="attendances[<%= student.id %>]" value="present" <%= 'checked' if existing&.status == 'present' %> class="form-radio h-4 w-4 text-green-500">
                      <span class="ml-2 text-sm text-gray-700">Present</span>
                    </label>
                    <label class="inline-flex items-center">
                      <input type="radio" name="attendances[<%= student.id %>]" value="absent" <%= 'checked' if existing&.status == 'absent' %> class="form-radio h-4 w-4 text-red-500">
                      <span class="ml-2 text-sm text-gray-700">Absent</span>
                    </label>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <input type="text" name="remarks[<%= student.id %>]" value="<%= existing&.remarks %>" class="w-full px-2 py-1 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500 text-sm" placeholder="Optional remarks...">
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="flex justify-between items-center pt-4">
        <div class="flex space-x-4">
          <button type="button" onclick="markAll('present')" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 transition duration-150">
            Mark All Present
          </button>
          <button type="button" onclick="markAll('absent')" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition duration-150">
            Mark All Absent
          </button>
        </div>
        <div class="flex space-x-3">
          <%= link_to "Cancel", admin_exam_attendances_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
          <%= submit_tag "Save Attendance", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">👨‍🎓</div>
      <p class="text-gray-500 text-lg">No students found in this class.</p>
      <p class="text-gray-400 text-sm mt-2">Please add students to the class first.</p>
      <%= link_to "Add Students", admin_students_path, class: "mt-4 inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
    </div>
  <% end %>
</div>

<script>
  function markAll(status) {
    const radios = document.querySelectorAll(`input[type="radio"][value="${status}"]`);
    radios.forEach(radio => {
      radio.checked = true;
    });
  }
</script>