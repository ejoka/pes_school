<% content_for :page_title, "Record Exam Attendance" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Record Exam Attendance</h1>
    <%= link_to admin_exam_attendances_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Attendance
    <% end %>
  </div>

  <div class="bg-blue-50 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-sm text-gray-600">Exam</p>
        <p class="font-semibold"><%= @exam_schedule.subject&.name %> - <%= @exam_schedule.exam_type&.name %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Date & Time</p>
        <p class="font-semibold"><%= @exam_schedule.formatted_datetime %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Class</p>
        <p class="font-semibold"><%= @exam_schedule.school_class&.name %></p>
      </div>
      <div>
        <p class="text-sm text-gray-600">Venue</p>
        <p class="font-semibold"><%= @exam_schedule.venue %></p>
      </div>
    </div>
  </div>

  <%= form_with(model: [:admin, @exam_attendance], local: true, class: "space-y-6") do |f| %>
    <% if @exam_attendance.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= pluralize(@exam_attendance.errors.count, "error") %> occurred:</h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @exam_attendance.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= hidden_field_tag :exam_schedule_id, @exam_schedule.id %>

    <div>
      <%= f.label :student_id, "Student", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.collection_select :student_id, @students, :id, :full_name, { include_blank: 'Select Student' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      <p class="mt-1 text-xs text-gray-500">Select the student to record attendance for</p>
    </div>

    <div>
      <%= f.label :status, "Attendance Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex space-x-4">
        <label class="inline-flex items-center">
          <%= f.radio_button :status, "present", class: "form-radio h-4 w-4 text-green-500" %>
          <span class="ml-2 text-gray-700">Present</span>
        </label>
        <label class="inline-flex items-center">
          <%= f.radio_button :status, "absent", class: "form-radio h-4 w-4 text-red-500" %>
          <span class="ml-2 text-gray-700">Absent</span>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :remarks, "Remarks (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :remarks, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "e.g., Late arrival, Medical reason, etc." %>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_exam_attendances_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Record Attendance", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>