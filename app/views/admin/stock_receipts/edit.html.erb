<% content_for :page_title, "Edit Stock Receipt" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-3xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Edit Stock Receipt</h1>
    <%= link_to "Back to Receipts", admin_stock_receipts_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-blue-50 rounded-lg p-4 mb-6">
    <p class="text-sm text-blue-800">
      <strong>Receipt Number:</strong> <%= @stock_receipt.receipt_number %>
    </p>
  </div>

  <%= form_with(model: [:admin, @stock_receipt], local: true, class: "space-y-6") do |f| %>
    <% if @stock_receipt.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        <h3 class="font-bold"><%= pluralize(@stock_receipt.errors.count, "error") %> prohibited this receipt from being saved:</h3>
        <ul class="list-disc list-inside mt-2">
          <% @stock_receipt.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :supplier_id, "Supplier", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :supplier_id, @suppliers, :id, :name, { include_blank: 'Select Supplier' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :received_date, "Received Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :received_date, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :notes, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_stock_receipt_path(@stock_receipt), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Receipt", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>