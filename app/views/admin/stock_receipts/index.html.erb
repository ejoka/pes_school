<% content_for :page_title, "Stock Receipts" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Stock Receipts</h1>
    <%= link_to "New Stock Receipt", new_admin_stock_receipt_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Receipt #</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @stock_receipts.each do |receipt| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono font-medium"><%= receipt.receipt_number %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= receipt.supplier&.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= receipt.received_date.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-right"><%= format_currency(receipt.total_amount) %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= receipt.status_color %>">
                <%= receipt.status.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
              <%= link_to "View", admin_stock_receipt_path(receipt), class: "text-green-600 hover:text-green-900" %>
              <% if receipt.status == 'pending' %>
                <%= link_to "Receive", receive_admin_stock_receipt_path(receipt), method: :post, class: "text-blue-600 hover:text-blue-900" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>