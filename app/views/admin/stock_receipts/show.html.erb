<% content_for :page_title, "Stock Receipt #{@stock_receipt.receipt_number}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Stock Receipt</h1>
    <div class="space-x-3">
      <% if @stock_receipt.status == 'pending' %>
        <%= button_to "Confirm Receipt", receive_admin_stock_receipt_path(@stock_receipt), method: :post, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
      <% end %>
      <%= link_to admin_stock_receipts_path, class: "bg-gray-500 text-white px-4 py-2 rounded" do %>
        Back to Receipts
      <% end %>
    </div>
  </div>

  <!-- Rest of the show view remains the same -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Receipt Number</p>
      <p class="font-mono font-semibold"><%= @stock_receipt.receipt_number %></p>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Supplier</p>
      <p class="font-semibold"><%= @stock_receipt.supplier&.name %></p>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Received Date</p>
      <p class="font-semibold"><%= @stock_receipt.received_date.strftime("%B %d, %Y") %></p>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Item</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Quantity</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Unit Price</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @items.each do |item| %>
          <tr>
            <td class="px-6 py-4 text-sm"><%= item.inventory_item&.name %></td>
            <td class="px-6 py-4 text-sm text-right"><%= item.quantity %> <%= item.inventory_item&.unit %></td>
            <td class="px-6 py-4 text-sm text-right"><%= format_currency(item.unit_price) %></td>
            <td class="px-6 py-4 text-sm text-right font-semibold"><%= format_currency(item.total_price) %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-50">
        <tr>
          <td colspan="3" class="px-6 py-4 text-right font-bold">Total:</td>
          <td class="px-6 py-4 text-right font-bold"><%= format_currency(@stock_receipt.total_amount) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <% if @stock_receipt.notes.present? %>
    <div class="mt-6 bg-gray-50 rounded-lg p-4">
      <p class="text-sm text-gray-600 mb-1">Notes</p>
      <p class="text-gray-700"><%= @stock_receipt.notes %></p>
    </div>
  <% end %>
</div>