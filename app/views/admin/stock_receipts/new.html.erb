<% content_for :page_title, "New Stock Receipt" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">New Stock Receipt</h1>
    <%= link_to "Back to Receipts", admin_stock_receipts_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <%= form_with(model: [:admin, @stock_receipt], local: true, class: "space-y-6") do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :supplier_id, "Supplier", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :supplier_id, @suppliers, :id, :name, { include_blank: 'Select Supplier' }, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>

      <div>
        <%= f.label :received_date, "Received Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :received_date, required: true, value: Date.today, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :notes, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
    </div>

    <div class="border-t pt-6">
      <h2 class="text-lg font-semibold text-blue-900 mb-4">Items Received</h2>
      <div id="items-container">
        <div class="item-row grid grid-cols-1 md:grid-cols-4 gap-4 mb-3">
          <div class="md:col-span-2">
            <select name="items[][inventory_item_id]" class="w-full px-3 py-2 border border-gray-300 rounded-md">
              <option value="">Select Item</option>
              <% @inventory_items.each do |item| %>
                <option value="<%= item.id %>"><%= item.name %> (<%= item.unit %>)</option>
              <% end %>
            </select>
          </div>
          <div>
            <input type="number" name="items[][quantity]" placeholder="Quantity" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-md">
          </div>
          <div>
            <input type="number" name="items[][unit_price]" placeholder="Unit Price" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-md">
          </div>
        </div>
      </div>
      <button type="button" onclick="addItemRow()" class="mt-2 text-blue-600 hover:text-blue-800">+ Add Another Item</button>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_stock_receipts_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
      <%= f.submit "Create Receipt", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  function addItemRow() {
    const container = document.getElementById('items-container');
    const newRow = document.createElement('div');
    newRow.className = 'item-row grid grid-cols-1 md:grid-cols-4 gap-4 mb-3';
    newRow.innerHTML = `
      <div class="md:col-span-2">
        <select name="items[][inventory_item_id]" class="w-full px-3 py-2 border border-gray-300 rounded-md">
          <option value="">Select Item</option>
          <% @inventory_items.each do |item| %>
            <option value="<%= item.id %>"><%= item.name %> (<%= item.unit %>)</option>
          <% end %>
        </select>
      </div>
      <div><input type="number" name="items[][quantity]" placeholder="Quantity" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-md"></div>
      <div><input type="number" name="items[][unit_price]" placeholder="Unit Price" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-md"></div>
      <div><button type="button" onclick="this.parentElement.remove()" class="text-red-600">Remove</button></div>
    `;
    container.appendChild(newRow);
  }
</script>