<% content_for :page_title, "Exam Marks Details" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Marks Details</h1>
    <div class="flex space-x-3">
      <%= link_to edit_admin_enter_mark_path(@enter_mark), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit Marks
      <% end %>
      <%= link_to admin_enter_marks_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Marks
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Student Information -->
    <div class="bg-gradient-to-r from-blue-50 to-white rounded-lg p-6">
      <h2 class="text-lg font-semibold text-blue-900 mb-4">Student Information</h2>
      <div class="space-y-3">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Student Name</p>
          <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.student&.full_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Class</p>
          <p class="text-base text-gray-700"><%= @enter_mark.school_class&.name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Admission No</p>
          <p class="text-base text-gray-700"><%= @enter_mark.student&.id %></p>
        </div>
      </div>
    </div>

    <!-- Exam Information -->
    <div class="bg-gradient-to-r from-green-50 to-white rounded-lg p-6">
      <h2 class="text-lg font-semibold text-blue-900 mb-4">Exam Information</h2>
      <div class="space-y-3">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Subject</p>
          <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.subject&.name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Type</p>
          <p class="text-base text-gray-700"><%= @enter_mark.exam_attendance&.exam_schedule&.exam_type&.name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Date</p>
          <p class="text-base text-gray-700"><%= @enter_mark.exam_attendance&.exam_schedule&.start_time&.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Marks Information -->
  <div class="mt-6 bg-gray-50 rounded-lg p-6">
    <h2 class="text-lg font-semibold text-blue-900 mb-4">Marks Information</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Marks Obtained</p>
        <p class="text-2xl font-bold text-gray-900"><%= @enter_mark.marks_obtained %> / <%= @enter_mark.total_marks %></p>
      </div>
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Percentage</p>
        <p class="text-2xl font-bold <%= @enter_mark.percentage.to_i >= 50 ? 'text-green-600' : 'text-red-600' %>">
          <%= @enter_mark.percentage %>%
        </p>
      </div>
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Grade</p>
        <span class="inline-flex px-3 py-1 text-sm font-semibold rounded-full <%= @enter_mark.grade_color %>">
          <%= @enter_mark.grade %>
        </span>
      </div>
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Status</p>
        <span class="inline-flex px-3 py-1 text-sm font-semibold rounded-full <%= @enter_mark.status_color %>">
          <%= @enter_mark.status.upcase %>
        </span>
      </div>
    </div>
    
    <!-- Progress Bar -->
    <div class="mt-4">
      <div class="flex justify-between text-sm mb-1">
        <span>Performance</span>
        <span><%= @enter_mark.percentage %>%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2.5">
        <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= @enter_mark.percentage %>%"></div>
      </div>
    </div>
  </div>

  <!-- Remarks -->
  <% if @enter_mark.remarks.present? %>
    <div class="mt-6 bg-yellow-50 rounded-lg p-6">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Remarks</p>
      <p class="text-gray-700"><%= @enter_mark.remarks %></p>
    </div>
  <% end %>

  <!-- Metadata -->
  <div class="mt-6 text-xs text-gray-400 text-center">
    <p>Recorded by: <%= @enter_mark.user&.full_name || 'System' %> on <%= @enter_mark.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    <% if @enter_mark.updated_at != @enter_mark.created_at %>
      <p>Last updated: <%= @enter_mark.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    <% end %>
  </div>

  <!-- Danger Zone -->
  <div class="mt-8 pt-6 border-t border-red-200">
    <div class="bg-red-50 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-700 mb-3">Danger Zone</h3>
      <p class="text-sm text-red-600 mb-4">This action cannot be undone. This will permanently delete the marks record.</p>
      <%= link_to "Delete Marks Record", admin_enter_mark_path(@enter_mark), method: :delete, data: { confirm: "Are you sure you want to delete these marks?" }, class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition duration-150" %>
    </div>
  </div>
</div>