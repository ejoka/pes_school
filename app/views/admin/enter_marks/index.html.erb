<% content_for :page_title, "Enter Marks" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Marks</h1>
      <p class="text-sm text-gray-500 mt-1">Enter and manage student exam marks</p>
    </div>
    <div class="flex space-x-3">
      <button onclick="showExamSelector()" class="bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold inline-flex items-center">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Batch Entry
      </button>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Records</h3>
      <p class="text-2xl font-bold"><%= @total_marks %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Average Percentage</h3>
      <p class="text-2xl font-bold"><%= @average_percentage %>%</p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Pass Rate</h3>
      <p class="text-2xl font-bold"><%= @pass_rate %>%</p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Pass/Fail</h3>
      <p class="text-2xl font-bold"><%= @pass_count %> / <%= @fail_count %></p>
    </div>
  </div>

  <!-- Marks Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subject</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Exam</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Marks</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Percentage</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Grade</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if @enter_marks.any? %>
          <% @enter_marks.each do |mark| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= mark.student&.full_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= mark.subject&.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= mark.exam_attendance&.exam_schedule&.exam_type&.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center font-medium">
                <%= mark.marks_obtained %> / <%= mark.total_marks %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                <span class="<%= mark.percentage.to_i >= 50 ? 'text-green-600' : 'text-red-600' %> font-semibold">
                  <%= mark.percentage %>%
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= mark.grade_color %>">
                  <%= mark.grade %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= mark.status_color %>">
                  <%= mark.status.upcase %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
                <%= link_to edit_admin_enter_mark_path(mark), class: "text-blue-600 hover:text-blue-900" do %>
                  Edit
                <% end %>
                <%= link_to admin_enter_mark_path(mark), method: :delete, data: { confirm: "Are you sure you want to delete this mark for #{mark.student&.full_name}?" }, class: "text-red-600 hover:text-red-900" do %>
                  Delete
                <% end %>
              </td>
            </td>
          <% end %>
        <% else %>
          <tr>
            <td colspan="8" class="text-center py-12">
              <div class="flex flex-col items-center justify-center">
                <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
                <p class="text-gray-500 text-lg">No exam marks records found.</p>
                <p class="text-sm text-gray-400 mt-2">Enter marks from exam attendance records.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Exam Selector Modal -->
<div id="examSelectorModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold text-blue-900">Select Exam Attendance</h3>
      <button onclick="closeExamSelector()" class="text-gray-400 hover:text-gray-600">&times;</button>
    </div>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Choose Exam</label>
        <select id="exam_attendance_id" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
          <option value="">Select an exam...</option>
          <% @exam_attendances_list.each do |attendance| %>
            <option value="<%= attendance.id %>">
              <%= attendance.subject&.name %> - <%= attendance.exam_schedule&.exam_type&.name %> 
              (<%= attendance.exam_schedule&.start_time&.strftime("%b %d, %Y") %>)
            </option>
          <% end %>
        </select>
      </div>
      <div class="flex justify-end space-x-3 pt-4">
        <button onclick="closeExamSelector()" class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600">Cancel</button>
        <button onclick="goToBatchMarks()" class="bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800">Continue</button>
      </div>
    </div>
  </div>
</div>

<script>
  function showExamSelector() {
    document.getElementById('examSelectorModal').classList.remove('hidden');
  }
  
  function closeExamSelector() {
    document.getElementById('examSelectorModal').classList.add('hidden');
  }
  
  function goToBatchMarks() {
    const examId = document.getElementById('exam_attendance_id').value;
    if (examId) {
      window.location.href = `/admin/enter_marks/batch_marks?exam_attendance_id=${examId}`;
    } else {
      alert('Please select an exam attendance');
    }
  }
</script>
