<% content_for :page_title, "Edit Exam Marks" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Edit Exam Marks</h1>
    <div class="space-x-3">
      <%= link_to admin_enter_marks_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Marks
      <% end %>
    </div>
  </div>

  <!-- Exam Information Summary -->
  <div class="bg-gradient-to-r from-blue-50 to-white rounded-lg p-4 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Student</p>
        <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.student&.full_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Subject</p>
        <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.subject&.name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Type</p>
        <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.exam_attendance&.exam_schedule&.exam_type&.name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Date</p>
        <p class="text-lg font-semibold text-gray-900"><%= @enter_mark.exam_attendance&.exam_schedule&.start_time&.strftime("%B %d, %Y") %></p>
      </div>
    </div>
  </div>

  <!-- Current Grade Display -->
  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Current Marks</p>
        <p class="text-xl font-bold text-gray-900"><%= @enter_mark.marks_obtained %> / <%= @enter_mark.total_marks %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Percentage</p>
        <p class="text-xl font-bold <%= @enter_mark.percentage.to_i >= 50 ? 'text-green-600' : 'text-red-600' %>">
          <%= @enter_mark.percentage %>%
        </p>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Grade</p>
        <span class="inline-flex px-3 py-1 text-sm font-semibold rounded-full <%= @enter_mark.grade_color %>">
          <%= @enter_mark.grade %>
        </span>
      </div>
    </div>
  </div>

  <%= form_with(model: [:admin, @enter_mark], local: true, class: "space-y-6") do |f| %>
    <% if @enter_mark.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@enter_mark.errors.count, "error") %> prohibited this mark from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @enter_mark.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :marks_obtained, "Marks Obtained", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :marks_obtained, required: true, step: 0.01, min: 0, max: @enter_mark.total_marks, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "0" %>
        <p class="mt-1 text-xs text-gray-500">Maximum: <%= @enter_mark.total_marks %></p>
      </div>

      <div>
        <%= f.label :total_marks, "Total Marks", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :total_marks, required: true, step: 0.01, min: 1, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "100" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :remarks, "Remarks (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :remarks, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "Additional comments about the student's performance..." %>
      </div>
    </div>

    <!-- Preview Section -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-yellow-800 mb-2">Preview</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-gray-600">Calculated Percentage</p>
          <p class="text-lg font-bold" id="percentage_preview">0%</p>
        </div>
        <div>
          <p class="text-xs text-gray-600">Grade</p>
          <span id="grade_preview" class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">-</span>
        </div>
      </div>
      <p class="text-xs text-yellow-700 mt-2">Note: Grade is automatically calculated based on percentage ranges</p>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_enter_marks_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Marks", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  // Live preview for percentage and grade
  const marksInput = document.querySelector('#enter_mark_marks_obtained');
  const totalInput = document.querySelector('#enter_mark_total_marks');
  const percentagePreview = document.querySelector('#percentage_preview');
  const gradePreview = document.querySelector('#grade_preview');
  
  function calculatePreview() {
    const marks = parseFloat(marksInput.value) || 0;
    const total = parseFloat(totalInput.value) || 1;
    const percentage = (marks / total * 100).toFixed(2);
    percentagePreview.textContent = `${percentage}%`;
    
    // Determine grade based on percentage
    let grade = 'Not Graded';
    let gradeClass = 'bg-gray-100 text-gray-800';
    
    if (percentage >= 80) {
      grade = 'A';
      gradeClass = 'bg-green-100 text-green-800';
    } else if (percentage >= 70) {
      grade = 'B';
      gradeClass = 'bg-blue-100 text-blue-800';
    } else if (percentage >= 60) {
      grade = 'C';
      gradeClass = 'bg-yellow-100 text-yellow-800';
    } else if (percentage >= 50) {
      grade = 'D';
      gradeClass = 'bg-orange-100 text-orange-800';
    } else if (percentage >= 0) {
      grade = 'F';
      gradeClass = 'bg-red-100 text-red-800';
    }
    
    gradePreview.textContent = grade;
    gradePreview.className = `inline-flex px-2 py-1 text-xs font-semibold rounded-full ${gradeClass}`;
  }
  
  if (marksInput && totalInput) {
    marksInput.addEventListener('input', calculatePreview);
    totalInput.addEventListener('input', calculatePreview);
    calculatePreview(); // Initial calculation
  }
</script>