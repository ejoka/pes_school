<% content_for :page_title, "Color Settings" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Color Settings</h1>
    <%= link_to "Back to Settings", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
  </div>

  <%= form_tag admin_update_color_settings_path, method: :post, class: "space-y-6" do %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Primary Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[primary_color]" value="<%= @colors[:primary_color].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[primary_color]" value="<%= @colors[:primary_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for main navigation, headers, and primary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Secondary Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[secondary_color]" value="<%= @colors[:secondary_color].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[secondary_color]" value="<%= @colors[:secondary_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for accents, highlights, and secondary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Accent Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[accent_color]" value="<%= @colors[:accent_color].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[accent_color]" value="<%= @colors[:accent_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for text on dark backgrounds</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Sidebar Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[sidebar_bg]" value="<%= @colors[:sidebar_bg].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[sidebar_bg]" value="<%= @colors[:sidebar_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for the sidebar menu</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Header Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[header_bg]" value="<%= @colors[:header_bg].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[header_bg]" value="<%= @colors[:header_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for the top header bar</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Button Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[button_bg]" value="<%= @colors[:button_bg].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[button_bg]" value="<%= @colors[:button_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for primary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Button Text Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[button_text]" value="<%= @colors[:button_text].value %>" class="h-10 w-20 border border-gray-300 rounded">
          <input type="text" name="colors[button_text]" value="<%= @colors[:button_text].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
        </div>
        <p class="mt-1 text-xs text-gray-500">Text color for primary buttons</p>
      </div>
    </div>

    <!-- Preview Section -->
    <div class="border border-gray-200 rounded-lg p-6 mt-6">
      <h3 class="text-lg font-semibold text-gray-700 mb-4">Preview</h3>
      <div class="space-y-4">
        <div style="background-color: <%= @colors[:primary_color].value %>; padding: 10px; border-radius: 5px;">
          <p style="color: <%= @colors[:accent_color].value %>;">Primary Color Preview - This is how your primary color will look</p>
        </div>
        <div style="background-color: <%= @colors[:secondary_color].value %>; padding: 10px; border-radius: 5px;">
          <p style="color: <%= @colors[:primary_color].value %>;">Secondary Color Preview - This is how your secondary color will look</p>
        </div>
        <button style="background-color: <%= @colors[:button_bg].value %>; color: <%= @colors[:button_text].value %>; padding: 8px 16px; border-radius: 5px; border: none; cursor: pointer;">
          Button Preview
        </button>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save Color Settings", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>