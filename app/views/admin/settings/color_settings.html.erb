<% content_for :page_title, "Color Settings" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Color Settings</h1>
    <%= link_to "Back to Settings", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
  </div>

  <%= form_tag admin_update_color_settings_path, method: :post, class: "space-y-6", id: "colorSettingsForm" do %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Primary Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[primary_color]" value="<%= @colors[:primary_color].value %>" class="h-10 w-20 border border-gray-300 rounded" id="primary_color_picker">
          <input type="text" name="colors[primary_color]" value="<%= @colors[:primary_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="primary_color_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for main navigation, headers, and primary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Secondary Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[secondary_color]" value="<%= @colors[:secondary_color].value %>" class="h-10 w-20 border border-gray-300 rounded" id="secondary_color_picker">
          <input type="text" name="colors[secondary_color]" value="<%= @colors[:secondary_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="secondary_color_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for accents, highlights, and secondary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Accent Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[accent_color]" value="<%= @colors[:accent_color].value %>" class="h-10 w-20 border border-gray-300 rounded" id="accent_color_picker">
          <input type="text" name="colors[accent_color]" value="<%= @colors[:accent_color].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="accent_color_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Used for text on dark backgrounds</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Sidebar Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[sidebar_bg]" value="<%= @colors[:sidebar_bg].value %>" class="h-10 w-20 border border-gray-300 rounded" id="sidebar_bg_picker">
          <input type="text" name="colors[sidebar_bg]" value="<%= @colors[:sidebar_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="sidebar_bg_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for the sidebar menu</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Header Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[header_bg]" value="<%= @colors[:header_bg].value %>" class="h-10 w-20 border border-gray-300 rounded" id="header_bg_picker">
          <input type="text" name="colors[header_bg]" value="<%= @colors[:header_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="header_bg_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for the top header bar</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Button Background</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[button_bg]" value="<%= @colors[:button_bg].value %>" class="h-10 w-20 border border-gray-300 rounded" id="button_bg_picker">
          <input type="text" name="colors[button_bg]" value="<%= @colors[:button_bg].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="button_bg_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Background color for primary buttons</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Button Text Color</label>
        <div class="flex items-center space-x-2">
          <input type="color" name="colors[button_text]" value="<%= @colors[:button_text].value %>" class="h-10 w-20 border border-gray-300 rounded" id="button_text_picker">
          <input type="text" name="colors[button_text]" value="<%= @colors[:button_text].value %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" id="button_text_text">
        </div>
        <p class="mt-1 text-xs text-gray-500">Text color for primary buttons</p>
      </div>
    </div>

    <!-- Preview Section -->
    <div class="border border-gray-200 rounded-lg p-6 mt-6">
      <h3 class="text-lg font-semibold text-gray-700 mb-4">Live Preview</h3>
      <div class="space-y-4">
        <div id="preview_primary" style="background-color: <%= @colors[:primary_color].value %>; padding: 10px; border-radius: 5px;">
          <p id="preview_accent" style="color: <%= @colors[:accent_color].value %>;">Primary Color Preview - This is how your primary color will look</p>
        </div>
        <div id="preview_secondary" style="background-color: <%= @colors[:secondary_color].value %>; padding: 10px; border-radius: 5px;">
          <p id="preview_primary_text" style="color: <%= @colors[:primary_color].value %>;">Secondary Color Preview - This is how your secondary color will look</p>
        </div>
        <button id="preview_button" style="background-color: <%= @colors[:button_bg].value %>; color: <%= @colors[:button_text].value %>; padding: 8px 16px; border-radius: 5px; border: none; cursor: pointer;">
          Button Preview
        </button>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save Color Settings", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  // Sync color pickers with text inputs
  function syncColorInputs(pickerId, textId) {
    const picker = document.getElementById(pickerId);
    const text = document.getElementById(textId);
    if (picker && text) {
      picker.addEventListener('input', function() {
        text.value = this.value;
        updatePreview();
      });
      text.addEventListener('input', function() {
        picker.value = this.value;
        updatePreview();
      });
    }
  }
  
  function updatePreview() {
    const primaryColor = document.getElementById('primary_color_text').value;
    const secondaryColor = document.getElementById('secondary_color_text').value;
    const accentColor = document.getElementById('accent_color_text').value;
    const buttonBg = document.getElementById('button_bg_text').value;
    const buttonText = document.getElementById('button_text_text').value;
    
    const previewPrimary = document.getElementById('preview_primary');
    const previewAccent = document.getElementById('preview_accent');
    const previewSecondary = document.getElementById('preview_secondary');
    const previewPrimaryText = document.getElementById('preview_primary_text');
    const previewButton = document.getElementById('preview_button');
    
    if (previewPrimary) previewPrimary.style.backgroundColor = primaryColor;
    if (previewAccent) previewAccent.style.color = accentColor;
    if (previewSecondary) previewSecondary.style.backgroundColor = secondaryColor;
    if (previewPrimaryText) previewPrimaryText.style.color = primaryColor;
    if (previewButton) {
      previewButton.style.backgroundColor = buttonBg;
      previewButton.style.color = buttonText;
    }
  }
  
  // Initialize all sync pairs
  syncColorInputs('primary_color_picker', 'primary_color_text');
  syncColorInputs('secondary_color_picker', 'secondary_color_text');
  syncColorInputs('accent_color_picker', 'accent_color_text');
  syncColorInputs('sidebar_bg_picker', 'sidebar_bg_text');
  syncColorInputs('header_bg_picker', 'header_bg_text');
  syncColorInputs('button_bg_picker', 'button_bg_text');
  syncColorInputs('button_text_picker', 'button_text_text');
  
  // Handle form submission with page reload
  const form = document.getElementById('colorSettingsForm');
  if (form) {
    form.addEventListener('submit', function(e) {
      // Show loading indicator
      const submitBtn = this.querySelector('input[type="submit"]');
      if (submitBtn) {
        submitBtn.value = 'Saving...';
        submitBtn.disabled = true;
      }
      // Allow normal form submission
    });
  }
</script>