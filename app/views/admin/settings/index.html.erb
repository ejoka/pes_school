<% content_for :page_title, "System Settings" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">System Settings</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- School Settings Card -->
    <div class="border border-gray-200 rounded-lg p-6 hover:shadow-lg transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center space-x-3">
          <svg class="h-8 w-8 text-blue-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          <h2 class="text-xl font-bold text-gray-800">School Information</h2>
        </div>
        <%= link_to "Configure", admin_school_settings_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      </div>
      <p class="text-gray-600">Manage school name, address, contact information, currency, and logo settings.</p>
    </div>

    <!-- Color Settings Card -->
    <div class="border border-gray-200 rounded-lg p-6 hover:shadow-lg transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center space-x-3">
          <svg class="h-8 w-8 text-blue-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
          </svg>
          <h2 class="text-xl font-bold text-gray-800">Color Theme</h2>
        </div>
        <%= link_to "Configure", admin_color_settings_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      </div>
      <p class="text-gray-600">Customize the system color scheme including primary, secondary colors and button styles.</p>
    </div>

    <!-- Invoice Settings Card -->
    <div class="border border-gray-200 rounded-lg p-6 hover:shadow-lg transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center space-x-3">
          <svg class="h-8 w-8 text-blue-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <h2 class="text-xl font-bold text-gray-800">Invoice Settings</h2>
        </div>
        <%= link_to "Configure", admin_school_settings_path(anchor: "invoice"), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      </div>
      <p class="text-gray-600">Configure invoice prefix, footer text, and other invoice-related settings.</p>
    </div>

    <!-- System Settings Card -->
    <div class="border border-gray-200 rounded-lg p-6 hover:shadow-lg transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center space-x-3">
          <svg class="h-8 w-8 text-blue-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <h2 class="text-xl font-bold text-gray-800">Academic Settings</h2>
        </div>
        <%= link_to "Configure", admin_school_settings_path(anchor: "academic"), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      </div>
      <p class="text-gray-600">Manage academic year, term dates, and other academic settings.</p>
    </div>
  </div>
</div>