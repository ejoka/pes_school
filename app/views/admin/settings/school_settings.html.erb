<% content_for :page_title, "School Settings" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">School Settings</h1>
    <%= link_to "Back to Settings", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
  </div>

  <%= form_tag admin_update_school_settings_path, method: :post, multipart: true, class: "space-y-6" do %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">School Name</label>
        <input type="text" name="settings[school_name]" value="<%= @settings[:school_name].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">School Website</label>
        <input type="text" name="settings[school_website]" value="<%= @settings[:school_website].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-2">School Address</label>
        <textarea name="settings[school_address]" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500"><%= @settings[:school_address].value %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
        <input type="text" name="settings[school_phone]" value="<%= @settings[:school_phone].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
        <input type="email" name="settings[school_email]" value="<%= @settings[:school_email].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Currency</label>
        <select name="settings[currency]" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
          <option value="USD" <%= @settings[:currency].value == 'USD' ? 'selected' : '' %>>USD - US Dollar</option>
          <option value="EUR" <%= @settings[:currency].value == 'EUR' ? 'selected' : '' %>>EUR - Euro</option>
          <option value="GBP" <%= @settings[:currency].value == 'GBP' ? 'selected' : '' %>>GBP - British Pound</option>
          <option value="TZS" <%= @settings[:currency].value == 'TZS' ? 'selected' : '' %>>TZS - Tanzanian Shilling</option>
          <option value="KES" <%= @settings[:currency].value == 'KES' ? 'selected' : '' %>>KES - Kenyan Shilling</option>
          <option value="UGX" <%= @settings[:currency].value == 'UGX' ? 'selected' : '' %>>UGX - Ugandan Shilling</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Currency Symbol</label>
        <input type="text" name="settings[currency_symbol]" value="<%= @settings[:currency_symbol].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Invoice Prefix</label>
        <input type="text" name="settings[invoice_prefix]" value="<%= @settings[:invoice_prefix].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Academic Year</label>
        <input type="text" name="settings[academic_year]" value="<%= @settings[:academic_year].value %>" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" placeholder="2024-2025">
      </div>

      <!-- Logo Upload Section -->
      <div class="md:col-span-2 border-t pt-4 mt-2">
        <h3 class="text-lg font-semibold text-blue-900 mb-4">Branding</h3>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">School Logo</label>
          <% logo_setting = Setting.find_by(key: 'logo') %>
          <% if logo_setting&.logo&.attached? %>
            <div class="mb-4 p-4 bg-gray-50 rounded-lg inline-block">
              <%= image_tag logo_setting.logo, class: "h-24 w-auto object-contain", alt: "School Logo" %>
              <p class="text-xs text-gray-500 mt-2">Current Logo</p>
            </div>
          <% end %>
          <input type="file" name="logo" accept="image/*" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
          <p class="mt-1 text-xs text-gray-500">Upload PNG, JPG, or SVG. Recommended size: 200x60px</p>
        </div>

        <!-- Favicon Upload Section -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Favicon (Browser Tab Icon)</label>
          <% favicon_setting = Setting.find_by(key: 'favicon') %>
          <% if favicon_setting&.favicon&.attached? %>
            <div class="mb-4 p-4 bg-gray-50 rounded-lg inline-block">
              <%= image_tag favicon_setting.favicon, class: "h-8 w-8 object-contain", alt: "Favicon" %>
              <p class="text-xs text-gray-500 mt-2">Current Favicon</p>
            </div>
          <% else %>
            <div class="mb-4 p-4 bg-gray-50 rounded-lg inline-block">
              <div class="w-8 h-8 bg-blue-900 text-yellow-500 rounded flex items-center justify-center text-xs font-bold">
                SMS
              </div>
              <p class="text-xs text-gray-500 mt-2">Default Favicon</p>
            </div>
          <% end %>
          <input type="file" name="favicon" accept="image/x-icon,image/png,image/jpeg" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500">
          <p class="mt-1 text-xs text-gray-500">Upload ICO, PNG, or JPG. Recommended size: 32x32px or 16x16px</p>
        </div>
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-2">Invoice Footer Text</label>
        <textarea name="settings[footer_text]" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500"><%= @settings[:footer_text].value %></textarea>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_settings_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= submit_tag "Save School Settings", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>