<div class="bg-white rounded-lg shadow-lg p-6">
  <h1 class="text-3xl font-bold text-blue-900 mb-6">Admin Dashboard</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">Total Users</h3>
      <p class="text-3xl font-bold"><%= @users.count %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">Categories</h3>
      <p class="text-3xl font-bold"><%= @categories.count %></p>
    </div>
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">Classes</h3>
      <p class="text-3xl font-bold"><%= @classes.count %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6">
      <h3 class="text-lg font-semibold mb-2">Subjects</h3>
      <p class="text-3xl font-bold"><%= @subjects.count %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <h2 class="text-xl font-bold text-blue-900 mb-4">Recent Users</h2>
      <div class="space-y-2">
        <% @users.limit(5).each do |user| %>
          <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
            <span class="text-gray-700"><%= user.full_name %></span>
            <span class="text-sm <%= user.admin? ? 'text-blue-900 font-semibold' : 'text-gray-500' %>">
              <%= user.admin? ? 'Admin' : 'User' %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
    
    <div>
      <h2 class="text-xl font-bold text-blue-900 mb-4">Quick Actions</h2>
      <div class="space-y-2">
        <%= link_to "Create New User", new_user_registration_path, class: "block w-full text-center bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150" %>
        <%= link_to "Add Category", new_category_path, class: "block w-full text-center bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
        <%= link_to "Add Class", new_school_class_path, class: "block w-full text-center bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150" %>
        <%= link_to "Add Subject", new_subject_path, class: "block w-full text-center bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150" %>
      </div>
    </div>
  </div>
</div>