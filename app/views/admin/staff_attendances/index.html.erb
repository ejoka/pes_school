<% content_for :page_title, "Staff Attendance" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Staff Attendance</h1>
      <p class="text-gray-600 mt-1">Date: <%= @date.strftime("%A, %B %d, %Y") %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Previous Day", admin_staff_attendances_path(date: @date - 1.day), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Today", admin_staff_attendances_path(date: Date.today), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
      <%= link_to "Next Day", admin_staff_attendances_path(date: @date + 1.day), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Weekly Report", weekly_report_admin_staff_attendances_path(date: @date), class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition" %>
      <%= link_to "Monthly Summary", monthly_summary_admin_staff_attendances_path(date: @date), class: "bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition" %>
    </div>
  </div>

  <%= form_tag save_attendance_admin_staff_attendances_path, method: :post, class: "space-y-6" do %>
    <%= hidden_field_tag :date, @date %>

    <div class="overflow-x-auto -mx-4 sm:mx-0">
      <div class="inline-block min-w-full align-middle">
        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
          <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Staff</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Department</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Position</th>
                <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Status</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Check In</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Check Out</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Remarks</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% if @staff_members.any? %>
                <% @staff_members.each do |staff| %>
                  <% existing = @attendance_records[staff.id] %>
                  <tr class="hover:bg-gray-50 transition duration-150">
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                      <div class="flex items-center">
                        <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-2">
                          <span class="text-blue-600 font-semibold text-sm"><%= staff.user.first_name[0].upcase %></span>
                        </div>
                        <%= staff.user.full_name %>
                      </div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <%= staff.department.name %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <%= staff.position %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4">
                      <div class="flex flex-wrap justify-center gap-2">
                        <% @statuses.each do |status| %>
                          <label class="inline-flex items-center cursor-pointer">
                            <%= radio_button_tag "attendances[#{staff.id}]", status.id, existing&.staff_attendance_status_id == status.id, class: "form-radio h-4 w-4 text-yellow-500" %>
                            <span class="ml-1 text-xs font-medium" style="<%= "color: #{status.color.match(/#[A-Fa-f0-9]{6}/)&.to_s}" %>"><%= status.code %></span>
                          </label>
                        <% end %>
                      </div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4">
                      <input type="time" name="check_in_time[<%= staff.id %>]" value="<%= existing&.check_in_time&.strftime("%H:%M") %>" class="w-28 px-2 py-1 border border-gray-300 rounded text-sm focus:ring-yellow-500 focus:border-yellow-500">
                    </td>
                    <td class="whitespace-nowrap px-3 py-4">
                      <input type="time" name="check_out_time[<%= staff.id %>]" value="<%= existing&.check_out_time&.strftime("%H:%M") %>" class="w-28 px-2 py-1 border border-gray-300 rounded text-sm focus:ring-yellow-500 focus:border-yellow-500">
                    </td>
                    <td class="px-3 py-4">
                      <input type="text" name="notes[<%= staff.id %>]" value="<%= existing&.notes %>" class="w-32 px-2 py-1 border border-gray-300 rounded text-sm focus:ring-yellow-500 focus:border-yellow-500" placeholder="Notes...">
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7" class="text-center py-12">
                    <div class="flex flex-col items-center justify-center">
                      <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <p class="text-gray-500 text-lg">No staff members found.</p>
                      <p class="text-gray-400 text-sm mt-1">Please assign staff to departments first.</p>
                      <%= link_to "Assign Staff", admin_staff_assignments_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <% if @staff_members.any? %>
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4">
        <div class="flex flex-wrap gap-2">
          <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'P')&.id %>')" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 transition">Mark All Present</button>
          <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'A')&.id %>')" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition">Mark All Absent</button>
          <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'L')&.id %>')" class="bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition">Mark All Late</button>
          <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'LV')&.id %>')" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition">Mark All Leave</button>
        </div>
        <div class="flex gap-2">
          <%= link_to "Cancel", admin_dashboard_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
          <%= submit_tag "Save Attendance", class: "bg-blue-900 text-yellow-500 px-6 py-2 rounded hover:bg-blue-800 transition font-semibold" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<script>
  function markAll(statusId) {
    const radios = document.querySelectorAll(`input[type="radio"][value="${statusId}"]`);
    radios.forEach(radio => radio.checked = true);
  }
</script>