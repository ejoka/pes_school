<% content_for :page_title, "Staff Attendance" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Staff Attendance</h1>
      <p class="text-gray-600 mt-1">Date: <%= @date.strftime("%A, %B %d, %Y") %></p>
    </div>
    <div class="flex space-x-3">
      <%= link_to "Previous Day", admin_staff_attendances_path(date: @date - 1.day), class: "bg-gray-500 text-white px-4 py-2 rounded" %>
      <%= link_to "Today", admin_staff_attendances_path(date: Date.today), class: "bg-blue-600 text-white px-4 py-2 rounded" %>
      <%= link_to "Next Day", admin_staff_attendances_path(date: @date + 1.day), class: "bg-gray-500 text-white px-4 py-2 rounded" %>
      <%= link_to "Monthly Summary", monthly_summary_admin_staff_attendances_path(date: @date), class: "bg-green-600 text-white px-4 py-2 rounded" %>
    </div>
  </div>

  <%= form_tag save_attendance_admin_staff_attendances_path, method: :post, class: "space-y-6" do %>
    <%= hidden_field_tag :date, @date %>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Staff</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Check In</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Check Out</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Remarks</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @staff_members.each do |staff| %>
            <% existing = @attendance_records[staff.id] %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900"><%= staff.user.full_name %></div>
                <div class="text-xs text-gray-500"><%= staff.position %></div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500">
                <%= staff.department.name %>
              </td>
              <td class="px-4 py-3 text-center">
                <div class="flex flex-wrap justify-center gap-2">
                  <% @statuses.each do |status| %>
                    <label class="inline-flex items-center">
                      <%= radio_button_tag "attendances[#{staff.id}]", status.id, existing&.status_id == status.id, class: "form-radio h-4 w-4 text-yellow-500" %>
                      <span class="ml-1 text-xs"><%= status.code %></span>
                    </label>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3">
                <input type="time" name="check_in_time[<%= staff.id %>]" value="<%= existing&.check_in_time&.strftime("%H:%M") %>" class="w-28 px-2 py-1 border rounded text-sm">
              </td>
              <td class="px-4 py-3">
                <input type="time" name="check_out_time[<%= staff.id %>]" value="<%= existing&.check_out_time&.strftime("%H:%M") %>" class="w-28 px-2 py-1 border rounded text-sm">
              </td>
              <td class="px-4 py-3">
                <input type="text" name="notes[<%= staff.id %>]" value="<%= existing&.notes %>" class="w-full px-2 py-1 border rounded text-sm" placeholder="Notes...">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-between items-center pt-4">
      <div class="flex space-x-4">
        <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'P')&.id %>')" class="bg-green-500 text-white px-4 py-2 rounded">Mark All Present</button>
        <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'A')&.id %>')" class="bg-red-500 text-white px-4 py-2 rounded">Mark All Absent</button>
        <button type="button" onclick="markAll('<%= StaffAttendanceStatus.find_by(code: 'L')&.id %>')" class="bg-yellow-500 text-blue-900 px-4 py-2 rounded">Mark All Late</button>
      </div>
      <div class="flex space-x-3">
        <%= link_to "Cancel", admin_dashboard_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
        <%= submit_tag "Save Attendance", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded font-semibold" %>
      </div>
    </div>
  <% end %>
</div>

<script>
  function markAll(statusId) {
    const radios = document.querySelectorAll(`input[type="radio"][value="${statusId}"]`);
    radios.forEach(radio => radio.checked = true);
  }
</script>