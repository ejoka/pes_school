<% content_for :page_title, "Staff Attendance Weekly Report" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Weekly Attendance Report</h1>
      <p class="text-gray-600 mt-1">Week of <%= @week_start.strftime("%B %d, %Y") %> - <%= @week_end.strftime("%B %d, %Y") %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Previous Week", weekly_report_admin_staff_attendances_path(date: @week_start - 7.days), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Current Week", weekly_report_admin_staff_attendances_path(date: Date.today), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
      <%= link_to "Next Week", weekly_report_admin_staff_attendances_path(date: @week_start + 7.days), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Back to Daily", admin_staff_attendances_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg active:shadow-sm transition-all duration-200 ease-in-out" %>
    </div>
  </div>

  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Staff</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Department</th>
              <% (@week_start..@week_end).each do |day| %>
                <th scope="col" class="px-2 py-3.5 text-center text-xs font-semibold text-gray-900">
                  <%= day.strftime("%a<br>%d") %>
                </th>
              <% end %>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Present</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Absent</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Late</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">%</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @staff_members.each do |staff| %>
              <% staff_attendances = @attendance_records.select { |a| a.staff_assignment_id == staff.id } %>
              <tr class="hover:bg-gray-50 transition duration-150">
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                  <div class="flex items-center">
                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-2">
                      <span class="text-blue-600 font-semibold text-sm"><%= staff.user.first_name[0].upcase %></span>
                    </div>
                    <%= staff.user.full_name %>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <%= staff.department.name %>
                </td>
                <% (@week_start..@week_end).each do |day| %>
                  <% attendance = staff_attendances.find { |a| a.date == day } %>
                  <td class="whitespace-nowrap px-2 py-4 text-center">
                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full <%= attendance&.status_color || 'bg-gray-100' %> text-sm font-semibold">
                      <%= attendance&.status_code || '—' %>
                    </span>
                  </td>
                <% end %>
                <% 
                  present_count = staff_attendances.count { |a| a.staff_attendance_status&.code == 'P' }
                  absent_count = staff_attendances.count { |a| a.staff_attendance_status&.code == 'A' }
                  late_count = staff_attendances.count { |a| a.staff_attendance_status&.code == 'L' }
                  total = staff_attendances.count
                  percentage = total > 0 ? (present_count.to_f / total * 100).round(1) : 0
                %>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-green-600"><%= present_count %></td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-red-600"><%= absent_count %></td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-yellow-600"><%= late_count %></td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-blue-600"><%= percentage %>%</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>