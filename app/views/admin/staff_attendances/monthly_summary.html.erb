<% content_for :page_title, "Staff Attendance Monthly Summary" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Monthly Attendance Summary</h1>
      <p class="text-gray-600 mt-1"><%= @date.strftime("%B %Y") %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Previous Month", monthly_summary_admin_staff_attendances_path(date: @date - 1.month), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Current Month", monthly_summary_admin_staff_attendances_path(date: Date.today), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
      <%= link_to "Next Month", monthly_summary_admin_staff_attendances_path(date: @date + 1.month), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition" %>
      <%= link_to "Back to Daily", admin_staff_attendances_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition" %>
    </div>
  </div>

  <!-- Summary Statistics -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
    <div class="bg-blue-900 text-white rounded-lg p-4">
      <p class="text-sm">Total Staff</p>
      <p class="text-2xl font-bold"><%= @summaries.count %></p>
    </div>
    <div class="bg-green-600 text-white rounded-lg p-4">
      <p class="text-sm">Total Present Days</p>
      <p class="text-2xl font-bold"><%= @summaries.sum(:total_present) %></p>
    </div>
    <div class="bg-red-600 text-white rounded-lg p-4">
      <p class="text-sm">Total Absent Days</p>
      <p class="text-2xl font-bold"><%= @summaries.sum(:total_absent) %></p>
    </div>
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-4">
      <p class="text-sm">Total Late Days</p>
      <p class="text-2xl font-bold"><%= @summaries.sum(:total_late) %></p>
    </div>
    <div class="bg-purple-600 text-white rounded-lg p-4">
      <p class="text-sm">Overall Attendance</p>
      <p class="text-2xl font-bold"><%= @summaries.average(:attendance_percentage).to_f.round(1) %>%</p>
    </div>
  </div>

  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Staff</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Department</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Present</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Absent</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Late</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Leave</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Total</th>
              <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900">Percentage</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @summaries.each do |summary| %>
              <tr class="hover:bg-gray-50 transition duration-150">
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                  <div class="flex items-center">
                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-2">
                      <span class="text-blue-600 font-semibold text-sm"><%= summary.staff_assignment.user.first_name[0].upcase %></span>
                    </div>
                    <%= summary.staff_assignment.user.full_name %>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <%= summary.staff_assignment.department.name %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-green-600">
                  <%= summary.total_present %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-red-600">
                  <%= summary.total_absent %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-yellow-600">
                  <%= summary.total_late %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-blue-600">
                  <%= summary.total_leave %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center font-semibold text-gray-700">
                  <%= summary.total_present + summary.total_absent + summary.total_late + summary.total_leave %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-center">
                  <div class="flex items-center justify-center">
                    <span class="font-bold <%= summary.attendance_percentage >= 90 ? 'text-green-600' : summary.attendance_percentage >= 75 ? 'text-yellow-600' : 'text-red-600' %>">
                      <%= summary.attendance_percentage %>%
                    </span>
                  </div>
                  <div class="w-full bg-gray-200 rounded-full h-1 mt-1">
                    <div class="bg-blue-600 h-1 rounded-full" style="width: <%= summary.attendance_percentage %>%"></div>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>