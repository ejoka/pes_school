<% content_for :page_title, "Stock Movements" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-blue-900">Stock Movements</h1>
      <p class="text-sm text-gray-500 mt-1">Track all inventory movements across the school</p>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-green-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Received</h3>
      <p class="text-2xl font-bold"><%= StockMovement.receipts.sum(:quantity) %></p>
    </div>
    <div class="bg-red-600 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Issued</h3>
      <p class="text-2xl font-bold"><%= StockMovement.issues.sum(:quantity) %></p>
    </div>
    <div class="bg-blue-900 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Movements</h3>
      <p class="text-2xl font-bold"><%= StockMovement.count %></p>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Item</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reference</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recorded By</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @stock_movements.each do |movement| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= movement.date.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= link_to movement.inventory_item.name, admin_inventory_item_path(movement.inventory_item), class: "text-blue-600 hover:text-blue-900" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= movement.movement_type == 'receive' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= movement.movement_type.upcase %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
              <span class="font-semibold"><%= movement.quantity %></span> <%= movement.inventory_item.unit %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= movement.reference_number || '—' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= movement.user&.full_name || 'System' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= link_to "Delete", admin_stock_movement_path(movement), method: :delete, data: { confirm: "Are you sure you want to delete this stock movement for #{movement.inventory_item.name}?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @stock_movements.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No stock movements recorded yet.</p>
      <p class="text-sm text-gray-400 mt-2">Record stock movements from inventory item pages.</p>
    </div>
  <% end %>
</div>
