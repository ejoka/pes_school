<% content_for :page_title, "Record Stock Movement" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Record Stock Movement</h1>
    <%= link_to "Back to Item", admin_inventory_item_path(@inventory_item), class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-2 gap-4">
      <div><span class="font-medium">Item:</span> <%= @inventory_item.name %></div>
      <div><span class="font-medium">Current Stock:</span> <%= @inventory_item.quantity %> <%= @inventory_item.unit %></div>
    </div>
  </div>

  <%= form_with(model: [:admin, @stock_movement], url: admin_stock_movements_path(item_id: @inventory_item.id), local: true, class: "space-y-6") do |f| %>
    <% if @stock_movement.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        <h3 class="font-bold"><%= pluralize(@stock_movement.errors.count, "error") %> prohibited this movement from being saved:</h3>
        <ul class="list-disc list-inside mt-2">
          <% @stock_movement.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :movement_type, "Movement Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex space-x-4">
        <label class="inline-flex items-center">
          <%= f.radio_button :movement_type, "receive", class: "form-radio h-4 w-4 text-green-500" %>
          <span class="ml-2 text-gray-700">Receive (Add Stock)</span>
        </label>
        <label class="inline-flex items-center">
          <%= f.radio_button :movement_type, "issue", class: "form-radio h-4 w-4 text-red-500" %>
          <span class="ml-2 text-gray-700">Issue (Remove Stock)</span>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :quantity, "Quantity", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.number_field :quantity, required: true, min: 0.01, step: 0.01, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
    </div>

    <div>
      <%= f.label :date, "Movement Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.date_field :date, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
    </div>

    <div>
      <%= f.label :reference_number, "Reference Number (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :reference_number, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "PO #, Receipt #, etc." %>
    </div>

    <div>
      <%= f.label :notes, "Notes (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :notes, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_inventory_item_path(@inventory_item), class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600" %>
      <%= f.submit "Record Movement", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 font-semibold" %>
    </div>
  <% end %>
</div>