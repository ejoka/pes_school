<% content_for :page_title, "Route Details: #{@route.name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Route Details</h1>
    <div class="flex space-x-3">
      <%= link_to edit_admin_route_path(@route), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit Route
      <% end %>
      <%= link_to admin_routes_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Routes
      <% end %>
    </div>
  </div>

  <div class="bg-gradient-to-r from-blue-50 to-white rounded-lg p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Route Name</p>
          <p class="text-lg font-semibold text-gray-900"><%= @route.name %></p>
        </div>
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Fare</p>
          <div class="mt-1">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
              <%= @route.formatted_fare %>
            </span>
          </div>
        </div>
      </div>
      <div class="space-y-4">
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Description</p>
          <p class="text-gray-700 mt-1"><%= @route.description.presence || 'No description provided' %></p>
        </div>
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Created</p>
          <p class="text-gray-700"><%= @route.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
      </div>
    </div>
  </div>
</div>