<% content_for :page_title, "Edit Route" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Edit Route</h1>
    <%= link_to admin_routes_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Routes
    <% end %>
  </div>

  <%= form_with(model: [:admin, @route], local: true, class: "space-y-6") do |f| %>
    <% if @route.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <!-- Same error display as new.html.erb -->
      </div>
    <% end %>

    <!-- Same form fields as new.html.erb -->
    <div class="space-y-6">
      <div>
        <%= f.label :name, "Route Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :fare, "Route Fare ($)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :fare, required: true, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_routes_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Route", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>