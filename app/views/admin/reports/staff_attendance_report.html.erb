<% content_for :page_title, "Staff Attendance Report" %>

<div class="bg-white rounded-xl shadow-sm p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Staff Attendance Report</h1>
    <%= link_to "Back to Reports", admin_reports_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <!-- Date Filter -->
  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
        <input type="date" name="start_date" value="<%= params[:start_date] %>" class="w-full px-3 py-2 border rounded-md">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">End Date</label>
        <input type="date" name="end_date" value="<%= params[:end_date] %>" class="w-full px-3 py-2 border rounded-md">
      </div>
      <div class="flex items-end">
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Apply Filter</button>
      </div>
    </form>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-blue-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Total Staff</p>
      <p class="text-2xl font-bold text-blue-900"><%= @summary[:total_staff] %></p>
    </div>
    <div class="bg-green-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Attendance Rate</p>
      <p class="text-2xl font-bold text-green-600"><%= @summary[:attendance_rate] %>%</p>
    </div>
    <div class="bg-yellow-50 rounded-lg p-4">
      <p class="text-sm text-gray-600">Present / Absent</p>
      <p class="text-2xl font-bold text-yellow-600"><%= @summary[:total_present] %> / <%= @summary[:total_absent] %></p>
    </div>
  </div>

  <!-- Coming Soon Message -->
  <div class="text-center py-12">
    <div class="w-24 h-24 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
      <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-700 mb-2">Report Details Coming Soon</h3>
    <p class="text-gray-500">Detailed charts and tables will be displayed here.</p>
  </div>
</div>