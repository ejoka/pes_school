<% content_for :page_title, "Edit Subject" %>
<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Edit Subject</h1>
    <%= link_to "Back to Subjects", admin_subjects_path, class: "inline-flex items-center text-blue-600 hover:text-blue-900 font-medium" %>
  </div>

  <%= form_with(model: [:admin, @subject], local: true, class: "space-y-6") do |f| %>
    <% if @subject.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        <h3 class="font-bold"><%= pluralize(@subject.errors.count, "error") %> prohibited this subject from being saved:</h3>
        <ul class="list-disc list-inside">
          <% @subject.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "e.g., Mathematics, English, Physics" %>
      </div>

      <div>
        <%= f.label :subject_code, "Subject Code", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :subject_code, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "e.g., MATH101, ENG201, SCI301" %>
      </div>

      <div>
        <%= f.label :school_class_id, "Class", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.collection_select :school_class_id, @school_classes, :id, :name, { prompt: "Select a class" }, { required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" } %>
      </div>

      <div>
        <%= f.label :pass_mark, "Pass Mark (%)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :pass_mark, required: true, min: 0, max: 100, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500", placeholder: "0-100" %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_subjects_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Subject", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>