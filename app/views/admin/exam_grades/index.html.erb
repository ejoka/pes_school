<% content_for :page_title, "Exam Grades" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Grades</h1>
      <p class="text-sm text-gray-500 mt-1">Grades arranged from highest to lowest percentage range</p>
    </div>
    <%= link_to new_admin_exam_grade_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add New Grade
    <% end %>
  </div>

  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">
                <div class="flex items-center">
                  Grade Name
                  <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                  </svg>
                </div>
              </th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">
                <div class="flex items-center">
                  Percentage Range
                  <svg class="w-4 h-4 ml-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"></path>
                  </svg>
                </div>
              </th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Description</th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% if @exam_grades.any? %>
              <% @exam_grades.each_with_index do |grade, index| %>
                <tr class="hover:bg-gray-50 transition duration-150">
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                    <div class="flex items-center">
                      <% if index == 0 %>
                        <span class="inline-flex items-center justify-center w-6 h-6 mr-2 bg-yellow-500 text-blue-900 rounded-full text-xs font-bold">1</span>
                      <% elsif index == 1 %>
                        <span class="inline-flex items-center justify-center w-6 h-6 mr-2 bg-gray-400 text-white rounded-full text-xs font-bold">2</span>
                      <% elsif index == 2 %>
                        <span class="inline-flex items-center justify-center w-6 h-6 mr-2 bg-orange-600 text-white rounded-full text-xs font-bold">3</span>
                      <% else %>
                        <span class="inline-flex items-center justify-center w-6 h-6 mr-2 bg-gray-300 text-gray-600 rounded-full text-xs font-bold"><%= index + 1 %></span>
                      <% end %>
                      <%= grade.name %>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <div class="flex flex-col">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <%= grade.percentage_range %>
                      </span>
                      <div class="w-32 mt-1">
                        <div class="flex justify-between text-xs text-gray-400">
                          <span><%= grade.percentage_from %>%</span>
                          <span><%= grade.percentage_to %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-1">
                          <div class="bg-green-500 h-1 rounded-full" style="width: <%= grade.percentage_to - grade.percentage_from %>%"></div>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="px-3 py-4 text-sm text-gray-500 max-w-md">
                    <%= truncate(grade.description, length: 80) if grade.description.present? %>
                    <span class="text-gray-400"><%= 'No description' if grade.description.blank? %></span>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <div class="flex items-center justify-end space-x-3">
                      <%= link_to admin_exam_grade_path(grade), class: "text-green-600 hover:text-green-900 transition", title: "View" do %>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                      <% end %>
                      <%= link_to edit_admin_exam_grade_path(grade), class: "text-blue-600 hover:text-blue-900 transition", title: "Edit" do %>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                      <% end %>
                      <%= link_to admin_exam_grade_path(grade), method: :delete, data: { confirm: "Are you sure you want to delete '#{grade.name}'?" }, class: "text-red-600 hover:text-red-900 transition", title: "Delete" do %>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                      <% end %>
                    </div>
                  </td>
                </td>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center py-12">
                  <div class="flex flex-col items-center justify-center">
                    <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    <p class="text-gray-500 text-lg">No exam grades created yet.</p>
                    <p class="text-gray-400 text-sm mt-1">Get started by creating your first exam grade.</p>
                    <%= link_to new_admin_exam_grade_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition" do %>
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                      </svg>
                      Create First Grade
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Legend for ordering -->
  <% if @exam_grades.any? %>
    <div class="mt-4 flex justify-end">
      <div class="text-xs text-gray-400 flex items-center">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h9"></path>
        </svg>
        Sorted from highest to lowest percentage range
      </div>
    </div>
  <% end %>
</div>