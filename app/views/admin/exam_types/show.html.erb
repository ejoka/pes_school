<% content_for :page_title, "Exam Type: #{@exam_type.name}" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Exam Type Details</h1>
    <div class="flex space-x-3">
      <%= link_to edit_admin_exam_type_path(@exam_type), class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit Exam Type
      <% end %>
      <%= link_to admin_exam_types_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Exam Types
      <% end %>
    </div>
  </div>

  <div class="bg-gradient-to-r from-blue-50 to-white rounded-lg p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Exam Type Name</p>
          <p class="text-lg font-semibold text-gray-900"><%= @exam_type.name %></p>
        </div>
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Average Pass Mark</p>
          <div class="mt-1">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
              <%= @exam_type.average_pass_mark %>%
            </span>
          </div>
          <div class="mt-2">
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= @exam_type.average_pass_mark %>%"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="space-y-4">
        <div class="border-b pb-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Pass Mark Status</p>
          <div class="mt-1">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @exam_type.status_color %>">
              <%= @exam_type.pass_mark_status %> Pass Mark
            </span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-6 pt-4 border-t">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Description</p>
      <p class="text-gray-700 mt-2"><%= @exam_type.description.presence || 'No description provided' %></p>
    </div>
  </div>

  <!-- Information Card -->
  <div class="mt-6 bg-gray-50 rounded-lg p-6">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">About Pass Marks</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="text-center">
        <div class="text-xs text-gray-500">High Pass Mark (≥75%)</div>
        <div class="text-green-600 font-semibold">Excellent Performance</div>
      </div>
      <div class="text-center">
        <div class="text-xs text-gray-500">Medium Pass Mark (50-74%)</div>
        <div class="text-yellow-600 font-semibold">Satisfactory Performance</div>
      </div>
      <div class="text-center">
        <div class="text-xs text-gray-500">Low Pass Mark (&lt;50%)</div>
        <div class="text-red-600 font-semibold">Needs Improvement</div>
      </div>
    </div>
  </div>
</div>