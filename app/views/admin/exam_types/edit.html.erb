<% content_for :page_title, "Edit Exam Type" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">Edit Exam Type</h1>
    <%= link_to admin_exam_types_path, class: "text-blue-600 hover:text-blue-900 inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Exam Types
    <% end %>
  </div>

  <%= form_with(model: [:admin, @exam_type], local: true, class: "space-y-6") do |f| %>
    <% if @exam_type.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 rounded-lg p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@exam_type.errors.count, "error") %> prohibited this exam type from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @exam_type.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Same form fields as new.html.erb -->
    <div class="space-y-6">
      <div>
        <%= f.label :name, "Exam Type Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>

      <div>
        <%= f.label :average_pass_mark, "Average Pass Mark (%)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :average_pass_mark, required: true, step: 0.01, min: 0, max: 100, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
        <div class="mt-2">
          <div class="flex justify-between text-xs text-gray-500 mb-1">
            <span>0%</span>
            <span>50%</span>
            <span>100%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div id="pass_mark_preview" class="bg-blue-600 h-2 rounded-full" style="width: <%= @exam_type.average_pass_mark %>%"></div>
          </div>
        </div>
      </div>

      <div>
        <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-yellow-500 focus:border-yellow-500" %>
      </div>
    </div>

    <div class="flex justify-end space-x-3 pt-4 border-t">
      <%= link_to "Cancel", admin_exam_types_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" %>
      <%= f.submit "Update Exam Type", class: "bg-blue-900 text-yellow-500 px-4 py-2 rounded hover:bg-blue-800 transition duration-150 font-semibold" %>
    </div>
  <% end %>
</div>

<script>
  const passMarkInput = document.querySelector('#exam_type_average_pass_mark');
  const previewBar = document.querySelector('#pass_mark_preview');
  
  if (passMarkInput && previewBar) {
    passMarkInput.addEventListener('input', function() {
      previewBar.style.width = this.value + '%';
    });
  }
</script>