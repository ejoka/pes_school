<% content_for :page_title, "My Tasks" %>

<div class="space-y-6">
  <!-- Header -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">My Tasks</h1>
        <p class="text-gray-500 text-sm mt-1">Tasks assigned to you</p>
      </div>
      <div class="flex space-x-3">
        <div class="bg-blue-50 rounded-lg px-4 py-2 text-center">
          <p class="text-xs text-blue-600">Total Tasks</p>
          <p class="text-xl font-bold text-blue-700"><%= @tasks.count %></p>
        </div>
        <div class="bg-yellow-50 rounded-lg px-4 py-2 text-center">
          <p class="text-xs text-yellow-600">Pending</p>
          <p class="text-xl font-bold text-yellow-700"><%= @tasks.where(status: ['pending', 'in_progress']).count %></p>
        </div>
        <div class="bg-green-50 rounded-lg px-4 py-2 text-center">
          <p class="text-xs text-green-600">Completed</p>
          <p class="text-xl font-bold text-green-700"><%= @tasks.where(status: 'completed').count %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tasks Grid -->
  <% if @tasks.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <% @tasks.each do |task| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-200 overflow-hidden">
          <!-- Task Header -->
          <div class="p-4 border-b bg-gray-50">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 rounded-full <%= task.status == 'completed' ? 'bg-green-500' : 'bg-yellow-500' %>"></div>
                <h3 class="font-semibold text-gray-800"><%= task.title %></h3>
              </div>
              <div class="flex items-center space-x-2">
                <span class="px-2 py-1 text-xs font-medium rounded-full <%= task.priority_color %>">
                  <%= task.priority.humanize %>
                </span>
                <span class="px-2 py-1 text-xs font-medium rounded-full <%= task.status_color %>">
                  <%= task.status.humanize %>
                </span>
              </div>
            </div>
          </div>
          
          <!-- Task Body -->
          <div class="p-4">
            <p class="text-gray-600 text-sm line-clamp-2 mb-3"><%= task.description %></p>
            
            <div class="flex items-center justify-between text-sm">
              <div class="flex items-center space-x-4">
                <!-- Due Date -->
                <div class="flex items-center text-gray-500">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span class="<%= task.due_date < Date.today && task.status != 'completed' ? 'text-red-600 font-medium' : '' %>">
                    <%= task.due_date.strftime("%b %d, %Y") %>
                    <%= ' (Overdue)' if task.due_date < Date.today && task.status != 'completed' %>
                  </span>
                </div>
                
                <!-- Goal Link -->
                <div class="flex items-center text-gray-500">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                  <%= link_to task.goal.title, admin_goal_path(task.goal), class: "text-blue-600 hover:underline truncate max-w-[150px]" %>
                </div>
              </div>
              
              <!-- Complete Button -->
              <% if task.status != 'completed' %>
                <%= button_to complete_admin_goal_task_path(task.goal, task), method: :post, class: "bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors duration-200 flex items-center space-x-1" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>Complete</span>
                <% end %>
              <% else %>
                <div class="flex items-center text-green-600 text-sm">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span>Completed</span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-white rounded-xl shadow-sm p-12 text-center">
      <div class="w-24 h-24 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-1">No tasks assigned</h3>
      <p class="text-gray-500 text-sm">When tasks are assigned to you, they will appear here.</p>
    </div>
  <% end %>
</div>