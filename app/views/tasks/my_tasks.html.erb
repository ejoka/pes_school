<% content_for :page_title, "My Tasks" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-blue-900">My Tasks</h1>
      <p class="text-sm text-gray-500 mt-1">Tasks assigned to you</p>
    </div>
  </div>

  <!-- Task Statistics -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Total Tasks</h3>
      <p class="text-2xl font-bold"><%= @tasks.count %></p>
    </div>
    <div class="bg-gradient-to-r from-yellow-500 to-yellow-400 text-blue-900 rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Pending</h3>
      <p class="text-2xl font-bold"><%= @tasks.where(status: ['pending', 'in_progress']).count %></p>
    </div>
    <div class="bg-gradient-to-r from-green-600 to-green-500 text-white rounded-lg p-6">
      <h3 class="text-sm font-semibold mb-2">Completed</h3>
      <p class="text-2xl font-bold"><%= @tasks.where(status: 'completed').count %></p>
    </div>
  </div>

  <!-- Tasks List -->
  <div class="space-y-4">
    <% @tasks.each do |task| %>
      <div class="border rounded-lg p-4 hover:shadow-lg transition">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-4">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h2 class="text-lg font-semibold text-gray-900"><%= task.title %></h2>
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= task.priority_color %>">
                <%= task.priority.humanize %>
              </span>
              <span class="px-2 py-1 text-xs font-semibold rounded-full <%= task.status_color %>">
                <%= task.status.humanize %>
              </span>
              <% if task.due_date < Date.today && task.status != 'completed' %>
                <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                  Overdue
                </span>
              <% end %>
            </div>
            <p class="text-gray-600 text-sm mb-3"><%= task.description %></p>
            <div class="flex flex-wrap gap-4 text-sm text-gray-500">
              <span class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
                Goal: <%= link_to task.goal.title, admin_goal_path(task.goal), class: "text-blue-600 hover:underline" %>
              </span>
              <span class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                Due: <%= task.due_date.strftime("%b %d, %Y") %>
              </span>
            </div>
          </div>
          <% if task.status != 'completed' %>
            <div class="text-right">
              <%= button_to complete_admin_goal_task_path(task.goal, task), method: :post, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition duration-150" do %>
                Mark Complete
              <% end %>
            </div>
          <% else %>
            <div class="text-right">
              <span class="px-3 py-2 bg-gray-100 text-gray-500 rounded-lg text-sm">Completed</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @tasks.empty? %>
    <div class="text-center py-12">
      <div class="flex flex-col items-center justify-center">
        <svg class="w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
        </svg>
        <p class="text-gray-500 text-lg">No tasks assigned to you yet.</p>
        <p class="text-gray-400 text-sm mt-1">When tasks are assigned, they will appear here.</p>
      </div>
    </div>
  <% end %>
</div>