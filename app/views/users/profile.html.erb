<% content_for :page_title, "My Profile" %>

<div class="bg-white rounded-lg shadow-lg p-6 max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-blue-900">My Profile</h1>
    <div class="space-x-3">
      <%= link_to edit_user_profile_path, class: "bg-yellow-500 text-blue-900 px-4 py-2 rounded hover:bg-yellow-600 transition duration-150 font-semibold" do %>
        Edit Profile
      <% end %>
      <%= link_to dashboard_path, class: "bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition duration-150" do %>
        Back to Dashboard
      <% end %>
    </div>
  </div>

  <!-- Profile Information -->
  <div class="border border-gray-200 rounded-lg p-6 mb-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Personal Information</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <p class="text-sm text-gray-600 mb-1">Title</p>
        <p class="font-medium text-gray-900"><%= @user.title.presence || 'Not specified' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Full Name</p>
        <p class="font-medium text-gray-900"><%= @user.full_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">First Name</p>
        <p class="font-medium text-gray-900"><%= @user.first_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Middle Name</p>
        <p class="font-medium text-gray-900"><%= @user.middle_name.presence || '—' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Last Name</p>
        <p class="font-medium text-gray-900"><%= @user.last_name %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Phone Number</p>
        <p class="font-medium text-gray-900"><%= @user.phone_number.presence || '—' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Email Address</p>
        <p class="font-medium text-gray-900"><%= @user.email %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-600 mb-1">Role</p>
        <p class="font-medium">
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
            <%= @user.role.capitalize %>
          </span>
        </p>
      </div>
    </div>
  </div>

  <!-- Account Information -->
  <div class="border border-gray-200 rounded-lg p-6 mb-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Account Information</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600 mb-1">Member Since</p>
        <p class="font-semibold text-blue-900"><%= @user.created_at.strftime("%B %d, %Y") %></p>
      </div>
      
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600 mb-1">Last Sign In</p>
        <p class="font-semibold text-blue-900">
          <% if @user.last_sign_in_at %>
            <%= @user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") %>
          <% else %>
            <span class="text-gray-500">First sign in</span>
          <% end %>
        </p>
      </div>
      
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600 mb-1">Sign In Count</p>
        <p class="font-semibold text-blue-900"><%= @user.sign_in_count || 0 %></p>
      </div>
      
      <% if @user.last_sign_in_ip %>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">Last IP Address</p>
          <p class="font-semibold text-blue-900 font-mono"><%= @user.last_sign_in_ip %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Resource Access Summary -->
  <div class="border border-gray-200 rounded-lg p-6 mb-6">
    <h2 class="text-xl font-bold text-blue-900 mb-4">Your Access Rights</h2>
    
    <!-- Categories -->
    <div class="mb-6">
      <h3 class="text-lg font-semibold text-blue-800 mb-3">Categories (<%= @user.assigned_categories.count %>)</h3>
      <% if @user.assigned_categories.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @user.assigned_categories.each do |category| %>
            <div class="bg-blue-50 rounded-lg p-3">
              <div class="flex justify-between items-center">
                <span class="font-medium text-gray-900"><%= category.name %></span>
                <% if @user.can_access?(category, :edit) %>
                  <span class="text-xs text-yellow-600">(edit)</span>
                <% end %>
              </div>
              <p class="text-xs text-gray-600 mt-1"><%= category.school_classes.count %> classes</p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No categories assigned yet.</p>
      <% end %>
    </div>

    <!-- Classes -->
    <div class="mb-6">
      <h3 class="text-lg font-semibold text-blue-800 mb-3">Classes (<%= @user.assigned_classes.count %>)</h3>
      <% if @user.assigned_classes.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @user.assigned_classes.each do |school_class| %>
            <div class="bg-green-50 rounded-lg p-3">
              <div class="flex justify-between items-center">
                <span class="font-medium text-gray-900"><%= school_class.name %></span>
                <% if @user.can_access?(school_class, :edit) %>
                  <span class="text-xs text-yellow-600">(edit)</span>
                <% end %>
              </div>
              <p class="text-xs text-gray-600 mt-1">Pass Mark: <%= school_class.pass_mark %>%</p>
              <p class="text-xs text-gray-600"><%= school_class.subjects.count %> subjects</p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No classes assigned yet.</p>
      <% end %>
    </div>

    <!-- Subjects -->
    <div>
      <h3 class="text-lg font-semibold text-blue-800 mb-3">Subjects (<%= @user.assigned_subjects.count %>)</h3>
      <% if @user.assigned_subjects.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @user.assigned_subjects.each do |subject| %>
            <div class="bg-yellow-50 rounded-lg p-3">
              <div class="flex justify-between items-center">
                <span class="font-medium text-gray-900"><%= subject.name %></span>
                <% if @user.can_access?(subject, :edit) %>
                  <span class="text-xs text-yellow-600">(edit)</span>
                <% end %>
              </div>
              <p class="text-xs text-gray-600 mt-1">Code: <%= subject.subject_code %></p>
              <p class="text-xs text-gray-600">Pass Mark: <%= subject.pass_mark %>%</p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No subjects assigned yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Password Change Link -->
  <div class="flex justify-between items-center pt-4">
    <div>
      <%= link_to "Change Password", edit_user_registration_path, class: "text-yellow-600 hover:text-yellow-700 font-semibold" %>
    </div>
  </div>

  <!-- Danger Zone -->
  <div class="mt-8 pt-6 border-t border-red-200">
    <div class="bg-red-50 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-red-700 mb-3">Danger Zone</h3>
      <p class="text-sm text-red-600 mb-4">Once you delete your account, there is no going back. Please be certain.</p>
      <%= button_to "Delete My Account", user_registration_path, 
          data: { confirm: "Are you sure you want to delete your account? This action cannot be undone.", turbo_confirm: "Are you sure you want to delete your account?" }, 
          method: :delete, 
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition duration-150" %>
    </div>
  </div>
</div>