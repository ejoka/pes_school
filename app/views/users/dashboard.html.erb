<% content_for :page_title, "My Dashboard" %>

<div class="bg-white rounded-lg shadow-lg p-6">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-blue-900">Welcome, <%= current_user.full_name %>!</h1>
    <p class="text-gray-600 mt-1">Here's what you have access to</p>
  </div>
  
  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-blue-900 text-white rounded-lg p-6 transform hover:scale-105 transition duration-300">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold mb-2">Categories</h3>
          <p class="text-3xl font-bold"><%= @accessible_categories.count %></p>
        </div>
        <div class="text-4xl opacity-50">📚</div>
      </div>
    </div>
    
    <div class="bg-yellow-500 text-blue-900 rounded-lg p-6 transform hover:scale-105 transition duration-300">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold mb-2">Classes</h3>
          <p class="text-3xl font-bold"><%= @accessible_classes.count %></p>
        </div>
        <div class="text-4xl opacity-50">🏫</div>
      </div>
    </div>
    
    <div class="bg-blue-900 text-white rounded-lg p-6 transform hover:scale-105 transition duration-300">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold mb-2">Subjects</h3>
          <p class="text-3xl font-bold"><%= @accessible_subjects.count %></p>
        </div>
        <div class="text-4xl opacity-50">📖</div>
      </div>
    </div>
  </div>

  <!-- Categories with Actions -->
  <% if @accessible_categories.any? %>
    <div class="mb-8">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Your Categories</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @accessible_categories.each do |category| %>
          <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-lg transition">
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-semibold text-blue-900 text-lg"><%= category.name %></h3>
              <% if current_user.can_access?(category, :edit) %>
                <%= link_to edit_admin_category_path(category), class: "inline-flex items-center p-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-all duration-200 ease-in-out", title: "Edit" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
              <% end %>
            </div>
            <p class="text-sm text-gray-600"><%= category.school_classes.count %> classes</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Classes with Actions -->
  <% if @accessible_classes.any? %>
    <div class="mb-8">
      <h2 class="text-xl font-bold text-blue-900 mb-4">Your Classes</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @accessible_classes.each do |school_class| %>
          <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-lg transition">
            <div class="flex justify-between items-start mb-2">
              <div>
                <h3 class="font-semibold text-blue-900 text-lg"><%= school_class.name %></h3>
                <p class="text-xs text-gray-500"><%= school_class.category.name %></p>
              </div>
              <% if current_user.can_access?(school_class, :edit) %>
                <%= link_to edit_admin_school_class_path(school_class), class: "inline-flex items-center p-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-all duration-200 ease-in-out", title: "Edit" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
              <% end %>
            </div>
            <div class="mt-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Pass Mark:</span>
                <span class="font-semibold"><%= school_class.pass_mark %>%</span>
              </div>
              <div class="flex justify-between text-sm mt-1">
                <span class="text-gray-600">Subjects:</span>
                <span class="text-gray-700"><%= school_class.subjects.count %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Subjects with Actions -->
  <% if @accessible_subjects.any? %>
    <div>
      <h2 class="text-xl font-bold text-blue-900 mb-4">Your Subjects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @accessible_subjects.each do |subject| %>
          <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-lg transition">
            <div class="flex justify-between items-start mb-2">
              <div>
                <h3 class="font-semibold text-blue-900 text-lg"><%= subject.name %></h3>
                <p class="text-xs text-gray-500 font-mono"><%= subject.subject_code %></p>
              </div>
              <% if current_user.can_access?(subject, :edit) %>
                <%= link_to edit_admin_subject_path(subject), class: "inline-flex items-center p-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-all duration-200 ease-in-out", title: "Edit" do %>
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
              <% end %>
            </div>
            <div class="mt-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Class:</span>
                <span class="text-gray-700"><%= subject.school_class.name %></span>
              </div>
              <div class="flex justify-between text-sm mt-1">
                <span class="text-gray-600">Pass Mark:</span>
                <span class="font-semibold"><%= subject.pass_mark %>%</span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Empty State -->
  <% if @accessible_categories.empty? && @accessible_classes.empty? && @accessible_subjects.empty? %>
    <div class="text-center py-12 bg-gray-50 rounded-lg">
      <div class="text-6xl mb-4">🔒</div>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">No Resources Assigned Yet</h3>
      <p class="text-gray-500 mb-4">You don't have access to any categories, classes, or subjects yet.</p>
      <p class="text-sm text-gray-400">Please contact your administrator to get access to resources.</p>
    </div>
  <% end %>
</div>