<h2 class="text-2xl font-bold text-gray-900 mb-2">Welcome back</h2>
<p class="text-gray-500 mb-6">Sign in to <%= Setting.get('school_name', 'School Management System') %></p>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
  <div>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", 
        placeholder: "Email address",
        class: "form-input" %>
  </div>
  
  <div>
    <%= f.password_field :password, autocomplete: "current-password", 
        placeholder: "Password",
        class: "form-input" %>
  </div>

  <div class="flex items-center justify-between">
    <label class="flex items-center cursor-pointer">
      <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-900 rounded border-gray-300" %>
      <span class="ml-2 text-sm text-gray-600">Remember me</span>
    </label>
    <%= link_to "Forgot password?", new_password_path(resource_name), class: "form-link text-sm" %>
  </div>

  <%= f.submit "Sign in", class: "form-button mt-2" %>
<% end %>

<div class="mt-6 text-center">
  <p class="text-sm text-gray-600">
    Don't have an account?
    <%= link_to "Create account", new_registration_path(resource_name), class: "form-link" %>
  </p>
</div>

<% if notice %>
  <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg">
    <p class="text-sm text-green-700"><%= notice %></p>
  </div>
<% end %>

<% if alert %>
  <div class="mt-4 p-3 bg-red-50 border border-red-200 rounded-lg">
    <p class="text-sm text-red-700"><%= alert %></p>
  </div>
<% end %>