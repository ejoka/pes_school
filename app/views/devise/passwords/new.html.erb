<h2 class="text-2xl font-bold text-gray-900 mb-2">Forgot password?</h2>
<p class="text-gray-500 mb-6">Enter your email to reset your password for <%= Setting.get('school_name', 'School Management System') %></p>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  
  <%= f.email_field :email, autofocus: true, autocomplete: "email", 
      placeholder: "Email address",
      class: "form-input" %>

  <%= f.submit "Send reset instructions", class: "form-button mt-2" %>
<% end %>

<div class="mt-6 text-center">
  <%= link_to "Back to sign in", new_session_path(resource_name), class: "form-link" %>
</div>

<% if notice %>
  <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg">
    <p class="text-sm text-green-700"><%= notice %></p>
  </div>
<% end %>

<% if alert %>
  <div class="mt-4 p-3 bg-red-50 border border-red-200 rounded-lg">
    <p class="text-sm text-red-700"><%= alert %></p>
  </div>
<% end %>