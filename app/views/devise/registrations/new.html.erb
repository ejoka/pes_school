<h2 class="text-2xl font-bold text-gray-900 mb-2">Create account</h2>
<p class="text-gray-500 mb-6">Join <%= Setting.get('school_name', 'School Management System') %></p>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-3" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  
  <div class="grid grid-cols-2 gap-3">
    <%= f.text_field :first_name, autofocus: true, placeholder: "First name", class: "form-input" %>
    <%= f.text_field :last_name, placeholder: "Last name", class: "form-input" %>
  </div>
  
  <%= f.text_field :middle_name, placeholder: "Middle name (optional)", class: "form-input" %>
  
  <div class="grid grid-cols-2 gap-3">
    <%= f.select :title, options_for_select([['Mr.', 'Mr.'], ['Mrs.', 'Mrs.'], ['Ms.', 'Ms.'], ['Dr.', 'Dr.'], ['Prof.', 'Prof.']]), { include_blank: 'Select Title' }, class: "form-input" %>
    
    <!-- Professional Type as text field (dynamic) -->
    <%= f.text_field :professional_type, placeholder: "Professional Type (e.g., Teacher, Accountant, Driver)", class: "form-input" %>
  </div>
  
  <%= f.telephone_field :phone_number, placeholder: "Phone number", class: "form-input" %>
  <%= f.email_field :email, placeholder: "Email address", class: "form-input" %>
  <%= f.password_field :password, placeholder: "Password", class: "form-input" %>
  <%= f.password_field :password_confirmation, placeholder: "Confirm password", class: "form-input" %>

  <%= f.submit "Create account", class: "form-button mt-4" %>
<% end %>

<div class="mt-6 text-center">
  <p class="text-sm text-gray-600">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name), class: "form-link" %>
  </p>
</div>