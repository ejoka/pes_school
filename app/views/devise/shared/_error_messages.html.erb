<% if resource.errors.any? %>
  <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
    <div class="flex items-start">
      <svg class="w-5 h-5 text-red-600 mt-0.5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div>
        <h3 class="text-sm font-medium text-red-800 mb-1">
          <%= pluralize(resource.errors.count, "error") %> prevented this account from being created:
        </h3>
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>